<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.diet.mapper.FoodMapper">

    <sql id="baseColumns">
        id,
        user_id,
        name,
        calories_per_100g,
        calorie_unit,
        protein_per_100g,
        carbs_per_100g,
        fat_per_100g,
        quantity_unit,
        category,
        source,
        source_ref,
        aliases,
        image_url,
        is_builtin,
        sort_order,
        created_at
    </sql>

    <sql id="visibleBuiltinScope">
        is_builtin = 1
        AND source IN ('CURATED_CN', 'CURATED_GLOBAL')
    </sql>

    <sql id="accessScope">
        <choose>
            <when test="customOnly">
                user_id = #{userId}
                AND is_builtin = 0
            </when>
            <when test="builtinOnly">
                <include refid="visibleBuiltinScope"/>
            </when>
            <when test="userId != null">
                (<include refid="visibleBuiltinScope"/> OR user_id = #{userId})
            </when>
            <otherwise>
                <include refid="visibleBuiltinScope"/>
            </otherwise>
        </choose>
    </sql>

    <sql id="pageFilters">
        <include refid="accessScope"/>
        <if test="category != null and category != ''">
            AND category = #{category}
        </if>
        <if test="keyword != null and keyword != ''">
            AND (
                LOWER(name) LIKE CONCAT('%', LOWER(#{keyword}), '%')
                OR LOWER(COALESCE(aliases, '')) LIKE CONCAT('%', LOWER(#{keyword}), '%')
            )
        </if>
    </sql>

    <sql id="categorySort">
        CASE
            WHEN category = '主食' THEN 1
            WHEN category = '肉蛋奶' THEN 2
            WHEN category = '蔬果' THEN 3
            WHEN category = '豆制品' THEN 4
            WHEN category = '饮品' THEN 5
            WHEN category = '零食' THEN 6
            WHEN category = '其他' THEN 7
            ELSE 99
        END
    </sql>

    <sql id="keywordSort">
        CASE
            WHEN #{keyword} IS NULL OR #{keyword} = '' THEN 9
            WHEN LOWER(name) = LOWER(#{keyword}) THEN 0
            WHEN LOWER(COALESCE(aliases, '')) LIKE CONCAT('%', LOWER(#{keyword}), '%') THEN 1
            WHEN LOWER(name) LIKE CONCAT('%', LOWER(#{keyword}), '%') THEN 2
            ELSE 8
        END
    </sql>

    <select id="findAccessibleById" resultType="com.diet.domain.food.Food">
        SELECT
            <include refid="baseColumns"/>
        FROM food
        WHERE id = #{id}
        <choose>
            <when test="userId != null">
                AND (is_builtin = 1 OR user_id = #{userId})
            </when>
            <otherwise>
                AND is_builtin = 1
            </otherwise>
        </choose>
        LIMIT 1
    </select>

    <select id="findOwnedCustomById" resultType="com.diet.domain.food.Food">
        SELECT
            <include refid="baseColumns"/>
        FROM food
        WHERE id = #{id}
          AND user_id = #{userId}
          AND is_builtin = 0
        LIMIT 1
    </select>

    <select id="findByAccessibleNameIgnoreCase" resultType="com.diet.domain.food.Food">
        SELECT
            <include refid="baseColumns"/>
        FROM food
        <where>
            LOWER(name) = LOWER(#{name})
            <choose>
                <when test="userId != null">
                    AND (<include refid="visibleBuiltinScope"/> OR user_id = #{userId})
                </when>
                <otherwise>
                    AND <include refid="visibleBuiltinScope"/>
                </otherwise>
            </choose>
        </where>
        LIMIT 1
    </select>

    <select id="findAll" resultType="com.diet.domain.food.Food">
        SELECT
            <include refid="baseColumns"/>
        FROM food
        <where>
            <choose>
                <when test="userId != null">
                    (<include refid="visibleBuiltinScope"/> OR user_id = #{userId})
                </when>
                <otherwise>
                    <include refid="visibleBuiltinScope"/>
                </otherwise>
            </choose>
            <if test="keyword != null and keyword != ''">
                AND (
                    LOWER(name) LIKE CONCAT('%', LOWER(#{keyword}), '%')
                    OR LOWER(COALESCE(aliases, '')) LIKE CONCAT('%', LOWER(#{keyword}), '%')
                )
            </if>
        </where>
        ORDER BY
            CASE
                WHEN is_builtin = 0 THEN 0
                ELSE 1
            END ASC,
            <include refid="keywordSort"/> ASC,
            <include refid="categorySort"/> ASC,
            sort_order ASC,
            name ASC,
            id ASC
    </select>

    <select id="findCustomByUser" resultType="com.diet.domain.food.Food">
        SELECT
            <include refid="baseColumns"/>
        FROM food
        <where>
            user_id = #{userId}
            AND is_builtin = 0
            <if test="keyword != null and keyword != ''">
                AND (
                    LOWER(name) LIKE CONCAT('%', LOWER(#{keyword}), '%')
                    OR LOWER(COALESCE(aliases, '')) LIKE CONCAT('%', LOWER(#{keyword}), '%')
                )
            </if>
        </where>
        ORDER BY
            <include refid="keywordSort"/> ASC,
            <include refid="categorySort"/> ASC,
            sort_order ASC,
            name ASC,
            id ASC
    </select>

    <select id="findPage" resultType="com.diet.domain.food.Food">
        SELECT
            <include refid="baseColumns"/>
        FROM food
        <where>
            <include refid="pageFilters"/>
        </where>
        ORDER BY
            CASE
                WHEN is_builtin = 0 THEN 0
                ELSE 1
            END ASC,
            <include refid="keywordSort"/> ASC,
            <include refid="categorySort"/> ASC,
            sort_order ASC,
            name ASC,
            id ASC
        LIMIT #{size} OFFSET #{offset}
    </select>

    <select id="countPage" resultType="long">
        SELECT COUNT(1)
        FROM food
        <where>
            <include refid="pageFilters"/>
        </where>
    </select>

</mapper>

.exercise-history-page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  min-height: 100vh;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.history-head {
  padding: 24rpx;
}

.history-title {
  color: #37423d;
  font-size: 32rpx;
  font-weight: 700;
}

.history-subtitle {
  color: #7d7c74;
  font-size: 24rpx;
  line-height: 1.6;
  margin-top: 10rpx;
}

.history-group-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.history-group {
  overflow: hidden;
  padding: 24rpx;
}

.group-date {
  color: #7d7c74;
  font-size: 24rpx;
  font-weight: 700;
}

.history-item {
  align-items: center;
  border-bottom: 1rpx solid rgba(107, 144, 132, 0.08);
  display: flex;
  gap: 16rpx;
  justify-content: space-between;
  padding: 20rpx 0;
}

.history-item:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.history-item-main {
  flex: 1;
  min-width: 0;
}

.history-item-title {
  color: #394541;
  font-size: 30rpx;
  font-weight: 700;
}

.history-item-meta {
  color: #7d7c74;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.history-item-arrow {
  color: #9b958a;
  font-size: 34rpx;
  line-height: 1;
}

.history-more-row {
  display: flex;
  justify-content: center;
  padding: 6rpx 0 0;
}

.history-more-btn {
  background: rgba(107, 144, 132, 0.12);
  border: 1rpx solid rgba(107, 144, 132, 0.2);
  border-radius: 999rpx;
  color: #5d8378;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
  padding: 14rpx 26rpx;
}

.history-more-btn.disabled {
  opacity: 0.6;
}

.history-more-end {
  color: #9b958a;
  font-size: 22rpx;
  padding: 14rpx 8rpx 8rpx;
}

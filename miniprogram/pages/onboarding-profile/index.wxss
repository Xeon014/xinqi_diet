.onboarding-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  min-height: 100vh;
  padding-bottom: calc(36rpx + env(safe-area-inset-bottom));
}

.header-panel {
  padding: 24rpx;
}

.header-row {
  align-items: flex-start;
  display: flex;
  justify-content: space-between;
}

.step-meta {
  color: #786d61;
  font-size: 23rpx;
  margin-top: 8rpx;
}

.skip-all {
  color: #1e5a4f;
  font-size: 24rpx;
  font-weight: 700;
}

.content-panel {
  border-left: 8rpx solid rgba(30, 90, 79, 0.62);
  min-height: 440rpx;
  padding: 28rpx;
}

.step-title {
  color: #2f2a24;
  font-size: 34rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
}

.step-desc {
  color: #6f6559;
  font-size: 24rpx;
  line-height: 1.5;
  margin-top: 12rpx;
}

.field-wrap {
  margin-top: 28rpx;
}

.gender-list {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.gender-chip {
  align-items: center;
  background: rgba(255, 255, 255, 0.9);
  border: 2rpx solid rgba(30, 90, 79, 0.16);
  border-radius: 999rpx;
  color: #1e5a4f;
  display: inline-flex;
  font-size: 26rpx;
  font-weight: 700;
  height: 80rpx;
  justify-content: center;
  min-width: 170rpx;
  padding: 0 22rpx;
}

.gender-chip.active {
  background: rgba(30, 90, 79, 0.15);
  border-color: rgba(30, 90, 79, 0.3);
}

.field-picker {
  background: #fffef9;
  border: 2rpx solid rgba(70, 57, 47, 0.12);
  border-radius: 22rpx;
  color: #2f2a24;
  font-size: 28rpx;
  min-height: 88rpx;
  padding: 24rpx;
}

.mode-row {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 28rpx;
}

.mode-chip {
  align-items: center;
  background: rgba(255, 255, 255, 0.86);
  border: 2rpx solid rgba(30, 90, 79, 0.16);
  border-radius: 999rpx;
  color: #1e5a4f;
  display: inline-flex;
  font-size: 24rpx;
  font-weight: 600;
  height: 72rpx;
  justify-content: center;
  min-width: 188rpx;
  padding: 0 20rpx;
}

.mode-chip.active {
  background: rgba(30, 90, 79, 0.16);
  border-color: rgba(30, 90, 79, 0.28);
}

.formula-tip {
  background: rgba(255, 255, 255, 0.84);
  border-radius: 18rpx;
  color: #2f2a24;
  font-size: 24rpx;
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
}

.formula-tip.disabled {
  color: #8f877d;
}

.goal-input-wrap {
  margin-top: 18rpx;
}

.goal-preview {
  color: #1e5a4f;
  font-size: 26rpx;
  font-weight: 700;
  margin-top: 14rpx;
}

.action-row {
  align-items: center;
  display: flex;
  gap: 14rpx;
}

.ghost-button {
  align-items: center;
  background: rgba(30, 90, 79, 0.08);
  border: 2rpx solid rgba(30, 90, 79, 0.14);
  border-radius: 20rpx;
  color: #1e5a4f;
  display: flex;
  font-size: 24rpx;
  font-weight: 700;
  height: 84rpx;
  justify-content: center;
  min-width: 164rpx;
  padding: 0 16rpx;
}

.action-primary {
  flex: 1;
  margin-top: 0;
}
.recommend-btn {
  align-items: center;
  background: linear-gradient(135deg, rgba(30, 90, 79, 0.12) 0%, rgba(30, 90, 79, 0.08) 100%);
  border: 2rpx solid rgba(30, 90, 79, 0.24);
  border-radius: 16rpx;
  color: #1e5a4f;
  display: flex;
  font-size: 26rpx;
  font-weight: 600;
  justify-content: center;
  margin-top: 20rpx;
  padding: 22rpx 24rpx;
}


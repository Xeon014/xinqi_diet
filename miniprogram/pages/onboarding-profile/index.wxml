<view class="page-shell onboarding-page">
  <view class="panel header-panel">
    <view class="header-row">
      <view>
        <view class="section-title">开始建档</view>
        <view class="step-meta">第 {{currentStep + 1}} / {{steps.length}} 步</view>
      </view>
    </view>
  </view>

  <view class="panel content-panel">
    <view class="step-title">{{steps[currentStep].title}}</view>
    <view wx:if="{{steps[currentStep].description}}" class="step-desc">{{steps[currentStep].description}}</view>

    <view wx:if="{{steps[currentStep].key === 'gender'}}" class="gender-list">
      <view
        wx:for="{{genderOptions}}"
        wx:key="value"
        wx:for-item="option"
        class="gender-chip {{form.gender === option.value ? 'active' : ''}}"
        data-value="{{option.value}}"
        bindtap="handleGenderSelect"
      >
        {{option.label}}
      </view>
    </view>

    <view wx:if="{{steps[currentStep].key === 'birthDate'}}" class="field-wrap">
      <picker
        mode="multiSelector"
        range="{{birthDateColumns}}"
        value="{{birthDateColumnIndex}}"
        bindcolumnchange="handleBirthDateColumnChange"
        bindchange="handleBirthDateConfirm"
      >
        <view class="field-picker">{{birthDateDisplay || '请选择生日'}}</view>
      </picker>
    </view>

    <view wx:if="{{steps[currentStep].key === 'height'}}" class="field-wrap">
      <input
        class="field-input"
        type="digit"
        value="{{form.height}}"
        data-field="height"
        bindinput="handleInput"
        placeholder="请输入身高(cm)"
      />
    </view>

    <view wx:if="{{steps[currentStep].key === 'currentWeight'}}" class="field-wrap">
      <input
        class="field-input"
        type="digit"
        value="{{form.currentWeight}}"
        data-field="currentWeight"
        bindinput="handleInput"
        placeholder="请输入体重(kg)"
      />
    </view>

    <view wx:if="{{steps[currentStep].key === 'bmr'}}" class="field-wrap">
      <input
        class="field-input"
        type="number"
        value="{{form.bmr}}"
        data-field="bmr"
        bindinput="handleInput"
        placeholder="请输入基础代谢(kcal/天)"
      />
      <view class="recommend-btn" bindtap="handleUseRecommendedBmr">使用推荐值 {{formulaBmrPreview}}</view>
    </view>

    <view wx:if="{{steps[currentStep].key === 'goal'}}" class="field-wrap">
      <view class="field-wrap goal-input-wrap">
        <input
          class="field-input"
          type="number"
          value="{{form.dailyCalorieTarget}}"
          data-field="dailyCalorieTarget"
          bindinput="handleInput"
          placeholder="请输入目标热量(kcal/天)"
        />
      </view>

      <view class="formula-tip">
        <view>{{baseCaloriesHint}}</view>
      </view>
    </view>
  </view>

  <view class="action-row">
    <view wx:if="{{currentStep > 0}}" class="ghost-button" bindtap="handlePrevStep">上一步</view>
    <view class="primary-button action-primary" bindtap="handleNextStep">
      {{currentStep === steps.length - 1 ? (submitting ? '保存中...' : '完成') : '下一步'}}
    </view>
  </view>
</view>

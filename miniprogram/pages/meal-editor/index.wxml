<view class="page-shell meal-editor-page">
  <view class="panel meal-head">
    <view class="meal-badge">{{mealLabel}}</view>
    <view class="meal-date">{{recordDate}}</view>
    <view class="section-title">{{mealLabel}}</view>
    <view class="section-subtitle">{{mode === 'edit' ? '调整已记录食物，保存后同步到首页' : '添加食物后一次性保存到该餐次'}}</view>
  </view>

  <view class="panel editor-panel">
    <view class="list-head">
      <view class="field-label">食物清单</view>
      <view class="list-count">{{foodItems.length}} 种</view>
    </view>

    <view class="add-food" bindtap="handleChooseFood">+ 添加食物</view>

    <view wx:if="{{foodItems.length}}" class="food-list">
      <view wx:for="{{foodItems}}" wx:key="index" class="food-item">
        <view class="food-item-head">
          <view class="food-name">{{item.name}}</view>
          <view class="food-remove" data-index="{{index}}" bindtap="handleRemoveFood">删除</view>
        </view>

        <view class="food-meta">{{item.caloriesPer100g}} kcal / 100g</view>

        <view class="food-edit-row">
          <view class="quantity-box">
            <input
              class="quantity-input"
              type="digit"
              value="{{item.quantityInGram}}"
              data-index="{{index}}"
              bindinput="handleQuantityInput"
            />
            <view class="quantity-unit">g</view>
          </view>
          <view class="item-calories">{{item.totalCalories}} kcal</view>
        </view>
      </view>
    </view>

    <view wx:else class="empty-tip">{{mode === 'edit' ? '该餐次暂无食物，可点击“添加食物”继续补录。' : '还没有添加食物，先点“添加食物”。'}}</view>
  </view>

  <view class="panel summary-panel">
    <view class="summary-label">本餐热量</view>
    <view class="summary-value">{{mealTotalCalories}} kcal</view>
  </view>

  <view class="primary-button" bindtap="handleSubmit">{{mode === 'edit' ? '保存修改' : '完成'}}</view>
</view>

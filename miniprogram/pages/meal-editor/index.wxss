.meal-editor-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.meal-head {
  background: linear-gradient(130deg, rgba(30, 90, 79, 0.16) 0%, rgba(255, 253, 248, 0.94) 54%);
  border: 1rpx solid rgba(30, 90, 79, 0.15);
  margin-right: 28rpx;
  padding: 30rpx;
}

.meal-badge {
  background: rgba(30, 90, 79, 0.12);
  border-radius: 999rpx;
  color: #1e5a4f;
  display: inline-flex;
  font-size: 22rpx;
  font-weight: 700;
  padding: 10rpx 18rpx;
}

.meal-date {
  color: #7b6f62;
  font-size: 24rpx;
  margin-top: 18rpx;
}

.editor-panel {
  padding: 28rpx;
}

.list-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.list-count {
  color: #7d7062;
  font-size: 24rpx;
}

.add-food {
  align-items: center;
  background: rgba(30, 90, 79, 0.1);
  border: 1rpx solid rgba(30, 90, 79, 0.16);
  border-radius: 22rpx;
  color: #1e5a4f;
  display: flex;
  font-size: 28rpx;
  font-weight: 700;
  height: 88rpx;
  justify-content: center;
  margin-top: 14rpx;
}

.food-list {
  margin-top: 16rpx;
}

.food-item {
  border-top: 1rpx solid rgba(70, 57, 47, 0.12);
  padding: 20rpx 0;
}

.food-item:first-child {
  border-top: none;
}

.food-item-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.food-name {
  color: #2f2a24;
  font-size: 30rpx;
  font-weight: 700;
}

.food-remove {
  color: #b95e3a;
  font-size: 24rpx;
  font-weight: 600;
}

.food-meta {
  color: #7d7062;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.food-edit-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
}

.quantity-box {
  align-items: center;
  display: flex;
}

.quantity-input {
  background: #fffef9;
  border: 2rpx solid rgba(70, 57, 47, 0.14);
  border-radius: 18rpx;
  font-size: 26rpx;
  height: 72rpx;
  padding: 0 16rpx;
  text-align: right;
  width: 180rpx;
}

.quantity-unit {
  color: #6f6255;
  font-size: 24rpx;
  margin-left: 12rpx;
}

.item-calories {
  color: #1e5a4f;
  font-size: 27rpx;
  font-weight: 700;
}

.empty-tip {
  color: #7d7062;
  font-size: 24rpx;
  margin-top: 20rpx;
}

.summary-panel {
  align-items: center;
  background: linear-gradient(140deg, rgba(30, 90, 79, 0.14) 0%, rgba(255, 253, 248, 0.95) 44%);
  display: flex;
  justify-content: space-between;
  padding: 24rpx 28rpx;
}

.summary-label {
  color: #5a4f44;
  font-size: 26rpx;
}

.summary-value {
  color: #1e5a4f;
  font-size: 34rpx;
  font-weight: 700;
}

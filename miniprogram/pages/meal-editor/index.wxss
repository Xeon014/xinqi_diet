.meal-editor-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.meal-head {
  padding: 28rpx;
}

.meal-badge {
  background: rgba(31, 111, 95, 0.1);
  border-radius: 999rpx;
  color: #1f6f5f;
  display: inline-flex;
  font-size: 22rpx;
  padding: 10rpx 18rpx;
}

.meal-date {
  color: #8f8373;
  font-size: 24rpx;
  margin-top: 18rpx;
}

.editor-panel {
  padding: 28rpx;
}

.list-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.list-count {
  color: #8f8373;
  font-size: 24rpx;
}

.add-food {
  align-items: center;
  background: rgba(31, 111, 95, 0.08);
  border-radius: 22rpx;
  color: #1f6f5f;
  display: flex;
  font-size: 28rpx;
  font-weight: 600;
  height: 88rpx;
  justify-content: center;
  margin-top: 12rpx;
}

.food-list {
  margin-top: 16rpx;
}

.food-item {
  border-top: 1rpx solid rgba(93, 76, 58, 0.1);
  padding: 20rpx 0;
}

.food-item:first-child {
  border-top: none;
}

.food-item-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.food-name {
  color: #33261c;
  font-size: 30rpx;
  font-weight: 600;
}

.food-remove {
  color: #bf4d34;
  font-size: 24rpx;
}

.food-meta {
  color: #8f8373;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.food-edit-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
}

.quantity-box {
  align-items: center;
  display: flex;
}

.quantity-input {
  background: #fff;
  border: 2rpx solid rgba(93, 76, 58, 0.08);
  border-radius: 18rpx;
  box-sizing: border-box;
  font-size: 26rpx;
  height: 72rpx;
  padding: 0 16rpx;
  text-align: right;
  width: 180rpx;
}

.quantity-unit {
  color: #6f6355;
  font-size: 24rpx;
  margin-left: 12rpx;
}

.item-calories {
  color: #1f6f5f;
  font-size: 26rpx;
  font-weight: 600;
}

.empty-tip {
  color: #8f8373;
  font-size: 24rpx;
  margin-top: 20rpx;
}

.summary-panel {
  align-items: center;
  display: flex;
  justify-content: space-between;
  padding: 24rpx 28rpx;
}

.summary-label {
  color: #5e5145;
  font-size: 26rpx;
}

.summary-value {
  color: #2f8b78;
  font-size: 34rpx;
  font-weight: 700;
}
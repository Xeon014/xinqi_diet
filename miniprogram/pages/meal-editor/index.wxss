.meal-editor-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.meal-head {
  padding: 18rpx 20rpx;
}

.meal-types {
  display: flex;
  gap: 10rpx;
}

.meal-chip {
  background: rgba(70, 57, 47, 0.08);
  border-radius: 999rpx;
  color: #665b50;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 14rpx;
}

.meal-chip.active {
  background: rgba(30, 90, 79, 0.16);
  color: #1e5a4f;
}

.editor-panel {
  padding: 22rpx;
}

.list-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.list-title {
  color: #5a4f44;
  font-size: 24rpx;
  font-weight: 600;
}

.list-count {
  color: #7d7062;
  font-size: 24rpx;
}

.quick-actions {
  display: grid;
  gap: 10rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 12rpx;
}

.quick-action {
  align-items: center;
  background: rgba(30, 90, 79, 0.1);
  border: 1rpx solid rgba(30, 90, 79, 0.16);
  border-radius: 20rpx;
  color: #1e5a4f;
  display: flex;
  font-size: 25rpx;
  font-weight: 700;
  height: 80rpx;
  justify-content: center;
}

.quick-action.ghost {
  background: #fffef9;
  border-color: rgba(70, 57, 47, 0.18);
  color: #5f5347;
  grid-column: span 2;
}

.food-list {
  margin-top: 12rpx;
}

.food-item {
  border-top: 1rpx solid rgba(70, 57, 47, 0.12);
  padding: 16rpx 0;
}

.food-item:first-child {
  border-top: none;
}

.food-item-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.food-name {
  color: #2f2a24;
  font-size: 30rpx;
  font-weight: 700;
}

.food-remove {
  color: #b95e3a;
  font-size: 24rpx;
  font-weight: 600;
}

.food-meta {
  color: #7d7062;
  font-size: 24rpx;
  margin-top: 6rpx;
}

.food-edit-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
}

.quantity-box {
  align-items: center;
  display: flex;
}

.quantity-input {
  background: #fffef9;
  border: 2rpx solid rgba(70, 57, 47, 0.14);
  border-radius: 18rpx;
  font-size: 26rpx;
  height: 70rpx;
  padding: 0 16rpx;
  text-align: right;
  width: 180rpx;
}

.quantity-unit {
  color: #6f6255;
  font-size: 24rpx;
  margin-left: 12rpx;
}

.item-calories {
  color: #1e5a4f;
  font-size: 27rpx;
  font-weight: 700;
}

.summary-panel {
  padding: 22rpx;
}

.summary-grid {
  display: grid;
  gap: 10rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.summary-item {
  background: rgba(255, 255, 255, 0.75);
  border-radius: 15rpx;
  padding: 12rpx;
}

.summary-label {
  color: #74685c;
  font-size: 22rpx;
}

.summary-value {
  color: #1e5a4f;
  font-size: 27rpx;
  font-weight: 700;
  margin-top: 6rpx;
}

.submit-wrap {
  bottom: calc(28rpx + env(safe-area-inset-bottom));
  left: 26rpx;
  position: fixed;
  right: 26rpx;
  z-index: 30;
}

.progress-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  min-height: 100vh;
  padding-bottom: calc(26rpx + env(safe-area-inset-bottom));
}

.range-panel {
  padding: 18rpx 16rpx 16rpx;
}

.range-tabs {
  background: rgba(107, 144, 132, 0.08);
  border-radius: 22rpx;
  display: flex;
  padding: 6rpx;
}

.range-tab {
  align-items: center;
  border-radius: 16rpx;
  color: #7d7c74;
  display: flex;
  flex: 1;
  font-size: 24rpx;
  font-weight: 600;
  height: 68rpx;
  justify-content: center;
}

.range-tab.active {
  background: rgba(253, 250, 245, 0.94);
  box-shadow: 0 8rpx 14rpx rgba(57, 65, 62, 0.06);
  color: #5d8378;
}

.chart-panel {
  background:
    radial-gradient(circle at 90% 0%, rgba(196, 167, 140, 0.14), transparent 24%),
    linear-gradient(180deg, rgba(253, 250, 245, 0.98) 0%, rgba(247, 242, 235, 0.96) 100%);
  padding: 24rpx 20rpx 20rpx;
  position: relative;
}

.chart-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.chart-latest {
  color: #3b4842;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1.4;
}

.chart-add-btn {
  align-items: center;
  background: rgba(107, 144, 132, 0.1);
  border: 1rpx solid rgba(107, 144, 132, 0.14);
  border-radius: 999rpx;
  color: #5d8378;
  display: flex;
  font-size: 34rpx;
  font-weight: 600;
  height: 54rpx;
  justify-content: center;
  line-height: 1;
  width: 54rpx;
}

.chart-add-btn.disabled {
  background: rgba(145, 166, 159, 0.1);
  border-color: rgba(145, 166, 159, 0.16);
  color: #9bb1ab;
}

.axis-label {
  color: #8a877f;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 20rpx;
  position: absolute;
  right: 22rpx;
}

.axis-label-top {
  top: 86rpx;
}

.axis-label-bottom {
  top: 334rpx;
}

.chart-scroll {
  height: 372rpx;
  width: 100%;
}

.chart-inner {
  height: 372rpx;
  position: relative;
}

.grid-line {
  border-top: 1rpx dashed rgba(107, 144, 132, 0.14);
  left: 0;
  position: absolute;
  right: 0;
}

.grid-line-top {
  top: 36rpx;
}

.grid-line-middle {
  top: 160rpx;
}

.grid-line-bottom {
  top: 284rpx;
}

.trend-segment {
  background: rgba(107, 144, 132, 0.42);
  border-radius: 999rpx;
  height: 4rpx;
  position: absolute;
  transform-origin: 0 50%;
}

.trend-point-wrap {
  align-items: center;
  display: flex;
  height: 108rpx;
  justify-content: center;
  position: absolute;
  transform: translate(-50%, -50%);
  width: 44rpx;
}

.trend-point {
  background: #fcfaf5;
  border: 3rpx solid #6f968b;
  border-radius: 50%;
  box-shadow: 0 5rpx 8rpx rgba(70, 104, 95, 0.12);
  height: 18rpx;
  width: 18rpx;
}

.trend-point.latest,
.trend-point.selected {
  background: #5d8378;
  border-color: #5d8378;
  box-shadow: 0 8rpx 14rpx rgba(70, 104, 95, 0.18);
  height: 20rpx;
  width: 20rpx;
}

.latest-value {
  background: rgba(107, 144, 132, 0.1);
  border-radius: 999rpx;
  color: #5d8378;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 20rpx;
  font-weight: 700;
  left: 50%;
  line-height: 1;
  min-width: 84rpx;
  padding: 8rpx 14rpx;
  position: absolute;
  text-align: center;
  top: -40rpx;
  transform: translateX(-50%);
}

.date-label {
  color: #8a877f;
  font-size: 19rpx;
  position: absolute;
  transform: translateX(-50%);
  white-space: nowrap;
}

.date-label.hidden {
  color: transparent;
}

.chart-empty,
.chart-loading {
  align-items: center;
  color: #8a877f;
  display: flex;
  font-size: 24rpx;
  height: 372rpx;
  justify-content: center;
}

.load-more-row {
  display: flex;
  justify-content: center;
  margin-top: 8rpx;
}

.load-more-btn {
  background: rgba(107, 144, 132, 0.08);
  border: 1rpx solid rgba(107, 144, 132, 0.14);
  border-radius: 999rpx;
  color: #5d8378;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
  padding: 14rpx 26rpx;
}

.load-more-btn.disabled {
  opacity: 0.6;
}

.metric-panel {
  padding: 20rpx;
}

.metric-grid {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.metric-card {
  background: rgba(253, 250, 245, 0.82);
  border: 1rpx solid rgba(107, 144, 132, 0.09);
  border-radius: 24rpx;
  min-height: 156rpx;
  padding: 18rpx 18rpx 16rpx;
  position: relative;
}

.metric-card.active {
  background: linear-gradient(160deg, rgba(249, 246, 240, 0.98), rgba(253, 250, 245, 0.96));
  border-color: rgba(107, 144, 132, 0.16);
  box-shadow: 0 8rpx 14rpx rgba(57, 65, 62, 0.08);
}

.metric-card-action {
  align-items: center;
  color: #5d8378;
  display: flex;
  font-size: 32rpx;
  font-weight: 600;
  height: 44rpx;
  justify-content: center;
  line-height: 1;
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  width: 44rpx;
}

.metric-label {
  color: #7d7c74;
  font-size: 22rpx;
}

.metric-label-circumference {
  font-size: 28rpx;
}

.metric-value-row {
  align-items: baseline;
  display: flex;
  gap: 6rpx;
  margin-top: 8rpx;
}

.metric-value {
  color: #37423d;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1;
}

.metric-value-circumference {
  font-size: 28rpx;
}

.metric-unit {
  color: #7d7c74;
  font-size: 20rpx;
}

.metric-date {
  color: #8a877f;
  font-size: 20rpx;
  margin-top: 10rpx;
}

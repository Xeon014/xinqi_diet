.progress-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  min-height: 100vh;
  padding-bottom: calc(26rpx + env(safe-area-inset-bottom));
}

.range-panel {
  background:
    linear-gradient(150deg, rgba(255, 255, 255, 0.82), rgba(248, 240, 229, 0.86)),
    rgba(255, 252, 246, 0.93);
  border: 1rpx solid rgba(31, 90, 79, 0.14);
  padding: 14rpx;
}

.range-tabs {
  background: rgba(31, 90, 79, 0.08);
  border-radius: 20rpx;
  display: flex;
  padding: 6rpx;
}

.range-tab {
  align-items: center;
  border-radius: 14rpx;
  color: #6f6458;
  display: flex;
  flex: 1;
  font-size: 24rpx;
  font-weight: 600;
  height: 68rpx;
  justify-content: center;
}

.range-tab.active {
  background: #fffef9;
  box-shadow: 0 10rpx 20rpx rgba(55, 41, 31, 0.08);
  color: #1e5a4f;
}

.chart-panel {
  padding: 22rpx 20rpx 20rpx;
  position: relative;
}

.chart-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.chart-latest {
  color: #2f2a24;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.4;
}

.chart-add-btn {
  align-items: center;
  background: rgba(30, 90, 79, 0.1);
  border: 1rpx solid rgba(30, 90, 79, 0.18);
  border-radius: 999rpx;
  color: #1e5a4f;
  display: flex;
  font-size: 34rpx;
  font-weight: 600;
  height: 54rpx;
  justify-content: center;
  line-height: 1;
  width: 54rpx;
}

.chart-add-btn.disabled {
  background: rgba(140, 127, 115, 0.1);
  border-color: rgba(140, 127, 115, 0.14);
  color: #9b8f81;
}

.axis-label {
  color: #8a7e71;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 20rpx;
  position: absolute;
  right: 22rpx;
}

.axis-label-top {
  top: 86rpx;
}

.axis-label-bottom {
  top: 334rpx;
}

.chart-scroll {
  height: 372rpx;
  width: 100%;
}

.chart-inner {
  height: 372rpx;
  position: relative;
}

.grid-line {
  border-top: 1rpx dashed rgba(30, 90, 79, 0.18);
  left: 0;
  position: absolute;
  right: 0;
}

.grid-line-top {
  top: 36rpx;
}

.grid-line-middle {
  top: 160rpx;
}

.grid-line-bottom {
  top: 284rpx;
}

.trend-segment {
  background: rgba(30, 90, 79, 0.46);
  border-radius: 999rpx;
  height: 4rpx;
  position: absolute;
  transform-origin: 0 50%;
}

.trend-point-wrap {
  position: absolute;
  transform: translate(-50%, -50%);
}

.trend-point {
  background: #f6f0e6;
  border: 3rpx solid #1e5a4f;
  border-radius: 50%;
  box-shadow: 0 6rpx 10rpx rgba(30, 90, 79, 0.2);
  height: 18rpx;
  width: 18rpx;
}

.trend-point.latest {
  background: #1e5a4f;
  border-color: #1e5a4f;
  box-shadow: 0 8rpx 18rpx rgba(30, 90, 79, 0.28);
  height: 20rpx;
  width: 20rpx;
}

.trend-point.selected {
  background: #1e5a4f;
  border-color: #1e5a4f;
  box-shadow: 0 10rpx 20rpx rgba(30, 90, 79, 0.34);
  height: 20rpx;
  width: 20rpx;
}

.latest-value {
  background: rgba(30, 90, 79, 0.12);
  border-radius: 999rpx;
  color: #1e5a4f;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 20rpx;
  font-weight: 700;
  left: 50%;
  line-height: 1;
  min-width: 84rpx;
  padding: 8rpx 14rpx;
  position: absolute;
  text-align: center;
  top: -40rpx;
  transform: translateX(-50%);
}

.date-label {
  color: #8c7f72;
  font-size: 19rpx;
  position: absolute;
  transform: translateX(-50%);
  white-space: nowrap;
}

.date-label.hidden {
  color: transparent;
}

.chart-empty {
  align-items: center;
  color: #8f8373;
  display: flex;
  font-size: 24rpx;
  height: 372rpx;
  justify-content: center;
}

.chart-loading {
  align-items: center;
  color: #8f8373;
  display: flex;
  font-size: 24rpx;
  height: 372rpx;
  justify-content: center;
}

.load-more-row {
  display: flex;
  justify-content: center;
  margin-top: 8rpx;
}

.load-more-btn {
  background: rgba(30, 90, 79, 0.1);
  border: 1rpx solid rgba(30, 90, 79, 0.18);
  border-radius: 999rpx;
  color: #1e5a4f;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
  padding: 14rpx 26rpx;
}

.load-more-btn.disabled {
  opacity: 0.6;
}

.metric-panel {
  padding: 20rpx;
}

.metric-grid {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.metric-card {
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(70, 57, 47, 0.1);
  border-radius: 20rpx;
  min-height: 148rpx;
  padding: 16rpx 16rpx 14rpx;
  position: relative;
}

.metric-card.active {
  background: linear-gradient(160deg, rgba(239, 247, 244, 0.96), rgba(252, 248, 240, 0.96));
  border-color: rgba(30, 90, 79, 0.24);
  box-shadow: 0 10rpx 20rpx rgba(30, 90, 79, 0.12);
}

.metric-card-action {
  align-items: center;
  color: #1e5a4f;
  display: flex;
  font-size: 32rpx;
  font-weight: 600;
  height: 44rpx;
  justify-content: center;
  line-height: 1;
  position: absolute;
  right: 10rpx;
  top: 10rpx;
  width: 44rpx;
}

.metric-label {
  color: #6f6458;
  font-size: 22rpx;
}

.metric-label-circumference {
  font-size: 28rpx;
}

.metric-value-row {
  align-items: baseline;
  display: flex;
  gap: 6rpx;
  margin-top: 8rpx;
}

.metric-value {
  color: #2f2a24;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1;
}

.metric-value-circumference {
  font-size: 28rpx;
}

.metric-unit {
  color: #7d7062;
  font-size: 20rpx;
}

.metric-date {
  color: #8f8373;
  font-size: 20rpx;
  margin-top: 10rpx;
}

.sheet-overlay {
  background: rgba(24, 20, 16, 0.44);
  bottom: 0;
  left: 0;
  position: fixed;
  right: 0;
  top: 0;
  z-index: 120;
}

.bottom-sheet {
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  bottom: 0;
  left: 0;
  padding: 24rpx 26rpx calc(34rpx + env(safe-area-inset-bottom));
  position: fixed;
  right: 0;
  z-index: 121;
}

.sheet-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.sheet-title {
  color: #2f2a24;
  font-size: 34rpx;
  font-weight: 700;
}

.sheet-close {
  align-items: center;
  color: #7f7264;
  display: flex;
  font-size: 32rpx;
  height: 48rpx;
  justify-content: center;
  width: 48rpx;
}

.sheet-date,
.sheet-date-picker {
  color: #7a6e61;
  font-size: 23rpx;
  margin-top: 12rpx;
}

.sheet-date-picker {
  background: rgba(30, 90, 79, 0.08);
  border: 1rpx solid rgba(30, 90, 79, 0.12);
  border-radius: 14rpx;
  display: inline-flex;
  padding: 8rpx 16rpx;
}

.sheet-input-row {
  align-items: center;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(70, 57, 47, 0.16);
  border-radius: 20rpx;
  display: flex;
  margin-top: 20rpx;
  overflow: hidden;
}

.sheet-input {
  flex: 1;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 38rpx;
  height: 92rpx;
  padding: 0 22rpx;
}

.sheet-unit {
  color: #6f6458;
  font-size: 26rpx;
  font-weight: 700;
  min-width: 94rpx;
  text-align: center;
}

.sheet-submit-btn {
  align-items: center;
  background: linear-gradient(128deg, #1e5a4f 0%, #2a7364 100%);
  border-radius: 999rpx;
  color: #fffef8;
  display: flex;
  font-size: 28rpx;
  font-weight: 700;
  height: 88rpx;
  justify-content: center;
  margin-top: 24rpx;
}

.sheet-submit-btn.disabled {
  opacity: 0.6;
}

.combo-manage-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.combo-list,
.combo-editor {
  padding: 12rpx 22rpx;
}

.combo-item {
  align-items: center;
  border-bottom: 1rpx solid rgba(70, 57, 47, 0.12);
  display: flex;
  gap: 12rpx;
  justify-content: space-between;
  min-height: 110rpx;
  padding: 14rpx 0;
}

.combo-item:last-child {
  border-bottom: 0;
}

.combo-main {
  flex: 1;
  min-width: 0;
}

.combo-name {
  color: #2f2a24;
  font-size: 30rpx;
  font-weight: 700;
}

.combo-meta {
  color: #74685c;
  font-size: 22rpx;
  margin-top: 6rpx;
}

.combo-actions {
  display: flex;
  gap: 10rpx;
}

.action-btn {
  align-items: center;
  background: rgba(30, 90, 79, 0.1);
  border-radius: 12rpx;
  color: #1e5a4f;
  display: flex;
  font-size: 22rpx;
  font-weight: 700;
  height: 56rpx;
  justify-content: center;
  padding: 0 16rpx;
}

.action-btn.danger {
  background: rgba(185, 94, 58, 0.12);
  color: #b95e3a;
}

.meal-types {
  display: flex;
  gap: 10rpx;
  margin-top: 8rpx;
}

.meal-chip {
  background: rgba(70, 57, 47, 0.08);
  border-radius: 999rpx;
  color: #665b50;
  font-size: 22rpx;
  padding: 8rpx 14rpx;
}

.meal-chip.active {
  background: rgba(30, 90, 79, 0.14);
  color: #1e5a4f;
}

.list-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
}

.add-food-btn {
  color: #1e5a4f;
  font-size: 24rpx;
  font-weight: 700;
}

.food-list {
  margin-top: 10rpx;
}

.food-item {
  border-top: 1rpx solid rgba(70, 57, 47, 0.12);
  padding: 14rpx 0;
}

.food-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.food-name {
  color: #2f2a24;
  font-size: 27rpx;
  font-weight: 700;
}

.food-remove {
  color: #b95e3a;
  font-size: 22rpx;
}

.food-meta {
  color: #74685c;
  font-size: 21rpx;
  margin-top: 6rpx;
}

.food-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-top: 10rpx;
}

.quantity-box {
  align-items: center;
  display: flex;
}

.quantity-input {
  background: #fffef9;
  border: 2rpx solid rgba(70, 57, 47, 0.14);
  border-radius: 14rpx;
  font-size: 24rpx;
  height: 64rpx;
  padding: 0 14rpx;
  text-align: right;
  width: 160rpx;
}

.unit {
  color: #6f6255;
  font-size: 22rpx;
  margin-left: 10rpx;
}

.kcal {
  color: #1e5a4f;
  font-size: 24rpx;
  font-weight: 700;
}

.empty-tip {
  color: #74685c;
  font-size: 22rpx;
  margin-top: 12rpx;
}

.editor-actions {
  display: grid;
  gap: 12rpx;
  grid-template-columns: 1fr 1fr;
  margin-top: 16rpx;
}

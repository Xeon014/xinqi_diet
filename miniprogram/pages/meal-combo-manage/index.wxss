.combo-manage-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.combo-editor-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.manage-head,
.combo-editor-head,
.combo-section,
.editor-footer,
.combo-item,
.list-head,
.editor-head-top,
.food-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.manage-head,
.combo-editor-head,
.combo-section {
  padding: 24rpx;
}

.combo-list {
  overflow: hidden;
  padding: 24rpx;
}

.combo-editor-head,
.combo-section {
  align-items: stretch;
  flex-direction: column;
}

.combo-section.compact-row {
  align-items: center;
  flex-direction: row;
  gap: 18rpx;
}

.editor-head-top {
  align-items: center;
}

.editor-head-actions {
  display: flex;
  gap: 12rpx;
  justify-content: flex-end;
}

.icon-action {
  align-items: center;
  background: rgba(107, 144, 132, 0.1);
  border-radius: 999rpx;
  color: #6d7f78;
  display: flex;
  font-size: 28rpx;
  font-weight: 700;
  height: 64rpx;
  justify-content: center;
  width: 64rpx;
}

.action-btn,
.mini-action {
  align-items: center;
  background: rgba(107, 144, 132, 0.12);
  border-radius: 999rpx;
  color: #5d8378;
  display: flex;
  font-size: 22rpx;
  font-weight: 700;
  justify-content: center;
}

.action-btn {
  min-width: 104rpx;
  padding: 16rpx 22rpx;
}

.action-btn.small {
  min-width: 120rpx;
  padding: 12rpx 20rpx;
}

.mini-action {
  min-width: 88rpx;
  padding: 12rpx 18rpx;
}

.action-btn.danger,
.mini-action.danger {
  background: rgba(187, 134, 108, 0.14);
  color: #bb866c;
}

.list-count {
  color: #7d7c74;
  font-size: 22rpx;
}

.field-label {
  color: #37423d;
  font-size: 24rpx;
  font-weight: 700;
}

.field-input {
  background: rgba(252, 250, 245, 0.96);
  border: 2rpx solid rgba(107, 144, 132, 0.14);
  border-radius: 18rpx;
  box-sizing: border-box;
  color: #37423d;
  font-size: 28rpx;
  height: 88rpx;
  margin-top: 16rpx;
  padding: 0 24rpx;
  width: 100%;
}

.inline-label {
  flex-shrink: 0;
}

.inline-input {
  flex: 1;
  height: 72rpx;
  margin-top: 0;
  min-width: 0;
}

.summary-card {
  gap: 14rpx;
}

.summary-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.summary-brief {
  color: #5d8378;
  font-size: 24rpx;
  font-weight: 700;
}

.summary-grid {
  display: grid;
  gap: 10rpx;
  grid-template-columns: 1.15fr 1fr 1fr 1fr;
}

.summary-item {
  background: rgba(252, 249, 243, 0.96);
  border: 1rpx solid rgba(107, 144, 132, 0.08);
  border-radius: 16rpx;
  min-height: 96rpx;
  padding: 16rpx 18rpx;
}

.summary-item.primary {
  background: linear-gradient(180deg, #f4f1e8 0%, #efe9de 100%);
}

.summary-label {
  color: #7d7c74;
  font-size: 20rpx;
}

.summary-value {
  color: #37423d;
  font-size: 30rpx;
  font-weight: 700;
  margin-top: 10rpx;
}

.summary-unit {
  color: #5d8378;
  font-size: 20rpx;
  margin-top: 4rpx;
}

.combo-food-section {
  gap: 12rpx;
}

.food-list {
  margin-top: 4rpx;
}

.food-item {
  border-top: 1rpx solid rgba(107, 144, 132, 0.1);
  padding: 16rpx 0;
}

.food-item:first-child {
  border-top: 0;
  padding-top: 0;
}

.food-head {
  align-items: center;
}

.food-name {
  color: #37423d;
  font-size: 27rpx;
  font-weight: 700;
}

.food-remove {
  color: #bb866c;
  font-size: 22rpx;
}

.food-meta {
  color: #7d7c74;
  font-size: 21rpx;
  margin-top: 8rpx;
}

.food-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-top: 14rpx;
}

.quantity-box {
  align-items: center;
  display: flex;
}

.quantity-input {
  background: rgba(252, 250, 245, 0.96);
  border: 2rpx solid rgba(107, 144, 132, 0.14);
  border-radius: 14rpx;
  font-size: 24rpx;
  height: 64rpx;
  padding: 0 14rpx;
  text-align: right;
  width: 160rpx;
}

.unit {
  color: #7d7c74;
  font-size: 22rpx;
  margin-left: 10rpx;
}

.kcal {
  color: #5d8378;
  font-size: 24rpx;
  font-weight: 700;
}

.empty-box {
  align-items: center;
  background: rgba(107, 144, 132, 0.06);
  border-radius: 18rpx;
  color: #7d7c74;
  display: flex;
  font-size: 22rpx;
  height: 120rpx;
  justify-content: center;
  margin-top: 4rpx;
}

.danger-link {
  color: #bb866c;
  font-size: 24rpx;
  font-weight: 700;
  padding: 4rpx 6rpx 0;
  text-align: center;
}

.combo-item {
  box-sizing: border-box;
  gap: 12rpx;
  min-height: 110rpx;
  padding: 18rpx 20rpx;
  width: 100%;
}

.combo-main {
  flex: 1;
  min-width: 0;
}

.combo-name {
  color: #37423d;
  font-size: 30rpx;
  font-weight: 700;
}

.combo-meta {
  color: #7d7c74;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.combo-actions {
  display: flex;
  gap: 10rpx;
  flex-shrink: 0;
  justify-content: flex-end;
  margin-left: auto;
}

.combo-swipe-cell {
  border-radius: 24rpx;
  box-shadow: 0 10rpx 20rpx rgba(68, 78, 73, 0.05);
  margin-top: 12rpx;
  overflow: hidden;
  position: relative;
}

.combo-swipe-cell:first-of-type {
  margin-top: 16rpx;
}

.swipe-action-track {
  align-items: center;
  display: flex;
  inset: 0;
  justify-content: flex-end;
  position: absolute;
}

.swipe-action-shell {
  align-items: center;
  border-radius: 24rpx;
  display: flex;
  height: 100%;
  justify-content: center;
  width: 84px;
}

.combo-swipe-content {
  background: linear-gradient(180deg, #fdfcf8 0%, #f8f5ee 100%);
  border: 1rpx solid rgba(91, 126, 115, 0.11);
  border-radius: 24rpx;
  position: relative;
  z-index: 1;
}

.swipe-delete-btn {
  height: 64rpx;
  width: 64rpx;
}

.editor-footer-placeholder {
  height: 140rpx;
}

.editor-footer {
  bottom: calc(env(safe-area-inset-bottom) + 24rpx);
  box-shadow: 0 18rpx 48rpx rgba(55, 66, 61, 0.1);
  display: grid;
  gap: 12rpx;
  grid-template-columns: 1fr 1fr;
  left: 24rpx;
  padding: 20rpx;
  position: fixed;
  right: 24rpx;
  z-index: 10;
}

<view class="page-shell metric-history-page">
  <view class="panel history-head">
    <view class="history-title">{{metricLabel}}记录</view>
    <view class="history-add-btn {{canCreate ? '' : 'disabled'}}" bindtap="handleOpenEditor">+</view>
  </view>

  <view wx:if="{{records.length}}" class="history-list">
    <view wx:for="{{records}}" wx:key="date" wx:for-item="item" class="panel history-item">
      <view class="history-item-left">
        <view class="history-item-date">{{item.date}}</view>
      </view>
      <view class="history-item-right">
        <view class="history-item-value">{{item.valueLabel}}</view>
        <view wx:if="{{item.unit}}" class="history-item-unit">{{item.unit}}</view>
      </view>
    </view>

    <view class="history-more-row">
      <view wx:if="{{hasMore}}" class="history-more-btn {{loading ? 'disabled' : ''}}" bindtap="handleLoadMore">
        {{loading ? '加载中...' : '加载更多'}}
      </view>
      <view wx:else class="history-more-end">已展示全部</view>
    </view>
  </view>

  <view wx:else class="panel history-empty">
    <view class="history-empty-text">暂无记录</view>
    <view wx:if="{{canCreate}}" class="history-empty-btn" bindtap="handleOpenEditor">去记录</view>
  </view>

  <view wx:if="{{editorVisible}}" class="sheet-overlay" bindtap="handleCloseEditor"></view>
  <view wx:if="{{editorVisible}}" class="bottom-sheet panel" catchtouchmove="noop">
    <view class="sheet-head">
      <view class="sheet-title">记录{{metricLabel}}</view>
      <view class="sheet-close" bindtap="handleCloseEditor">✕</view>
    </view>
    <picker mode="date" value="{{editorDate}}" bindchange="handleEditorDateChange" disabled="{{editorLoading}}">
      <view class="sheet-date-picker">日期：{{editorDate}}</view>
    </picker>
    <view class="sheet-input-row">
      <input
        class="sheet-input"
        type="digit"
        value="{{editorValue}}"
        placeholder="请输入数值"
        bindinput="handleEditorInput"
      />
      <view class="sheet-unit">{{metricUnit}}</view>
    </view>
    <view class="sheet-submit-btn {{editorLoading ? 'disabled' : ''}}" bindtap="handleSubmitEditor">
      {{editorLoading ? '保存中...' : '保存'}}
    </view>
  </view>
</view>

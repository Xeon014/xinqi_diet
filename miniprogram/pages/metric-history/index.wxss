.metric-history-page {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  min-height: 100vh;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.history-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
}

.history-title {
  color: #2f2a24;
  font-size: 32rpx;
  font-weight: 700;
}

.history-add-btn {
  align-items: center;
  background: rgba(30, 90, 79, 0.1);
  border: 1rpx solid rgba(30, 90, 79, 0.18);
  border-radius: 999rpx;
  color: #1e5a4f;
  display: flex;
  font-size: 34rpx;
  font-weight: 600;
  height: 54rpx;
  justify-content: center;
  line-height: 1;
  width: 54rpx;
}

.history-add-btn.disabled {
  background: rgba(140, 127, 115, 0.1);
  border-color: rgba(140, 127, 115, 0.14);
  color: #9b8f81;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.history-item {
  align-items: center;
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
}

.history-item-date {
  color: #6f6458;
  font-size: 24rpx;
}

.history-item-right {
  align-items: baseline;
  display: flex;
  gap: 6rpx;
}

.history-item-value {
  color: #2f2a24;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1;
}

.history-item-unit {
  color: #7d7062;
  font-size: 22rpx;
}

.history-more-row {
  display: flex;
  justify-content: center;
  margin-top: 8rpx;
}

.history-more-btn {
  background: rgba(30, 90, 79, 0.1);
  border: 1rpx solid rgba(30, 90, 79, 0.18);
  border-radius: 999rpx;
  color: #1e5a4f;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
  padding: 14rpx 26rpx;
}

.history-more-btn.disabled {
  opacity: 0.6;
}

.history-more-end {
  color: #908273;
  font-size: 22rpx;
  padding: 14rpx 8rpx 8rpx;
}

.history-empty {
  align-items: center;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  justify-content: center;
  min-height: 280rpx;
  padding: 30rpx;
}

.history-empty-text {
  color: #8f8373;
  font-size: 24rpx;
}

.history-empty-btn {
  align-items: center;
  background: rgba(30, 90, 79, 0.1);
  border: 1rpx solid rgba(30, 90, 79, 0.18);
  border-radius: 999rpx;
  color: #1e5a4f;
  display: flex;
  font-size: 24rpx;
  font-weight: 600;
  height: 72rpx;
  justify-content: center;
  padding: 0 28rpx;
}

.sheet-overlay {
  background: rgba(24, 20, 16, 0.44);
  bottom: 0;
  left: 0;
  position: fixed;
  right: 0;
  top: 0;
  z-index: 120;
}

.bottom-sheet {
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  bottom: 0;
  left: 0;
  padding: 24rpx 26rpx calc(34rpx + env(safe-area-inset-bottom));
  position: fixed;
  right: 0;
  z-index: 121;
}

.sheet-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.sheet-title {
  color: #2f2a24;
  font-size: 34rpx;
  font-weight: 700;
}

.sheet-close {
  align-items: center;
  color: #7f7264;
  display: flex;
  font-size: 32rpx;
  height: 48rpx;
  justify-content: center;
  width: 48rpx;
}

.sheet-date,
.sheet-date-picker {
  color: #7a6e61;
  font-size: 23rpx;
  margin-top: 12rpx;
}

.sheet-date-picker {
  background: rgba(30, 90, 79, 0.08);
  border: 1rpx solid rgba(30, 90, 79, 0.12);
  border-radius: 14rpx;
  display: inline-flex;
  padding: 8rpx 16rpx;
}

.sheet-input-row {
  align-items: center;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(70, 57, 47, 0.16);
  border-radius: 20rpx;
  display: flex;
  margin-top: 20rpx;
  overflow: hidden;
}

.sheet-input {
  flex: 1;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 38rpx;
  height: 92rpx;
  padding: 0 22rpx;
}

.sheet-unit {
  color: #6f6458;
  font-size: 26rpx;
  font-weight: 700;
  min-width: 94rpx;
  text-align: center;
}

.sheet-submit-btn {
  align-items: center;
  background: linear-gradient(128deg, #1e5a4f 0%, #2a7364 100%);
  border-radius: 999rpx;
  color: #fffef8;
  display: flex;
  font-size: 28rpx;
  font-weight: 700;
  height: 88rpx;
  justify-content: center;
  margin-top: 24rpx;
}

.sheet-submit-btn.disabled {
  opacity: 0.6;
}

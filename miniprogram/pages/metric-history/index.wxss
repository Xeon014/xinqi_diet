.metric-history-page {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  min-height: 100vh;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.history-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
}

.history-title {
  color: #37423d;
  font-size: 32rpx;
  font-weight: 700;
}

.history-add-btn {
  align-items: center;
  background: rgba(107, 144, 132, 0.12);
  border: 1rpx solid rgba(107, 144, 132, 0.2);
  border-radius: 999rpx;
  color: #5d8378;
  display: flex;
  font-size: 34rpx;
  font-weight: 600;
  height: 54rpx;
  justify-content: center;
  line-height: 1;
  width: 54rpx;
}

.history-add-btn.disabled {
  background: rgba(140, 127, 115, 0.1);
  border-color: rgba(140, 127, 115, 0.14);
  color: #9b8f81;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.history-swipe-cell {
  background: #f2efe8;
  border-radius: 32rpx;
  box-shadow:
    0 14rpx 30rpx rgba(68, 78, 73, 0.07),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
  overflow: hidden;
  position: relative;
}

.history-action-track {
  align-items: center;
  display: flex;
  inset: 0;
  justify-content: flex-end;
  position: absolute;
}

.history-action-shell {
  align-items: center;
  display: flex;
  height: 100%;
  justify-content: center;
  width: 84px;
}

.history-delete-action {
  height: 64rpx;
  width: 64rpx;
}

.history-swipe-content {
  background:
    linear-gradient(180deg, #fdfcf8 0%, #f8f5ee 100%),
    #fcfaf5;
  border: 1rpx solid rgba(91, 126, 115, 0.11);
  border-radius: 32rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
  position: relative;
  z-index: 1;
}

.history-item {
  align-items: center;
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
}

.history-item-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-item-date {
  color: #7d7c74;
  font-size: 24rpx;
}

.history-item-time {
  color: #9b958a;
  font-size: 22rpx;
}

.history-item-right {
  align-items: baseline;
  display: flex;
  gap: 6rpx;
}

.history-item-value {
  color: #37423d;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1;
}

.history-item-unit {
  color: #7d7c74;
  font-size: 22rpx;
}

.history-more-row {
  display: flex;
  justify-content: center;
  margin-top: 8rpx;
}

.history-more-btn {
  background: rgba(107, 144, 132, 0.12);
  border: 1rpx solid rgba(107, 144, 132, 0.2);
  border-radius: 999rpx;
  color: #5d8378;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
  padding: 14rpx 26rpx;
}

.history-more-btn.disabled {
  opacity: 0.6;
}

.history-more-end {
  color: #9b958a;
  font-size: 22rpx;
  padding: 14rpx 8rpx 8rpx;
}

.history-empty {
  align-items: center;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  justify-content: center;
  min-height: 280rpx;
  padding: 30rpx;
}

.history-empty-text {
  color: #9b958a;
  font-size: 24rpx;
}

.history-empty-btn {
  align-items: center;
  background: rgba(107, 144, 132, 0.12);
  border: 1rpx solid rgba(107, 144, 132, 0.2);
  border-radius: 999rpx;
  color: #5d8378;
  display: flex;
  font-size: 24rpx;
  font-weight: 600;
  height: 72rpx;
  justify-content: center;
  padding: 0 28rpx;
}

.metric-history-page {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  min-height: 100vh;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}

.history-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
}

.history-title {
  color: #2f2a24;
  font-size: 32rpx;
  font-weight: 700;
}

.history-add-btn {
  align-items: center;
  background: rgba(30, 90, 79, 0.1);
  border: 1rpx solid rgba(30, 90, 79, 0.18);
  border-radius: 999rpx;
  color: #1e5a4f;
  display: flex;
  font-size: 34rpx;
  font-weight: 600;
  height: 54rpx;
  justify-content: center;
  line-height: 1;
  width: 54rpx;
}

.history-add-btn.disabled {
  background: rgba(140, 127, 115, 0.1);
  border-color: rgba(140, 127, 115, 0.14);
  color: #9b8f81;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.history-item {
  align-items: center;
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
}

.history-item-left {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.history-item-date {
  color: #6f6458;
  font-size: 24rpx;
}

.history-item-time {
  color: #a08f7f;
  font-size: 22rpx;
}

.history-item-right {
  align-items: baseline;
  display: flex;
  gap: 6rpx;
}

.history-item-value {
  color: #2f2a24;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 36rpx;
  font-weight: 800;
  line-height: 1;
}

.history-item-unit {
  color: #7d7062;
  font-size: 22rpx;
}

.history-more-row {
  display: flex;
  justify-content: center;
  margin-top: 8rpx;
}

.history-more-btn {
  background: rgba(30, 90, 79, 0.1);
  border: 1rpx solid rgba(30, 90, 79, 0.18);
  border-radius: 999rpx;
  color: #1e5a4f;
  font-size: 22rpx;
  font-weight: 600;
  line-height: 1;
  padding: 14rpx 26rpx;
}

.history-more-btn.disabled {
  opacity: 0.6;
}

.history-more-end {
  color: #908273;
  font-size: 22rpx;
  padding: 14rpx 8rpx 8rpx;
}

.history-empty {
  align-items: center;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  justify-content: center;
  min-height: 280rpx;
  padding: 30rpx;
}

.history-empty-text {
  color: #8f8373;
  font-size: 24rpx;
}

.history-empty-btn {
  align-items: center;
  background: rgba(30, 90, 79, 0.1);
  border: 1rpx solid rgba(30, 90, 79, 0.18);
  border-radius: 999rpx;
  color: #1e5a4f;
  display: flex;
  font-size: 24rpx;
  font-weight: 600;
  height: 72rpx;
  justify-content: center;
  padding: 0 28rpx;
}

.food-item-editor-page {
  min-height: 100vh;
  position: relative;
}

.overlay {
  background: rgba(54, 66, 61, 0.22);
  inset: 0;
  position: fixed;
}

.sheet {
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  bottom: 0;
  left: 0;
  padding: 26rpx 26rpx calc(26rpx + env(safe-area-inset-bottom));
  position: fixed;
  right: 0;
  z-index: 20;
}

.sheet-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.sheet-title {
  color: #37423d;
  font-size: 30rpx;
  font-weight: 700;
}

.sheet-subtitle {
  color: #7d7c74;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.sheet-close {
  align-items: center;
  background: rgba(107, 144, 132, 0.1);
  border-radius: 999rpx;
  color: #6d7f78;
  display: flex;
  font-size: 26rpx;
  font-weight: 700;
  height: 56rpx;
  justify-content: center;
  line-height: 1;
  width: 56rpx;
}

.food-header {
  margin-top: 18rpx;
}

.food-header.with-image {
  align-items: center;
  display: flex;
  gap: 18rpx;
}

.food-image {
  border-radius: 22rpx;
  flex-shrink: 0;
  height: 120rpx;
  width: 120rpx;
}

.food-copy {
  flex: 1;
  min-width: 0;
}

.food-name {
  color: #37423d;
  font-size: 36rpx;
  font-weight: 700;
}

.food-meta {
  color: #7d7c74;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.editor-row {
  margin-top: 20rpx;
}

.quantity-wrap {
  align-items: center;
  display: flex;
}

.quantity-input {
  background: rgba(252, 250, 245, 0.96);
  border: 2rpx solid rgba(107, 144, 132, 0.14);
  border-radius: 18rpx;
  font-size: 30rpx;
  height: 84rpx;
  padding: 0 20rpx;
  text-align: right;
  width: 220rpx;
}

.quantity-unit {
  color: #7d7c74;
  font-size: 25rpx;
  margin-left: 12rpx;
}

.nutrition-grid {
  display: grid;
  gap: 10rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 18rpx;
}

.nutrition-item {
  background: rgba(252, 250, 245, 0.84);
  border-radius: 16rpx;
  padding: 12rpx;
}

.nutrition-label {
  color: #7d7c74;
  font-size: 22rpx;
}

.nutrition-value {
  color: #5d8378;
  font-size: 26rpx;
  font-weight: 700;
  margin-top: 8rpx;
}

.delete-row {
  color: #bb866c;
  font-size: 25rpx;
  font-weight: 600;
  margin-top: 20rpx;
  padding: 10rpx 0;
  text-align: center;
}

.action-row {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.action-btn {
  align-items: center;
  border-radius: 999rpx;
  display: flex;
  flex: 1;
  font-size: 26rpx;
  font-weight: 700;
  height: 88rpx;
  justify-content: center;
}

.action-btn.primary {
  background: linear-gradient(128deg, #6f968b 0%, #5d8378 100%);
  border: 1rpx solid rgba(93, 131, 120, 0.24);
  color: #fffdfa;
}

.action-btn.secondary {
  background: rgba(107, 144, 132, 0.12);
  border: 1rpx solid rgba(107, 144, 132, 0.2);
  color: #5d8378;
}

.action-btn.disabled {
  opacity: 0.6;
}

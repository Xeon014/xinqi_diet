<view class="page-shell home-page">
  <view class="panel date-panel">
    <view class="date-switch-row">
      <view class="date-step" bindtap="handlePrevDay">前一天</view>
      <picker mode="date" value="{{recordDate}}" bindchange="handleDateChange">
        <view class="date-center">
          <view class="date-label">{{displayDateLabel || recordDate}}</view>
          <view
            wx:if="{{displayDateLabel !== '今天'}}"
            class="date-today-link"
            catchtap="handleBackToToday"
          >
            回到今天
          </view>
        </view>
      </picker>
      <view class="date-step" bindtap="handleNextDay">后一天</view>
    </view>
  </view>

  <view class="hero panel">
    <view class="hero-head">
      <view>
        <view class="hero-title">今日净热量</view>
      </view>
    </view>

    <view class="hero-main">
      <view class="hero-value">{{homeLoading && !homeLoaded ? '--' : summary.netCalories}}</view>
      <view class="hero-unit">kcal</view>
    </view>

    <view class="hero-status {{summary.hasTarget && summary.exceededTarget ? 'danger' : ''}}">
      <block wx:if="{{homeLoading && !homeLoaded}}">加载中...</block>
      <block wx:elif="{{summary.hasTarget}}">
        {{summary.exceededTarget ? '已超目标' : '剩余'}} {{summary.remainingAbs}} kcal
      </block>
      <block wx:else>目标热量未设置</block>
    </view>

    <view class="hero-metrics">
      <view class="metric-item metric-item-main">
        <view class="metric-head">
          <view class="metric-label">饮食摄入</view>
          <view
            wx:if="{{dailyNutritionVisible}}"
            class="metric-nutrition-btn"
            catchtap="handleOpenDailyNutrition"
          >
            <view class="nutrition-icon">
              <view class="nutrition-bar nutrition-bar-1"></view>
              <view class="nutrition-bar nutrition-bar-2"></view>
              <view class="nutrition-bar nutrition-bar-3"></view>
            </view>
          </view>
        </view>
        <view class="metric-value">
          <block wx:if="{{homeLoading && !homeLoaded}}">--</block>
          <block wx:else>+{{summary.dietCalories}}</block>
        </view>
      </view>
      <view class="metric-item">
        <view class="metric-label">运动消耗</view>
        <view class="metric-value">
          <block wx:if="{{homeLoading && !homeLoaded}}">--</block>
          <block wx:else>-{{summary.exerciseCalories}}</block>
        </view>
      </view>
      <view class="metric-item">
        <view class="metric-label">今日目标</view>
        <view class="metric-value">
          <block wx:if="{{homeLoading && !homeLoaded}}">--</block>
          <block wx:elif="{{summary.targetCalories == null}}">--</block>
          <block wx:else>{{summary.targetCalories}}</block>
        </view>
      </view>
    </view>

    <view wx:if="{{summary.summaryText}}" class="hero-tip">{{summary.summaryText}}</view>

  </view>

  <view class="section-head">
    <view class="section-title">记录</view>
  </view>

  <view wx:if="{{homeLoading && !homeLoaded}}" class="panel home-loading-card">加载中...</view>
  <view
    wx:elif="{{dailyWeight.hasRecord || recordGroups.length || recommendedMealPrompt.visible}}"
    class="record-groups"
    bindtap="handleRecordListTap"
  >
    <view wx:if="{{dailyWeight.hasRecord}}" class="panel weight-record-panel" catchtap="handleOpenWeightEditor">
      <view class="weight-record-line">
        <view class="weight-record-title">{{dailyWeight.title}}</view>
      </view>
    </view>
    <block
      wx:for="{{recordGroups}}"
      wx:key="key"
      wx:for-item="group"
    >
      <view
        wx:if="{{group.type === 'PROMPT'}}"
        class="panel record-prompt-card"
      >
        <view class="record-prompt-main">
          <view class="record-prompt-title">{{group.label}}</view>
        </view>
        <view
          class="record-prompt-action"
          data-meal-type="{{group.mealType}}"
          catchtap="handleOpenRecommendedMealPrompt"
        >
          {{group.actionText}}
        </view>
      </view>
      <view
        wx:else
        class="record-group panel {{group.type === 'EXERCISE' ? 'record-group-exercise' : 'record-group-diet'}}"
      >
        <block wx:if="{{group.type === 'DIET'}}">
          <view
            class="group-head {{group.collapsed ? 'collapsed' : ''}}"
            data-meal-type="{{group.mealType}}"
            bindtouchstart="handleMealGroupTouchStart"
            bindtouchmove="handleMealGroupTouchMove"
            bindtouchcancel="handleMealGroupTouchCancel"
            catchtap="handleToggleMealGroup"
          >
            <view class="group-main">
              <view class="group-accent"></view>
              <view class="group-title">{{group.label}}</view>
              <view wx:if="{{group.collapsed}}" class="group-inline-calories">{{group.totalCaloriesLabel}}</view>
            </view>
            <view class="group-side">
              <view class="group-actions">
                <view
                  class="group-action-btn group-action-nutrition"
                  data-meal-type="{{group.mealType}}"
                  catchtap="handleOpenMealNutrition"
                >
                  <view class="nutrition-icon">
                    <view class="nutrition-bar nutrition-bar-1"></view>
                    <view class="nutrition-bar nutrition-bar-2"></view>
                    <view class="nutrition-bar nutrition-bar-3"></view>
                  </view>
                </view>
                <view
                  class="group-action-btn group-action-add"
                  data-meal-type="{{group.mealType}}"
                  catchtap="handleQuickAddMeal"
                >
                  +
                </view>
              </view>
            </view>
          </view>
        </block>
        <block wx:else>
          <view class="group-head">
            <view class="group-main">
              <view class="group-accent"></view>
              <view class="group-title">{{group.label}}</view>
            </view>
            <view class="group-side">
              <view class="group-actions">
                <view
                  class="group-action-btn group-action-exercise"
                  catchtap="handleQuickAddExercise"
                >
                  <view class="group-exercise-icon">
                    <view class="group-exercise-stroke"></view>
                  </view>
                </view>
              </view>
            </view>
          </view>
        </block>

        <view wx:if="{{group.records.length && !group.collapsed}}" class="group-list" catchtap="noop">
          <view
            wx:for="{{group.records}}"
            wx:key="recordKey"
            wx:for-item="record"
            class="stream-swipe-cell"
            data-record-key="{{record.recordKey}}"
            bindtouchstart="handleRecordTouchStart"
            bindtouchmove="handleRecordTouchMove"
            bindtouchend="handleRecordTouchEnd"
            bindtouchcancel="handleRecordTouchEnd"
          >
            <view class="stream-action-track">
              <view class="stream-action-shell">
                <view
                  class="stream-repeat-btn"
                  data-record-type="{{record.recordType}}"
                  data-record-id="{{record.recordId}}"
                  data-meal-type="{{record.mealType}}"
                  data-record-date="{{record.recordDate}}"
                  catchtap="handleRepeatHomeRecord"
                >再记一次</view>
                <view
                  class="danger-icon-btn stream-delete-btn"
                  data-record-type="{{record.recordType}}"
                  data-record-id="{{record.recordId}}"
                  catchtap="handleDeleteHomeRecord"
                >
                  <view class="trash-icon">
                    <view class="trash-icon-handle"></view>
                    <view class="trash-icon-lid"></view>
                    <view class="trash-icon-body">
                      <view class="trash-icon-line left"></view>
                      <view class="trash-icon-line center"></view>
                      <view class="trash-icon-line right"></view>
                    </view>
                  </view>
                </view>
              </view>
            </view>
            <view
              class="stream-swipe-content"
              style="{{record.swipeContentStyle}}"
              data-record-type="{{record.recordType}}"
              data-record-id="{{record.recordId}}"
              data-meal-type="{{record.mealType}}"
              data-record-date="{{record.recordDate}}"
              catchtap="handleRecordTap"
            >
              <view class="stream-item">
                <view class="stream-main">
                  <view class="stream-title">{{record.title}}</view>
                </view>
                <view class="stream-calories {{record.isDiet ? 'diet' : 'exercise'}}">{{record.signedCalories}}</view>
              </view>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>
  <empty-state
    wx:else
    show-icon="{{false}}"
    title="{{homeCopy.emptyTitle}}"
    description="{{homeCopy.emptyDescription}}"
  />

  <view class="section-head diary-section-head">
    <view class="section-title">健康日记</view>
  </view>

  <view class="panel diary-panel" bindtap="handleOpenHealthDiary">
    <view wx:if="{{healthDiary}}">
      <view wx:if="{{healthDiary.hasContent}}" class="diary-content">{{healthDiary.contentPreview}}</view>
      <view wx:if="{{healthDiary.hasImages}}" class="diary-image-list">
        <image
          wx:for="{{healthDiary.imageFileIds}}"
          wx:key="*this"
          wx:for-item="imageFileId"
          class="diary-image"
          mode="aspectFill"
          src="{{imageFileId}}"
        />
      </view>

    </view>
    <view wx:else class="diary-empty">{{homeCopy.diaryEmpty}}</view>
  </view>

  <view class="quick-add-fab" bindtap="handleQuickEntry">
    <view class="quick-add-icon">+</view>
  </view>

  <view wx:if="{{quickMenuVisible}}" class="sheet-overlay" bindtap="handleCloseQuickMenu"></view>
  <view wx:if="{{quickMenuVisible}}" class="quick-menu-panel panel" catchtouchmove="noop">
    <view class="quick-menu-title">{{homeCopy.quickMenuTitle}}</view>
    <view class="quick-menu-list">
      <view class="quick-menu-item" data-action="weight" bindtap="handleQuickMenuAction">
        <view class="quick-menu-icon quick-menu-icon-weight">
          <view class="icon-weight-dot"></view>
        </view>
        <view class="quick-menu-label">{{homeCopy.quickMenuLabels.weight}}</view>
      </view>
      <view class="quick-menu-item" data-action="diet" bindtap="handleQuickMenuAction">
        <view class="quick-menu-icon quick-menu-icon-diet">
          <view class="icon-diet-bowl"></view>
        </view>
        <view class="quick-menu-label">{{homeCopy.quickMenuLabels.diet}}</view>
      </view>
      <view class="quick-menu-item" data-action="exercise" bindtap="handleQuickMenuAction">
        <view class="quick-menu-icon quick-menu-icon-exercise">
          <view class="icon-exercise-stroke"></view>
        </view>
        <view class="quick-menu-label">{{homeCopy.quickMenuLabels.exercise}}</view>
      </view>
      <view class="quick-menu-item" data-action="diary" bindtap="handleQuickMenuAction">
        <view class="quick-menu-icon quick-menu-icon-diary">
          <view class="icon-diary-line icon-diary-line-1"></view>
          <view class="icon-diary-line icon-diary-line-2"></view>
        </view>
        <view class="quick-menu-label">{{homeCopy.quickMenuLabels.diary}}</view>
      </view>
    </view>
  </view>

  <view wx:if="{{mealNutritionVisible}}" class="sheet-overlay" bindtap="handleCloseMealNutrition"></view>
  <view wx:if="{{mealNutritionVisible}}" class="bottom-sheet panel" catchtouchmove="noop">
    <view class="sheet-head">
      <view class="sheet-title">{{selectedMealLabel}}营养分析</view>
      <view class="sheet-close" bindtap="handleCloseMealNutrition">✕</view>
    </view>
    <view wx:if="{{mealNutritionLoading}}" class="sheet-loading">加载中...</view>
    <view wx:else>
      <view class="sheet-metric-grid">
        <view class="sheet-metric-item">
          <view class="sheet-metric-label">热量</view>
          <view class="sheet-metric-value">{{mealNutrition.totalCalories}} kcal</view>
        </view>
        <view class="sheet-metric-item">
          <view class="sheet-metric-label">蛋白</view>
          <view class="sheet-metric-value">{{mealNutrition.totalProtein}} g</view>
        </view>
        <view class="sheet-metric-item">
          <view class="sheet-metric-label">碳水</view>
          <view class="sheet-metric-value">{{mealNutrition.totalCarbs}} g</view>
        </view>
        <view class="sheet-metric-item">
          <view class="sheet-metric-label">脂肪</view>
          <view class="sheet-metric-value">{{mealNutrition.totalFat}} g</view>
        </view>
      </view>

      <view wx:if="{{mealNutrition.hasProteinTarget}}" class="protein-target-card">
        <view class="protein-target-main">
          <view class="protein-target-label">蛋白目标</view>
          <view class="protein-target-value">{{mealNutrition.totalProtein}} / {{mealNutrition.proteinTarget}} g</view>
        </view>
        <view class="protein-target-status {{mealNutrition.proteinTargetMet ? 'done' : ''}}">
          {{mealNutrition.proteinTargetMet ? '已达标' : '差 ' + mealNutrition.proteinRemainingAbs + 'g'}}
        </view>
      </view>

      <view wx:if="{{mealNutrition.hasMacroRatio}}" class="macro-ratio-card">
        <view class="macro-ratio-title">三大营养供能占比</view>
        <view wx:for="{{mealNutrition.macroItems}}" wx:key="key" class="macro-ratio-row">
          <view class="macro-ratio-label">{{item.label}}</view>
          <view class="macro-ratio-track">
            <view class="macro-ratio-bar {{item.key}}" style="{{item.barStyle}}"></view>
          </view>
          <view class="macro-ratio-percent">{{item.percent}}%</view>
        </view>
      </view>
    </view>
  </view>
  <metric-editor-sheet
    visible="{{weightEditorVisible}}"
    loading="{{weightEditorLoading}}"
    title="记录体重"
    date="{{weightEditorDate}}"
    dateEditable="{{true}}"
    showTime="{{true}}"
    time="{{weightEditorTime}}"
    value="{{weightValue}}"
    placeholder="请输入体重"
    unit="kg"
    bind:close="handleCloseWeightEditor"
    bind:datechange="handleWeightDateChange"
    bind:timechange="handleWeightTimeChange"
    bind:input="handleWeightInput"
    bind:submit="handleSubmitWeight"
  />
</view>

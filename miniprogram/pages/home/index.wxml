<view class="page-shell home-page">
  <view class="panel date-panel">
    <view class="date-switch-row">
      <view class="date-step" bindtap="handlePrevDay">前一天</view>
      <picker mode="date" value="{{recordDate}}" bindchange="handleDateChange">
        <view class="date-center">
          <view class="date-label">{{displayDateLabel || recordDate}}</view>
        </view>
      </picker>
      <view class="date-step" bindtap="handleNextDay">后一天</view>
    </view>
  </view>

  <view class="hero panel">
    <view class="hero-strip"></view>
    <view class="hero-head">
      <view class="hero-title">净热量</view>
    </view>

    <view class="hero-main">
      <view class="hero-value">{{summary.netCalories}}</view>
      <view class="hero-unit">kcal</view>
    </view>

    <view class="hero-status {{summary.hasTarget && summary.exceededTarget ? 'danger' : ''}}">
      <block wx:if="{{summary.hasTarget}}">
        {{summary.exceededTarget ? '已超目标' : '剩余'}} {{summary.remainingAbs}} kcal
      </block>
      <block wx:else>目标热量未设置</block>
    </view>

    <view class="hero-metrics">
      <view class="metric-item metric-item-main">
        <view class="metric-label">饮食摄入</view>
        <view class="metric-value">+{{summary.dietCalories}}</view>
      </view>
      <view class="metric-item">
        <view class="metric-label">运动消耗</view>
        <view class="metric-value">-{{summary.exerciseCalories}}</view>
      </view>
      <view class="metric-item">
        <view class="metric-label">今日目标</view>
        <view class="metric-value">{{summary.targetCalories == null ? '--' : summary.targetCalories}}</view>
      </view>
    </view>

    <view class="hero-tip">{{summary.summaryText}}</view>

  </view>

  <view class="section-head">
    <view class="section-title">记录</view>
  </view>

  <view wx:if="{{recordGroups.length}}" class="record-groups">
    <view
      wx:for="{{recordGroups}}"
      wx:key="key"
      wx:for-item="group"
      class="record-group panel {{group.type === 'EXERCISE' ? 'record-group-exercise' : 'record-group-diet'}}"
    >
      <view class="group-head">
        <view class="group-main">
          <view class="group-accent"></view>
          <view class="group-title">{{group.label}}</view>
        </view>
        <view class="group-count">{{group.records.length}} 条</view>
      </view>

      <view class="group-list">
        <view
          wx:for="{{group.records}}"
          wx:key="recordKey"
          wx:for-item="record"
          class="stream-item"
          data-record-type="{{record.recordType}}"
          data-meal-type="{{record.mealType}}"
          data-record-date="{{record.recordDate}}"
          bindtap="handleOpenRecord"
        >
          <view class="stream-main">
            <view class="stream-title">{{record.title}}</view>
          </view>
          <view class="stream-calories {{record.isDiet ? 'diet' : 'exercise'}}">{{record.signedCalories}}</view>
        </view>
      </view>
    </view>
  </view>

  <empty-state wx:else show-icon="{{false}}" title="暂无记录" description="点击右下角加号开始记录" />

  <view class="section-head diary-section-head">
    <view class="section-title">健康日记</view>
    <view class="diary-entry-action" bindtap="handleOpenHealthDiary">{{healthDiary ? "编辑" : "记录"}}</view>
  </view>

  <view class="panel diary-panel" bindtap="handleOpenHealthDiary">
    <view wx:if="{{healthDiary}}">
      <view wx:if="{{healthDiary.hasContent}}" class="diary-content">{{healthDiary.contentPreview}}</view>
      <view wx:if="{{healthDiary.hasImages}}" class="diary-image-list">
        <image
          wx:for="{{healthDiary.imageFileIds}}"
          wx:key="*this"
          wx:for-item="imageFileId"
          class="diary-image"
          mode="aspectFill"
          src="{{imageFileId}}"
        />
      </view>
      <view class="diary-meta">已记录</view>
    </view>
    <view wx:else class="diary-empty">点击记录今天状态</view>
  </view>

  <view class="quick-add-fab" bindtap="handleQuickAddDiet">
    <view class="quick-add-icon">+</view>
  </view>
</view>

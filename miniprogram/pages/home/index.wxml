<view class="page-shell home-page">
  <view class="hero panel">
    <view class="hero-head">
      <view class="hero-title">今日净摄入</view>
      <view class="hero-date">{{today}}</view>
    </view>
    <view class="hero-main">
      <view class="hero-value">{{summary.netCalories}}</view>
      <view class="hero-unit">kcal</view>
    </view>
    <view class="hero-status">{{summary.exceededTarget ? '已超目标' : '剩余'}} {{summary.remainingAbs}} kcal</view>

    <view class="hero-metrics">
      <view class="metric-item">
        <view class="metric-label">饮食摄入</view>
        <view class="metric-value">+{{summary.dietCalories}}</view>
      </view>
      <view class="metric-item">
        <view class="metric-label">运动消耗</view>
        <view class="metric-value">-{{summary.exerciseCalories}}</view>
      </view>
      <view class="metric-item">
        <view class="metric-label">目标热量</view>
        <view class="metric-value">{{summary.targetCalories}}</view>
      </view>
      <view class="metric-item">
        <view class="metric-label">剩余目标</view>
        <view class="metric-value">{{summary.exceededTarget ? '-' : ''}}{{summary.remainingAbs}}</view>
      </view>
    </view>

    <view class="summary-note">{{summary.summaryText}}</view>
  </view>

  <view class="action-row">
    <view class="primary-button" bindtap="handleCreate">记录</view>
    <view class="ghost-button" bindtap="handleOpenProgress">趋势</view>
  </view>

  <view class="panel meal-progress-panel" wx:if="{{summary.mealProgress.length}}">
    <view class="section-title">餐次进度</view>
    <view wx:for="{{summary.mealProgress}}" wx:key="mealType" class="meal-row">
      <view class="meal-main">
        <view class="meal-title">{{item.mealLabel}}</view>
        <view class="meal-detail">{{item.intakeCalories}} / {{item.targetCalories}} kcal</view>
      </view>
      <view class="meal-right">
        <view class="meal-status {{item.exceededTarget ? 'danger' : 'normal'}}">
          {{item.exceededTarget ? '超出' : '剩余'}} {{item.remainingAbs}}
        </view>
        <view class="meal-go" data-meal-type="{{item.mealType}}" bindtap="handleGoMeal">去记录</view>
      </view>
    </view>
  </view>

  <view class="panel suggestion-panel" wx:if="{{summary.suggestions.length}}">
    <view class="section-title">今日建议</view>
    <view wx:for="{{summary.suggestions}}" wx:key="title" class="suggestion-item" data-meal-type="{{item.mealType}}" bindtap="handleSuggestionTap">
      <view class="suggestion-title">{{item.title}}</view>
      <view class="suggestion-desc">{{item.description}}</view>
    </view>
  </view>

  <view class="panel trend-panel">
    <view class="section-title">阶段反馈</view>
    <view class="trend-grid">
      <view class="trend-item">
        <view class="trend-label">近7天平均</view>
        <view class="trend-value">{{summary.trendInsight.averageNetCalories}} kcal</view>
      </view>
      <view class="trend-item">
        <view class="trend-label">近7天运动天数</view>
        <view class="trend-value">{{summary.trendInsight.exerciseDays}} 天</view>
      </view>
    </view>
  </view>

  <view class="section-head">
    <view class="section-title">今日记录</view>
    <view class="record-count">{{summary.records.length}} 条</view>
  </view>

  <view wx:if="{{summary.records.length}}" class="record-stream panel">
    <view
      wx:for="{{summary.records}}"
      wx:key="recordKey"
      class="stream-item"
      data-record-type="{{item.recordType}}"
      data-meal-type="{{item.mealType}}"
      data-record-date="{{item.recordDate}}"
      bindtap="handleOpenRecord"
    >
      <view class="stream-main">
        <view class="stream-title">{{item.title}}</view>
      </view>
      <view class="stream-calories {{item.isDiet ? 'diet' : 'exercise'}}">{{item.signedCalories}}</view>
    </view>
  </view>

  <empty-state wx:else title="今日暂无记录" description="点击上方按钮开始记录" />
</view>

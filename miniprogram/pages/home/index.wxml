<view class="page-shell home-page">
  <view class="hero">
    <view>
      <view class="hero-kicker">心栖轻食 · 今日状态</view>
      <view class="hero-title">{{today}}</view>
      <view class="hero-desc">记录今天每一餐，热量变化一眼看清。</view>
    </view>
    <view class="hero-badge">单用户演示</view>
  </view>

  <summary-card
    title="当日热量总览"
    subtitle="目标、已摄入和剩余热量"
    targetCalories="{{summary.targetCalories}}"
    consumedCalories="{{summary.consumedCalories}}"
    remainingCalories="{{summary.remainingCalories}}"
    exceededTarget="{{summary.exceededTarget}}"
  />

  <view class="action-grid">
    <view class="primary-button" bindtap="handleCreate">去记录</view>
    <view class="ghost-button" bindtap="handleOpenProgress">查看趋势</view>
  </view>

  <view class="section-head">
    <view>
      <view class="section-title">今日餐次</view>
      <view class="section-subtitle">按餐次查看已记录数据</view>
    </view>
    <view class="record-count">{{summary.mealCards.length}} 餐</view>
  </view>

  <view wx:if="{{summary.mealCards.length}}" class="meal-panel">
    <view wx:for="{{summary.mealCards}}" wx:key="mealType" class="meal-card panel">
      <view class="meal-card-head">
        <view class="meal-card-title">{{item.mealTypeLabel}}</view>
        <view class="meal-card-count">{{item.foodCount}} 种</view>
      </view>
      <view class="meal-card-calories">{{item.totalCalories}} kcal</view>
    </view>
  </view>

  <empty-state wx:else title="今天还没记录" description="点一下“去记录”，从第一餐开始。" />
</view>

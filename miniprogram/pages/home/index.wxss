.home-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.hero {
  border: 1rpx solid rgba(30, 90, 79, 0.16);
  padding: 24rpx;
}

.hero-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.hero-title {
  color: #1e5a4f;
  font-size: 24rpx;
  font-weight: 700;
}

.hero-date {
  color: #74685c;
  font-size: 22rpx;
}

.hero-main {
  align-items: baseline;
  display: flex;
  gap: 10rpx;
  margin-top: 12rpx;
}

.hero-value {
  color: #2f2a24;
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1;
}

.hero-unit {
  color: #74685c;
  font-size: 24rpx;
}

.hero-status {
  background: rgba(30, 90, 79, 0.1);
  border-radius: 999rpx;
  color: #1e5a4f;
  display: inline-flex;
  font-size: 22rpx;
  font-weight: 600;
  margin-top: 14rpx;
  padding: 8rpx 16rpx;
}

.hero-metrics {
  display: grid;
  gap: 10rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 18rpx;
}

.metric-item {
  background: rgba(255, 255, 255, 0.65);
  border-radius: 16rpx;
  padding: 14rpx 16rpx;
}

.metric-label {
  color: #74685c;
  font-size: 21rpx;
}

.metric-value {
  color: #2f2a24;
  font-size: 28rpx;
  font-weight: 700;
  margin-top: 6rpx;
}

.summary-note {
  color: #5f5347;
  font-size: 24rpx;
  margin-top: 14rpx;
}

.action-row {
  display: grid;
  gap: 12rpx;
  grid-template-columns: 1.25fr 0.75fr;
}

.meal-progress-panel,
.suggestion-panel,
.trend-panel {
  padding: 20rpx;
}

.meal-row {
  align-items: center;
  border-top: 1rpx solid rgba(70, 57, 47, 0.1);
  display: flex;
  justify-content: space-between;
  padding: 16rpx 0;
}

.meal-row:first-child {
  border-top: 0;
}

.meal-main {
  flex: 1;
}

.meal-title {
  color: #2f2a24;
  font-size: 28rpx;
  font-weight: 700;
}

.meal-detail {
  color: #74685c;
  font-size: 22rpx;
  margin-top: 6rpx;
}

.meal-right {
  align-items: flex-end;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.meal-status {
  border-radius: 999rpx;
  font-size: 20rpx;
  font-weight: 600;
  padding: 6rpx 14rpx;
}

.meal-status.normal {
  background: rgba(30, 90, 79, 0.08);
  color: #1e5a4f;
}

.meal-status.danger {
  background: rgba(185, 94, 58, 0.12);
  color: #b95e3a;
}

.meal-go {
  color: #1e5a4f;
  font-size: 22rpx;
  font-weight: 700;
}

.suggestion-item {
  border-top: 1rpx solid rgba(70, 57, 47, 0.1);
  padding: 14rpx 0;
}

.suggestion-item:first-child {
  border-top: 0;
}

.suggestion-title {
  color: #2f2a24;
  font-size: 26rpx;
  font-weight: 700;
}

.suggestion-desc {
  color: #74685c;
  font-size: 22rpx;
  margin-top: 6rpx;
}

.trend-grid {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.trend-item {
  background: rgba(255, 255, 255, 0.62);
  border-radius: 16rpx;
  padding: 14rpx;
}

.trend-label {
  color: #74685c;
  font-size: 22rpx;
}

.trend-value {
  color: #2f2a24;
  font-size: 26rpx;
  font-weight: 700;
  margin-top: 6rpx;
}

.section-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-top: 2rpx;
}

.record-count {
  background: rgba(30, 90, 79, 0.09);
  border-radius: 999rpx;
  color: #1e5a4f;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
}

.record-stream {
  padding: 4rpx 20rpx;
}

.stream-item {
  align-items: center;
  border-bottom: 1rpx solid rgba(70, 57, 47, 0.12);
  display: flex;
  gap: 10rpx;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 12rpx 0;
}

.stream-item:last-child {
  border-bottom: 0;
}

.stream-main {
  flex: 1;
  min-width: 0;
}

.stream-title {
  color: #2f2a24;
  font-size: 27rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stream-calories {
  font-size: 25rpx;
  font-weight: 700;
  margin-left: 12rpx;
}

.stream-calories.diet {
  color: #1f6f5f;
}

.stream-calories.exercise {
  color: #b95e3a;
}

.home-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.hero {
  border: 1rpx solid rgba(30, 90, 79, 0.16);
  padding: 24rpx;
}

.hero-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.hero-title {
  color: #1e5a4f;
  font-size: 24rpx;
  font-weight: 700;
}

.hero-date {
  color: #74685c;
  font-size: 22rpx;
}

.hero-main {
  align-items: baseline;
  display: flex;
  gap: 10rpx;
  margin-top: 12rpx;
}

.hero-value {
  color: #2f2a24;
  font-size: 64rpx;
  font-weight: 700;
  line-height: 1;
}

.hero-unit {
  color: #74685c;
  font-size: 24rpx;
}

.hero-status {
  background: rgba(30, 90, 79, 0.1);
  border-radius: 999rpx;
  color: #1e5a4f;
  display: inline-flex;
  font-size: 22rpx;
  font-weight: 600;
  margin-top: 14rpx;
  padding: 8rpx 16rpx;
}

.stats-grid {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.stat-card {
  border: 1rpx solid rgba(30, 90, 79, 0.12);
  min-height: 150rpx;
  padding: 20rpx;
}

.stat-label {
  color: #74685c;
  font-size: 22rpx;
}

.stat-value {
  color: #2f2a24;
  font-size: 34rpx;
  font-weight: 700;
  margin-top: 10rpx;
  line-height: 1.2;
}

.stat-unit {
  color: #74685c;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.action-row {
  display: grid;
  gap: 12rpx;
  grid-template-columns: 1.25fr 0.75fr;
}

.section-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-top: 2rpx;
}

.record-count {
  background: rgba(30, 90, 79, 0.09);
  border-radius: 999rpx;
  color: #1e5a4f;
  font-size: 22rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
}

.meal-list {
  padding: 4rpx 20rpx;
}

.meal-item {
  align-items: center;
  border-bottom: 1rpx solid rgba(70, 57, 47, 0.12);
  display: flex;
  justify-content: space-between;
  min-height: 96rpx;
  padding: 16rpx 0;
}

.meal-item:last-child {
  border-bottom: 0;
}

.meal-main {
  flex: 1;
}

.meal-name {
  color: #2f2a24;
  font-size: 30rpx;
  font-weight: 700;
}

.meal-meta {
  color: #74685c;
  font-size: 22rpx;
  margin-top: 6rpx;
}

.meal-calories {
  color: #1e5a4f;
  font-size: 28rpx;
  font-weight: 700;
  margin-left: 16rpx;
}
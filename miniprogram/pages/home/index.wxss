.home-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-bottom: calc(190rpx + env(safe-area-inset-bottom));
}

.date-panel {
  padding: 14rpx;
}

.date-switch-row {
  align-items: center;
  display: grid;
  gap: 12rpx;
  grid-template-columns: 116rpx 1fr 116rpx;
}

.date-step,
.date-center {
  align-items: center;
  border-radius: 22rpx;
  display: flex;
  height: 84rpx;
  justify-content: center;
}

.date-step {
  background: rgba(107, 144, 132, 0.08);
  border: 1rpx solid rgba(107, 144, 132, 0.14);
  color: #5d8378;
  font-size: 22rpx;
  font-weight: 600;
}

.date-step:active {
  opacity: 0.84;
}

.date-center {
  background: linear-gradient(180deg, #fcfaf5 0%, #f5f1ea 100%);
  border: 2rpx solid rgba(107, 144, 132, 0.14);
  color: #3b4842;
  font-weight: 800;
  position: relative;
}

.date-label {
  font-size: 30rpx;
  line-height: 1.05;
  letter-spacing: 1rpx;
}

.date-today-link {
  background: rgba(107, 144, 132, 0.1);
  border-radius: 999rpx;
  color: #5d8378;
  font-size: 18rpx;
  font-weight: 700;
  line-height: 1;
  padding: 6rpx 12rpx;
  position: absolute;
  right: 10rpx;
  top: 10rpx;
}

.hero {
  background:
    radial-gradient(circle at 92% 10%, rgba(196, 167, 140, 0.16), transparent 28%),
    radial-gradient(circle at 10% 0%, rgba(107, 144, 132, 0.12), transparent 34%),
    linear-gradient(180deg, rgba(253, 250, 245, 0.98) 0%, rgba(247, 243, 236, 0.98) 100%);
  overflow: hidden;
  padding: 28rpx 24rpx 24rpx;
  position: relative;
}

.hero::after {
  background: linear-gradient(90deg, rgba(107, 144, 132, 0.46), rgba(196, 167, 140, 0.26));
  border-radius: 999rpx;
  content: "";
  height: 6rpx;
  left: 24rpx;
  position: absolute;
  right: 180rpx;
  top: 0;
}

.hero-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.hero-title {
  color: #3b4842;
  font-size: 28rpx;
  font-weight: 800;
}

.hero-main {
  align-items: baseline;
  display: flex;
  gap: 12rpx;
  margin-top: 20rpx;
}

.hero-value {
  color: #37423d;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 88rpx;
  font-weight: 800;
  letter-spacing: 1rpx;
  line-height: 0.95;
}

.hero-unit {
  color: #7d7c74;
  font-size: 24rpx;
  font-weight: 700;
}

.hero-status {
  background: rgba(107, 144, 132, 0.12);
  border-radius: 999rpx;
  color: #5d8378;
  display: inline-flex;
  font-size: 23rpx;
  font-weight: 700;
  margin-top: 16rpx;
  padding: 10rpx 20rpx;
}

.hero-status.danger {
  background: rgba(187, 134, 108, 0.14);
  color: #bb866c;
}

.hero-tip {
  color: #767870;
  font-size: 23rpx;
  line-height: 1.6;
  margin-top: 16rpx;
}

.hero-metrics {
  display: grid;
  gap: 12rpx;
  grid-template-columns: 1.45fr 1fr 1fr;
  margin-top: 22rpx;
}

.metric-item {
  background: rgba(253, 251, 246, 0.82);
  border: 1rpx solid rgba(107, 144, 132, 0.09);
  border-radius: 22rpx;
  padding: 16rpx 16rpx 14rpx;
}

.metric-item-main {
  background: linear-gradient(180deg, rgba(107, 144, 132, 0.1) 0%, rgba(253, 251, 246, 0.82) 100%);
  border-color: rgba(107, 144, 132, 0.14);
}

.metric-label {
  color: #7d7c74;
  font-size: 21rpx;
}

.metric-value {
  color: #3b4842;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 30rpx;
  font-weight: 800;
  margin-top: 8rpx;
}

.section-head {
  align-items: center;
  display: flex;
  justify-content: flex-start;
  margin-top: 2rpx;
}

.section-head .section-title {
  font-size: 33rpx;
  letter-spacing: 1rpx;
}

.record-groups {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.weight-record-panel {
  padding: 0 18rpx;
}

.weight-record-line {
  align-items: center;
  display: flex;
  min-height: 88rpx;
}

.weight-record-title {
  color: #3b4842;
  font-size: 28rpx;
  font-weight: 700;
}

.record-prompt-card {
  align-items: center;
  background:
    radial-gradient(circle at 100% 0%, rgba(196, 167, 140, 0.18), transparent 34%),
    linear-gradient(180deg, rgba(252, 249, 244, 0.98) 0%, rgba(244, 249, 246, 0.98) 100%);
  border: 1rpx solid rgba(107, 144, 132, 0.16);
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
  padding: 22rpx 22rpx 20rpx;
}

.record-prompt-card:active {
  opacity: 0.88;
}

.record-prompt-main {
  flex: 1;
  min-width: 0;
}

.record-prompt-title {
  color: #3b4842;
  font-size: 30rpx;
  font-weight: 800;
}

.record-prompt-action {
  align-items: center;
  background: rgba(107, 144, 132, 0.12);
  border-radius: 999rpx;
  color: #5d8378;
  display: inline-flex;
  flex-shrink: 0;
  font-size: 22rpx;
  font-weight: 800;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 24rpx;
}

.record-group {
  padding: 16rpx 18rpx 8rpx;
}

.group-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  min-height: 72rpx;
}

.group-main,
.group-side,
.group-actions {
  align-items: center;
  display: flex;
}

.group-main {
  gap: 12rpx;
}

.group-actions {
  gap: 10rpx;
}

.group-accent {
  border-radius: 999rpx;
  height: 28rpx;
  width: 8rpx;
}

.record-group-diet .group-accent {
  background: linear-gradient(180deg, #6f968b, rgba(111, 150, 139, 0.3));
}

.record-group-exercise .group-accent {
  background: linear-gradient(180deg, #bb866c, rgba(187, 134, 108, 0.3));
}

.group-title {
  color: #3b4842;
  font-size: 29rpx;
  font-weight: 800;
}

.group-action-btn {
  align-items: center;
  border-radius: 999rpx;
  display: flex;
  font-size: 20rpx;
  font-weight: 700;
  height: 50rpx;
  justify-content: center;
  width: 50rpx;
}

.group-action-btn:active {
  opacity: 0.84;
}

.group-action-nutrition {
  background: rgba(107, 144, 132, 0.1);
  color: #5d8378;
}

.nutrition-icon {
  align-items: flex-end;
  display: flex;
  gap: 3rpx;
  height: 20rpx;
}

.nutrition-bar {
  background: linear-gradient(180deg, #6f968b, #5d8378);
  border-radius: 3rpx;
  width: 5rpx;
}

.nutrition-bar-1 {
  height: 10rpx;
}

.nutrition-bar-2 {
  height: 16rpx;
}

.nutrition-bar-3 {
  height: 13rpx;
}

.group-action-add {
  background: rgba(107, 144, 132, 0.14);
  color: #5d8378;
  font-size: 30rpx;
  line-height: 1;
}

.group-action-exercise {
  background: rgba(187, 134, 108, 0.12);
}

.group-exercise-icon {
  align-items: center;
  display: flex;
  height: 22rpx;
  justify-content: center;
  position: relative;
  width: 22rpx;
}

.group-exercise-stroke {
  background: #bb866c;
  border-radius: 2rpx;
  height: 14rpx;
  transform: skew(-20deg) rotate(16deg);
  width: 5rpx;
}

.group-exercise-icon::before {
  background: #bb866c;
  border-radius: 2rpx;
  content: "";
  height: 5rpx;
  left: 11rpx;
  position: absolute;
  top: 6rpx;
  width: 10rpx;
}

.group-list {
  padding: 4rpx 2rpx;
}

.stream-swipe-cell {
  overflow: hidden;
  position: relative;
}

.stream-action-track {
  align-items: center;
  display: flex;
  inset: 0;
  justify-content: flex-end;
  position: absolute;
}

.stream-action-shell {
  align-items: center;
  display: flex;
  gap: 14rpx;
  height: 100%;
  justify-content: center;
  width: 168px;
}

.stream-delete-btn {
  height: 60rpx;
  width: 60rpx;
}

.stream-repeat-btn {
  align-items: center;
  background: rgba(107, 144, 132, 0.14);
  border-radius: 999rpx;
  color: #5d8378;
  display: inline-flex;
  font-size: 22rpx;
  font-weight: 700;
  height: 60rpx;
  justify-content: center;
  min-width: 128rpx;
  padding: 0 24rpx;
}

.stream-swipe-content {
  background: linear-gradient(180deg, #fdfcf8 0%, #f8f5ee 100%);
  border-bottom: 1rpx solid rgba(107, 144, 132, 0.08);
  position: relative;
  z-index: 1;
}

.stream-swipe-cell:last-child .stream-swipe-content {
  border-bottom: 0;
}

.stream-item {
  align-items: center;
  display: flex;
  gap: 10rpx;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 12rpx 0;
}

.stream-item:active {
  opacity: 0.82;
}

.stream-main {
  flex: 1;
  min-width: 0;
}

.stream-title {
  color: #37423d;
  font-size: 25rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.stream-calories {
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 24rpx;
  font-weight: 800;
  margin-left: 12rpx;
}

.stream-calories.diet {
  color: #5d8378;
}

.stream-calories.exercise {
  color: #bb866c;
}

.diary-section-head {
  margin-top: 6rpx;
}

.diary-panel {
  background:
    radial-gradient(circle at 100% 0%, rgba(196, 167, 140, 0.12), transparent 26%),
    linear-gradient(180deg, rgba(252, 249, 244, 0.98) 0%, rgba(246, 242, 235, 0.96) 100%);
  padding: 24rpx 20rpx;
}

.diary-panel:active {
  opacity: 0.9;
}

.diary-content {
  color: #3b4842;
  font-size: 25rpx;
  line-height: 1.7;
  word-break: break-all;
}

.diary-image-list {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.diary-image {
  border: 1rpx solid rgba(107, 144, 132, 0.1);
  border-radius: 18rpx;
  height: 156rpx;
  width: 156rpx;
}

.diary-empty {
  color: #7d7c74;
  font-size: 24rpx;
}

.quick-add-fab {
  align-items: center;
  background:
    radial-gradient(circle at 28% 25%, rgba(255, 255, 255, 0.24), transparent 42%),
    linear-gradient(135deg, #6f968b 0%, #5d8378 100%);
  border: 2rpx solid rgba(107, 144, 132, 0.18);
  border-radius: 999rpx;
  bottom: calc(34rpx + env(safe-area-inset-bottom));
  box-shadow:
    0 12rpx 24rpx rgba(70, 104, 95, 0.18),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.26);
  color: #fcfffd;
  display: flex;
  height: 102rpx;
  justify-content: center;
  position: fixed;
  right: 30rpx;
  width: 102rpx;
  z-index: 30;
}

.quick-add-fab:active {
  transform: translateY(2rpx);
}

.quick-add-icon {
  font-size: 58rpx;
  font-weight: 500;
  line-height: 1;
  margin-top: -2rpx;
}

.sheet-overlay {
  background: rgba(40, 43, 42, 0.28);
  inset: 0;
  position: fixed;
  z-index: 40;
}

.bottom-sheet {
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  border-top-left-radius: 40rpx;
  border-top-right-radius: 40rpx;
  bottom: 0;
  left: 0;
  padding: 28rpx 26rpx calc(26rpx + env(safe-area-inset-bottom));
  position: fixed;
  right: 0;
  z-index: 50;
}

.sheet-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.sheet-title {
  color: #3b4842;
  font-size: 30rpx;
  font-weight: 800;
}

.sheet-close {
  align-items: center;
  background: rgba(107, 144, 132, 0.08);
  border-radius: 999rpx;
  color: #75756e;
  display: flex;
  font-size: 26rpx;
  font-weight: 700;
  height: 56rpx;
  justify-content: center;
  line-height: 1;
  width: 56rpx;
}

.sheet-loading {
  color: #7d7c74;
  font-size: 24rpx;
  margin-top: 22rpx;
}

.sheet-metric-grid {
  display: grid;
  gap: 10rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 20rpx;
}

.sheet-metric-item {
  background: rgba(253, 251, 246, 0.84);
  border: 1rpx solid rgba(107, 144, 132, 0.08);
  border-radius: 18rpx;
  padding: 14rpx;
}

.sheet-metric-label {
  color: #7d7c74;
  font-size: 22rpx;
}

.sheet-metric-value {
  color: #5d8378;
  font-size: 26rpx;
  font-weight: 700;
  margin-top: 8rpx;
}

.quick-menu-panel {
  border-radius: 30rpx;
  bottom: calc(154rpx + env(safe-area-inset-bottom));
  padding: 18rpx 16rpx;
  position: fixed;
  right: 28rpx;
  width: 292rpx;
  z-index: 45;
}

.quick-menu-title {
  color: #7d7c74;
  font-size: 21rpx;
  margin-bottom: 10rpx;
  padding-left: 6rpx;
}

.quick-menu-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.quick-menu-item {
  align-items: center;
  background: rgba(253, 250, 245, 0.9);
  border: 1rpx solid rgba(107, 144, 132, 0.1);
  border-radius: 18rpx;
  display: flex;
  gap: 10rpx;
  height: 72rpx;
  padding: 0 14rpx;
}

.quick-menu-item:active {
  opacity: 0.84;
}

.quick-menu-icon {
  align-items: center;
  border-radius: 12rpx;
  display: flex;
  height: 42rpx;
  justify-content: center;
  position: relative;
  width: 42rpx;
}

.quick-menu-label {
  color: #37423d;
  font-size: 24rpx;
  font-weight: 700;
}

.quick-menu-icon-weight {
  background: linear-gradient(140deg, rgba(107, 144, 132, 0.16), rgba(107, 144, 132, 0.08));
}

.icon-weight-dot {
  background: #5d8378;
  border-radius: 999rpx;
  height: 10rpx;
  margin-top: 6rpx;
  width: 10rpx;
}

.quick-menu-icon-weight::before {
  border-bottom: 2rpx solid #5d8378;
  border-left: 2rpx solid #5d8378;
  border-right: 2rpx solid #5d8378;
  border-radius: 8rpx 8rpx 10rpx 10rpx;
  content: "";
  height: 18rpx;
  left: 8rpx;
  position: absolute;
  top: 8rpx;
  width: 24rpx;
}

.quick-menu-icon-diet {
  background: linear-gradient(140deg, rgba(196, 167, 140, 0.18), rgba(196, 167, 140, 0.08));
}

.icon-diet-bowl {
  border-bottom: 2rpx solid #9c7a66;
  border-left: 2rpx solid #9c7a66;
  border-right: 2rpx solid #9c7a66;
  border-radius: 0 0 12rpx 12rpx;
  height: 12rpx;
  margin-top: 8rpx;
  width: 20rpx;
}

.quick-menu-icon-exercise {
  background: linear-gradient(140deg, rgba(187, 134, 108, 0.14), rgba(187, 134, 108, 0.08));
}

.icon-exercise-stroke {
  background: #bb866c;
  border-radius: 2rpx;
  height: 18rpx;
  transform: skew(-20deg) rotate(16deg);
  width: 6rpx;
}

.quick-menu-icon-exercise::before {
  background: #bb866c;
  border-radius: 2rpx;
  content: "";
  height: 6rpx;
  left: 19rpx;
  position: absolute;
  top: 9rpx;
  width: 12rpx;
}

.quick-menu-icon-diary {
  background: linear-gradient(140deg, rgba(107, 144, 132, 0.14), rgba(107, 144, 132, 0.08));
  flex-direction: column;
  gap: 4rpx;
}

.quick-menu-icon-diary::before {
  border: 2rpx solid #5d8378;
  border-radius: 4rpx;
  content: "";
  inset: 7rpx;
  position: absolute;
}

.icon-diary-line {
  background: #5d8378;
  border-radius: 2rpx;
  height: 2rpx;
  position: relative;
  width: 14rpx;
  z-index: 1;
}

.icon-diary-line-2 {
  width: 10rpx;
}

<view class="page-shell health-page" wx:if="{{profile}}">
  <view class="panel module-panel">
    <view class="section-title">核心指标</view>

    <view class="metrics-grid">
      <view class="metric-card green">
        <view class="metric-label">当前体重</view>
        <view class="metric-value">{{metrics.currentWeightLabel}}</view>
        <view class="metric-unit">kg</view>
      </view>
      <view class="metric-card sand">
        <view class="metric-label">BMI</view>
        <view class="metric-value">{{metrics.bmiLabel}}</view>
        <view class="metric-unit">指数</view>
      </view>
      <view class="metric-card teal">
        <view class="metric-label">基础代谢(BMR)</view>
        <view class="metric-value">{{metrics.bmrLabel}}</view>
        <view class="metric-unit">kcal/天</view>
      </view>
      <view class="metric-card orange">
        <view class="metric-label">基础日消耗</view>
        <view class="metric-value">{{metrics.baseCaloriesLabel}}</view>
        <view class="metric-unit">kcal/天</view>
      </view>
      <view class="metric-card plum">
        <view class="metric-label">目标热量</view>
        <view class="metric-value">{{metrics.targetCaloriesLabel}}</view>
        <view class="metric-unit">kcal/天</view>
      </view>
    </view>
  </view>

  <view class="panel module-panel">
    <view class="section-title">健康档案</view>

    <view class="field-group two-column">
      <view class="field-half">
        <view class="field-label">当前体重(kg)</view>
        <input
          class="field-input"
          type="digit"
          value="{{settings.currentWeight}}"
          data-field="currentWeight"
          bindinput="handleInput"
          placeholder="请输入当前体重"
        />
      </view>
      <view class="field-half">
        <view class="field-label">目标体重(kg)</view>
        <input
          class="field-input"
          type="digit"
          value="{{settings.targetWeight}}"
          data-field="targetWeight"
          bindinput="handleInput"
          placeholder="请输入目标体重"
        />
      </view>
    </view>

    <view class="setting-entry-card" bindtap="handleOpenBmrSheet">
      <view class="setting-entry-main">
        <view class="setting-entry-title">基础代谢</view>
        <view class="setting-entry-sub">当前 {{metrics.bmrLabel}} kcal/天</view>
      </view>
      <view class="setting-entry-action">去设置</view>
    </view>

    <view class="setting-entry-card" bindtap="handleOpenBaseSheet">
      <view class="setting-entry-main">
        <view class="setting-entry-title">基础日消耗</view>
        <view class="setting-entry-sub">当前 {{metrics.baseCaloriesLabel}} kcal/天</view>
      </view>
      <view class="setting-entry-action">去设置</view>
    </view>

    <view class="setting-entry-card" bindtap="handleOpenGoalSheet">
      <view class="setting-entry-main">
        <view class="setting-entry-title">目标热量</view>
        <view class="setting-entry-sub">{{metrics.goalModeLabel}} · {{metrics.goalDeltaLabel}} kcal/天 · 目标 {{metrics.targetCaloriesLabel}} kcal/天</view>
      </view>
      <view class="setting-entry-action">去设置</view>
    </view>
  </view>

  <view class="primary-button" bindtap="handleSave">保存</view>

  <view wx:if="{{sheet.visible}}" class="sheet-overlay" bindtap="handleCloseSheet"></view>
  <view wx:if="{{sheet.visible}}" class="editor-sheet panel" catchtouchmove="noop">
    <view class="sheet-head">
      <view>
        <view class="sheet-title">{{sheet.title}}</view>
        <view wx:if="{{sheet.type === 'GOAL'}}" class="sheet-current">当前目标 {{sheet.currentValue}} kcal/天</view>
        <view wx:else class="sheet-current">当前 {{sheet.currentValue}} kcal/天</view>
      </view>
      <view class="sheet-close" bindtap="handleCloseSheet">✕</view>
    </view>

    <view wx:if="{{sheet.type === 'GOAL'}}">
      <view class="goal-mode-row">
        <view
          wx:for="{{goalModeOptions}}"
          wx:key="value"
          wx:for-item="option"
          class="goal-mode-chip {{sheet.modeValue === option.value ? 'active' : ''}}"
          data-value="{{option.value}}"
          bindtap="handleGoalModeSelect"
        >
          {{option.label}}
        </view>
      </view>

      <view class="field-group sheet-field-group">
        <view class="field-label">{{sheet.fieldLabel}}</view>
        <input
          class="field-input"
          type="text"
          value="{{sheet.inputValue}}"
          bindinput="handleSheetInput"
          placeholder="例如 -300"
        />
      </view>

      <view class="goal-summary-card">
        <view class="goal-summary-label">预计目标热量</view>
        <view class="goal-summary-value">{{sheet.targetPreview}} kcal/天</view>
      </view>
      <view class="sheet-hint">{{sheet.hint}}</view>
    </view>

    <view wx:else>
      <view class="field-group sheet-field-group">
        <view class="field-label">{{sheet.fieldLabel}}</view>
        <input
          class="field-input"
          type="digit"
          value="{{sheet.inputValue}}"
          bindinput="handleSheetInput"
          placeholder="请输入数值"
        />
      </view>

      <view class="estimate-btn {{sheet.smartAvailable ? '' : 'disabled'}}" bindtap="handleUseSmartValue">
        使用智能预估值：{{sheet.smartValue}}
      </view>
      <view class="sheet-hint">{{sheet.hint}}</view>
    </view>

    <view class="primary-button sheet-primary" bindtap="handleSaveSheet">
      {{sheet.saving ? '保存中...' : '保存'}}
    </view>
  </view>
</view>

<empty-state wx:else title="健康档案加载失败" description="下拉刷新后重试。" />

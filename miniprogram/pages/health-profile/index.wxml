<view class="page-shell health-page" wx:if="{{profile}}">
  <view class="summary-badges">
    <view class="summary-badge">
      <view class="summary-badge-label">BMI</view>
      <view class="summary-badge-value">{{metrics.bmiLabel}}</view>
    </view>
    <view class="summary-badge">
      <view class="summary-badge-label">当前体重</view>
      <view class="summary-badge-value">{{metrics.currentWeightLabel === '--' ? '--' : metrics.currentWeightLabel + 'kg'}}</view>
    </view>
  </view>

  <view class="field-card action-card" bindtap="handleOpenBmrSheet">
    <view class="field-card-main">
      <view class="field-card-stack">
        <view class="field-card-title">基础代谢</view>
        <view class="field-card-sub">当前 {{metrics.bmrLabel}} kcal/天</view>
      </view>
    </view>
    <view class="field-card-action">设置</view>
  </view>

  <view class="field-card inline-field-card">
    <view class="inline-field-main">
      <view class="field-card-title">目标体重 (kg)</view>
      <input
        class="inline-field-input"
        type="digit"
        value="{{settings.targetWeight}}"
        data-field="targetWeight"
        bindinput="handleInput"
        placeholder="请输入"
      />
    </view>
  </view>

  <view class="field-card inline-field-card">
    <picker mode="date" value="{{settings.goalTargetDate}}" start="{{minGoalDate}}" bindchange="handleGoalDateChange">
      <view class="inline-field-main">
        <view class="field-card-title">预期日期</view>
        <view class="inline-field-picker">{{settings.goalTargetDate || '请选择日期'}}</view>
      </view>
    </picker>
  </view>

  <view class="panel strategy-panel">
    <view class="strategy-card">
      <view class="field-card-title">热量方案</view>
      <view class="strategy-control-row">
        <view class="strategy-button-group">
          <view
            wx:for="{{goalStrategies}}"
            wx:key="value"
            wx:for-item="strategy"
            class="strategy-chip {{settings.goalCalorieStrategy === strategy.value ? 'active' : ''}}"
            data-value="{{strategy.value}}"
            bindtap="handleGoalStrategySelect"
          >
            {{strategy.label}}
          </view>
        </view>
      </view>
    </view>

    <view class="goal-preview-card">
      <view class="goal-preview-head">
        <view class="goal-preview-title">方案预览</view>
        <view wx:if="{{goalPreview.warningLevel === 'EXTREME'}}" class="preview-pill danger">偏激进</view>
        <view wx:elif="{{goalPreview.status === 'ready'}}" class="preview-pill">{{settings.goalCalorieStrategy === 'MANUAL' ? '手动方案' : '智能推荐'}}</view>
      </view>

      <view class="goal-preview-main {{goalPreview.status === 'ready' ? '' : 'muted'}}">
        {{goalPreview.status === 'ready' ? goalPreview.targetCaloriesLabel : '--'}}
      </view>
      <view class="goal-preview-meta">热量差值 {{goalPreview.status === 'ready' ? goalPreview.deltaLabel : '--'}}</view>
      <view class="goal-preview-meta">{{goalPreview.status === 'ready' ? goalPreview.weeklyLabel : '--'}}</view>
      <view class="goal-preview-note {{goalPreview.noticeTone === 'warning' ? 'warning' : ''}}">
        {{goalPreview.noticeText}}
      </view>
    </view>
  </view>

  <view class="progress-entry-card" bindtap="handleOpenProgress">
    <view class="field-card-main">
      <view class="field-card-stack">
        <view class="field-card-title">体征记录与趋势</view>
        <view class="field-card-sub">查看体重和围度记录</view>
      </view>
    </view>
    <view class="field-card-action">查看</view>
  </view>

  <view class="primary-button" bindtap="handleSave">保存</view>

  <view wx:if="{{sheet.visible}}" class="sheet-overlay" bindtap="handleCloseSheet"></view>
  <view wx:if="{{sheet.visible}}" class="editor-sheet panel" catchtouchmove="noop">
    <view class="sheet-head">
      <view>
        <view class="sheet-title">{{sheet.title}}</view>
      </view>
      <view class="sheet-close" bindtap="handleCloseSheet">✕</view>
    </view>

    <view class="field-group sheet-field-group">
      <view class="field-label">{{sheet.fieldLabel}}</view>
      <input class="field-input" type="digit" value="{{sheet.inputValue}}" bindinput="handleSheetInput" placeholder="请输入数值" />
    </view>

    <view
      wx:if="{{sheet.type === 'BMR'}}"
      class="estimate-btn {{sheet.smartAvailable ? '' : 'disabled'}}"
      bindtap="handleUseSmartValue"
    >
      使用估算值：{{sheet.smartValue}}
    </view>
    <view class="sheet-hint">{{sheet.hint}}</view>

    <view class="primary-button sheet-primary" bindtap="handleSaveSheet">
      {{sheet.saving ? '确认中...' : '确认'}}
    </view>
  </view>
</view>

<empty-state wx:else title="健康档案加载失败" description="下拉刷新后重试。" />

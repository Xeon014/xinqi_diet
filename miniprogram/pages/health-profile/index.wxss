.health-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  padding-bottom: calc(44rpx + env(safe-area-inset-bottom));
}

.strategy-panel {
  padding: 26rpx;
}

.summary-badges {
  display: flex;
  gap: 12rpx;
  padding: 0 4rpx;
}

.summary-badge {
  align-items: baseline;
  background: linear-gradient(135deg, rgba(245, 247, 242, 0.98) 0%, rgba(252, 249, 243, 0.96) 100%);
  border: 2rpx solid rgba(107, 144, 132, 0.12);
  border-radius: 999rpx;
  color: #5d8378;
  display: inline-flex;
  gap: 10rpx;
  padding: 12rpx 20rpx;
}

.summary-badge-label {
  font-size: 22rpx;
  font-weight: 700;
}

.summary-badge-value {
  color: #37423d;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 1;
}

.field-card,
.progress-entry-card {
  background: linear-gradient(180deg, rgba(252, 250, 245, 0.98) 0%, rgba(247, 243, 237, 0.98) 100%);
  border: 2rpx solid rgba(107, 144, 132, 0.08);
  border-radius: 24rpx;
  padding: 22rpx;
}

.field-card-head,
.field-card-main {
  align-items: center;
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.field-card-title {
  color: #37423d;
  font-size: 28rpx;
  font-weight: 700;
}

.field-card-stack {
  flex: 1;
  min-width: 0;
}

.field-card-sub {
  color: #7d7c74;
  font-size: 23rpx;
  line-height: 1.5;
}

.field-card-stack .field-card-sub {
  margin-top: 8rpx;
}

.field-card-input,
.field-card-picker {
  align-items: center;
  background: rgba(252, 250, 245, 0.96);
  border: 2rpx solid rgba(107, 144, 132, 0.12);
  border-radius: 20rpx;
  color: #37423d;
  display: flex;
  font-size: 28rpx;
  height: 88rpx;
  margin-top: 18rpx;
  padding: 0 22rpx;
  width: 100%;
}

.field-card-half .field-card-picker,
.field-card-half .field-card-input {
  margin-top: 16rpx;
}

.inline-field-card {
  padding: 0;
}

.inline-field-main {
  align-items: center;
  display: flex;
  gap: 20rpx;
  justify-content: space-between;
  min-height: 92rpx;
  padding: 0 22rpx;
}

.inline-field-input,
.inline-field-picker {
  color: #37423d;
  flex: 1;
  font-size: 28rpx;
  font-weight: 700;
  min-width: 0;
  text-align: right;
}

.inline-field-input {
  height: 92rpx;
}

.inline-field-picker {
  line-height: 92rpx;
}

.strategy-control-row {
  align-items: center;
  margin-top: 16rpx;
}

.strategy-button-group {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.strategy-chip {
  align-items: center;
  background: rgba(252, 250, 245, 0.92);
  border: 2rpx solid rgba(107, 144, 132, 0.14);
  border-radius: 999rpx;
  color: #5d8378;
  display: inline-flex;
  font-size: 26rpx;
  font-weight: 700;
  height: 72rpx;
  justify-content: center;
  min-width: 0;
  padding: 0 18rpx;
}

.strategy-chip.active {
  background: rgba(107, 144, 132, 0.14);
  border-color: rgba(107, 144, 132, 0.24);
}

.action-card,
.progress-entry-card {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.action-card {
  background: linear-gradient(135deg, rgba(107, 144, 132, 0.12) 0%, rgba(252, 249, 243, 0.98) 82%);
  border: 2rpx solid rgba(107, 144, 132, 0.16);
}

.progress-entry-card {
  background: linear-gradient(135deg, rgba(245, 247, 242, 0.98) 0%, rgba(252, 249, 243, 0.96) 100%);
  border: 2rpx solid rgba(107, 144, 132, 0.08);
  margin-top: 4rpx;
}

.field-card-action {
  color: #5d8378;
  font-size: 24rpx;
  font-weight: 700;
  margin-left: 18rpx;
}

.goal-preview-card {
  background: linear-gradient(135deg, rgba(107, 144, 132, 0.12) 0%, rgba(252, 249, 243, 0.98) 78%);
  border: 2rpx solid rgba(107, 144, 132, 0.16);
  border-radius: 24rpx;
  margin-top: 18rpx;
  padding: 22rpx;
}

.goal-preview-head {
  align-items: center;
  display: flex;
  gap: 12rpx;
  justify-content: space-between;
}

.goal-preview-title {
  color: #37423d;
  font-size: 28rpx;
  font-weight: 700;
}

.preview-pill {
  background: rgba(107, 144, 132, 0.14);
  border-radius: 999rpx;
  color: #5d8378;
  font-size: 22rpx;
  font-weight: 700;
  padding: 10rpx 18rpx;
}

.preview-pill.danger {
  background: rgba(187, 134, 108, 0.14);
  color: #bb866c;
}

.goal-preview-main {
  color: #37423d;
  font-size: 42rpx;
  font-weight: 800;
  margin-top: 16rpx;
}

.goal-preview-main.muted {
  color: #8f877d;
}

.goal-preview-meta {
  color: #7d7c74;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.goal-preview-note {
  background: rgba(252, 250, 245, 0.84);
  border-radius: 18rpx;
  color: #37423d;
  display: flex;
  align-items: center;
  font-size: 24rpx;
  line-height: 1.55;
  margin-top: 14rpx;
  min-height: 92rpx;
  padding: 16rpx 18rpx;
}

.goal-preview-note.warning {
  background: rgba(187, 134, 108, 0.12);
  color: #9a6a54;
}

.sheet-overlay {
  background: rgba(54, 66, 61, 0.22);
  inset: 0;
  position: fixed;
  z-index: 30;
}

.editor-sheet {
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  bottom: 0;
  left: 0;
  padding: 30rpx 28rpx calc(36rpx + env(safe-area-inset-bottom));
  position: fixed;
  right: 0;
  z-index: 31;
}

.sheet-head {
  align-items: flex-start;
  display: flex;
  justify-content: space-between;
}

.sheet-title {
  color: #37423d;
  font-size: 34rpx;
  font-weight: 800;
}

.sheet-close {
  align-items: center;
  color: #5d8378;
  display: flex;
  font-size: 32rpx;
  font-weight: 700;
  height: 64rpx;
  justify-content: center;
  width: 64rpx;
}

.sheet-field-group {
  margin-top: 28rpx;
}

.estimate-btn {
  align-items: center;
  background: linear-gradient(135deg, rgba(107, 144, 132, 0.12) 0%, rgba(107, 144, 132, 0.08) 100%);
  border: 2rpx solid rgba(107, 144, 132, 0.22);
  border-radius: 16rpx;
  color: #5d8378;
  display: flex;
  font-size: 26rpx;
  font-weight: 600;
  justify-content: center;
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
}

.estimate-btn.disabled {
  background: rgba(242, 238, 232, 0.9);
  border-color: rgba(107, 144, 132, 0.12);
  color: #8f877d;
}

.sheet-hint {
  color: #7d7c74;
  font-size: 23rpx;
  line-height: 1.6;
  margin-top: 14rpx;
}

.sheet-primary {
  margin-top: 28rpx;
}

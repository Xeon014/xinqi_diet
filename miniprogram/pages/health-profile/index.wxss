.health-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.module-panel {
  padding: 28rpx;
}

.metrics-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1.15fr 0.85fr;
  margin-top: 24rpx;
}

.metric-card {
  border-radius: 24rpx;
  padding: 24rpx;
}

.metric-card:nth-child(odd) {
  margin-right: 12rpx;
}

.metric-card.green {
  background: linear-gradient(180deg, #eef7f3 0%, #e5f1eb 100%);
}

.metric-card.sand {
  background: linear-gradient(180deg, #faf3e8 0%, #f6e8d7 100%);
}

.metric-card.teal {
  background: linear-gradient(180deg, #edf7f5 0%, #e2f1ec 100%);
}

.metric-card.orange {
  background: linear-gradient(180deg, #fff4ea 0%, #fbe4d4 100%);
}

.metric-label {
  color: #685c50;
  font-size: 24rpx;
}

.metric-value {
  color: #2f2a24;
  font-size: 38rpx;
  font-weight: 700;
  margin-top: 12rpx;
}

.metric-unit {
  color: #786c60;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.sub-module {
  margin-top: 28rpx;
}

.sub-title {
  color: #2f2a24;
  font-size: 28rpx;
  font-weight: 700;
}

.calorie-row {
  display: grid;
  gap: 16rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 18rpx;
}

.calorie-box {
  background: #fbf7f0;
  border-radius: 22rpx;
  padding: 22rpx;
}

.calorie-label {
  color: #786c60;
  font-size: 22rpx;
}

.calorie-value {
  color: #2f2a24;
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 12rpx;
}

.calorie-unit {
  color: #786c60;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.compact-input {
  margin-top: 12rpx;
}

.result-pill {
  border-radius: 999rpx;
  display: inline-flex;
  font-size: 22rpx;
  font-weight: 600;
  margin-top: 18rpx;
  padding: 10rpx 18rpx;
}

.result-pill.success {
  background: rgba(30, 90, 79, 0.14);
  color: #1e5a4f;
}

.result-pill.danger {
  background: rgba(185, 94, 58, 0.14);
  color: #b95e3a;
}

.nutrient-module {
  margin-top: 28rpx;
}

.nutrient-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 18rpx;
}

.nutrient-card {
  background: #fbf7f0;
  border-radius: 22rpx;
  padding: 22rpx 18rpx;
  text-align: center;
}

.nutrient-label {
  color: #6e6256;
  font-size: 22rpx;
}

.nutrient-value {
  color: #2f2a24;
  font-size: 34rpx;
  font-weight: 700;
  margin-top: 10rpx;
}

.nutrient-unit {
  color: #84786b;
  font-size: 20rpx;
  margin-top: 6rpx;
}

.field-group {
  margin-top: 24rpx;
}

.field-picker {
  background: #fffef9;
  border: 2rpx solid rgba(70, 57, 47, 0.12);
  border-radius: 22rpx;
  color: #2f2a24;
  font-size: 28rpx;
  min-height: 88rpx;
  padding: 24rpx;
}

.coming-soon {
  color: #857a6d;
  font-size: 24rpx;
  line-height: 1.7;
  margin-top: 18rpx;
}

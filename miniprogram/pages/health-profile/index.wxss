.health-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: calc(52rpx + env(safe-area-inset-bottom));
}

.module-panel {
  padding: 28rpx;
}

.metrics-grid {
  display: grid;
  gap: 16rpx;
  grid-template-columns: 1.15fr 0.85fr;
  margin-top: 24rpx;
}

.metric-card {
  border-radius: 24rpx;
  padding: 24rpx;
}

.metric-card:nth-child(odd) {
  margin-right: 12rpx;
}

.metric-card.green {
  background: linear-gradient(180deg, #eef7f3 0%, #e5f1eb 100%);
}

.metric-card.sand {
  background: linear-gradient(180deg, #faf3e8 0%, #f6e8d7 100%);
}

.metric-card.teal {
  background: linear-gradient(180deg, #edf7f5 0%, #e2f1ec 100%);
}

.metric-card.orange {
  background: linear-gradient(180deg, #fff4ea 0%, #fbe4d4 100%);
}

.metric-card.plum {
  background: linear-gradient(180deg, #f6eef9 0%, #eadcf4 100%);
}

.metric-label {
  color: #685c50;
  font-size: 24rpx;
}

.metric-value {
  color: #2f2a24;
  font-size: 38rpx;
  font-weight: 700;
  margin-top: 12rpx;
}

.metric-unit {
  color: #786c60;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.field-group {
  margin-top: 24rpx;
}

.two-column {
  display: flex;
  gap: 16rpx;
}

.field-half {
  flex: 1;
}

.setting-entry-card {
  align-items: center;
  background: linear-gradient(135deg, rgba(30, 90, 79, 0.12) 0%, rgba(255, 253, 248, 0.98) 78%);
  border: 2rpx solid rgba(30, 90, 79, 0.18);
  border-radius: 24rpx;
  display: flex;
  justify-content: space-between;
  margin-top: 24rpx;
  padding: 24rpx;
}

.setting-entry-main {
  flex: 1;
  min-width: 0;
}

.setting-entry-title {
  color: #2f2a24;
  font-size: 28rpx;
  font-weight: 700;
}

.setting-entry-sub {
  color: #6f6559;
  font-size: 23rpx;
  margin-top: 10rpx;
}

.setting-entry-action {
  color: #1e5a4f;
  font-size: 24rpx;
  font-weight: 700;
  margin-left: 18rpx;
}

.goal-mode-row {
  display: flex;
  gap: 16rpx;
  margin-top: 26rpx;
}

.goal-mode-chip {
  align-items: center;
  background: rgba(255, 255, 255, 0.88);
  border: 2rpx solid rgba(30, 90, 79, 0.16);
  border-radius: 999rpx;
  color: #1e5a4f;
  display: inline-flex;
  font-size: 24rpx;
  font-weight: 700;
  height: 74rpx;
  justify-content: center;
  min-width: 160rpx;
  padding: 0 22rpx;
}

.goal-mode-chip.active {
  background: rgba(30, 90, 79, 0.16);
  border-color: rgba(30, 90, 79, 0.3);
}

.sheet-overlay {
  background: rgba(37, 30, 22, 0.34);
  inset: 0;
  position: fixed;
  z-index: 30;
}

.editor-sheet {
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  bottom: 0;
  left: 0;
  padding: 30rpx 28rpx calc(36rpx + env(safe-area-inset-bottom));
  position: fixed;
  right: 0;
  z-index: 31;
}

.sheet-head {
  align-items: flex-start;
  display: flex;
  justify-content: space-between;
}

.sheet-title {
  color: #2f2a24;
  font-size: 34rpx;
  font-weight: 800;
}

.sheet-current {
  color: #6f6559;
  font-size: 23rpx;
  line-height: 1.5;
  margin-top: 10rpx;
}

.sheet-close {
  align-items: center;
  color: #1e5a4f;
  display: flex;
  font-size: 32rpx;
  font-weight: 700;
  height: 64rpx;
  justify-content: center;
  width: 64rpx;
}

.sheet-field-group {
  margin-top: 28rpx;
}

.estimate-btn {
  align-items: center;
  background: linear-gradient(135deg, rgba(30, 90, 79, 0.12) 0%, rgba(30, 90, 79, 0.08) 100%);
  border: 2rpx solid rgba(30, 90, 79, 0.24);
  border-radius: 16rpx;
  color: #1e5a4f;
  display: flex;
  font-size: 26rpx;
  font-weight: 600;
  justify-content: center;
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
}

.estimate-btn.disabled {
  background: rgba(244, 239, 232, 0.9);
  border-color: rgba(70, 57, 47, 0.12);
  color: #8f877d;
}

.sheet-hint {
  color: #786c60;
  font-size: 23rpx;
  line-height: 1.6;
  margin-top: 14rpx;
}

.goal-summary-card {
  background: linear-gradient(180deg, rgba(246, 249, 247, 0.98) 0%, rgba(234, 244, 239, 0.95) 100%);
  border: 2rpx solid rgba(30, 90, 79, 0.12);
  border-radius: 20rpx;
  margin-top: 18rpx;
  padding: 22rpx 24rpx;
}

.goal-summary-label {
  color: #685c50;
  font-size: 23rpx;
}

.goal-summary-value {
  color: #1e5a4f;
  font-size: 32rpx;
  font-weight: 800;
  margin-top: 10rpx;
}

.sheet-primary {
  margin-top: 28rpx;
}

<view class="page-shell food-search-page">
  <view class="search-bar panel">
    <input class="search-input" placeholder="搜索食物" value="{{keyword}}" bindinput="handleInput" confirm-type="search" />
    <view class="custom-entry" bindtap="handleOpenCustomFood">自定义食物</view>
  </view>

  <view class="food-layout">
    <view class="category-sidebar panel">
      <view
        wx:for="{{systemFilters}}"
        wx:key="key"
        class="category-item {{selectedCategoryKey === item.key ? 'active' : ''}}"
        data-key="{{item.key}}"
        bindtap="handleCategoryTap"
      >
        {{item.label}}
      </view>
      <view class="category-divider"></view>
      <view
        wx:for="{{builtinCategories}}"
        wx:key="key"
        class="category-item {{selectedCategoryKey === item.key ? 'active' : ''}}"
        data-key="{{item.key}}"
        bindtap="handleCategoryTap"
      >
        {{item.label}}
      </view>
    </view>

    <view class="food-content">
      <view wx:if="{{displayedFoods.length}}" class="panel section-panel">
        <view class="section-title-small">{{currentCategoryLabel}}</view>
        <view class="food-list compact-list">
          <view
            wx:for="{{displayedFoods}}"
            wx:key="id"
            class="food-item"
            data-index="{{index}}"
            bindtap="handleSelectFood"
          >
            <view class="food-top">
              <view class="food-name">{{item.name}}</view>
              <view class="food-calories">{{item.caloriesPer100g}} kcal</view>
            </view>
            <view class="food-bottom">{{item.categoryLabel}} · 蛋白 {{item.proteinPer100g}}g · 碳水 {{item.carbsPer100g}}g · 脂肪 {{item.fatPer100g}}g</view>
          </view>
        </view>
      </view>

      <empty-state wx:if="{{!displayedFoods.length}}" title="{{emptyTitle}}" description="{{emptyDescription}}" />
    </view>
  </view>
</view>

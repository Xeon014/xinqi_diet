.food-search-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.search-bar {
  align-items: center;
  border: 1rpx solid rgba(70, 57, 47, 0.14);
  display: flex;
  gap: 16rpx;
  margin-left: 16rpx;
  padding: 18rpx;
}

.search-input {
  background: #fffef9;
  border-radius: 999rpx;
  flex: 1;
  font-size: 28rpx;
  height: 82rpx;
  padding: 0 24rpx;
}

.custom-entry {
  align-items: center;
  background: rgba(30, 90, 79, 0.1);
  border: 1rpx solid rgba(30, 90, 79, 0.14);
  border-radius: 999rpx;
  color: #1e5a4f;
  display: flex;
  font-size: 24rpx;
  font-weight: 700;
  height: 82rpx;
  justify-content: center;
  padding: 0 24rpx;
  white-space: nowrap;
}

.food-layout {
  display: flex;
  gap: 16rpx;
  min-height: 760rpx;
}

.category-sidebar {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 12rpx;
  width: 168rpx;
}

.category-item {
  border-radius: 20rpx;
  color: #675b4f;
  font-size: 24rpx;
  font-weight: 600;
  padding: 18rpx 12rpx;
  text-align: center;
}

.category-item.active {
  background: rgba(30, 90, 79, 0.14);
  color: #1e5a4f;
  font-weight: 700;
}

.category-divider {
  border-top: 1rpx solid rgba(70, 57, 47, 0.18);
  margin: 8rpx 10rpx;
}

.food-content {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 16rpx;
}

.section-panel {
  padding: 24rpx;
}

.section-title-small {
  color: #2f2a24;
  font-size: 27rpx;
  font-weight: 700;
}

.compact-list {
  gap: 14rpx;
  margin-top: 18rpx;
}

.food-list {
  display: flex;
  flex-direction: column;
}

.food-item {
  border-bottom: 1rpx solid rgba(70, 57, 47, 0.1);
  padding: 18rpx 0;
}

.food-item:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.food-top {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.food-name {
  color: #2f2a24;
  font-size: 30rpx;
  font-weight: 700;
}

.food-calories {
  color: #1e5a4f;
  font-size: 24rpx;
  font-weight: 700;
}

.food-bottom {
  color: #7a6d60;
  font-size: 22rpx;
  line-height: 1.62;
  margin-top: 10rpx;
}

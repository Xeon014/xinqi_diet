.food-search-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.search-bar {
  align-items: center;
  display: flex;
  gap: 16rpx;
  padding: 18rpx;
}

.search-input {
  background: #fff;
  border-radius: 999rpx;
  flex: 1;
  font-size: 28rpx;
  height: 82rpx;
  padding: 0 24rpx;
}

.custom-entry {
  align-items: center;
  background: rgba(31, 111, 95, 0.08);
  border-radius: 999rpx;
  color: #1f6f5f;
  display: flex;
  font-size: 24rpx;
  font-weight: 600;
  height: 82rpx;
  justify-content: center;
  padding: 0 24rpx;
  white-space: nowrap;
}

.food-layout {
  display: flex;
  gap: 16rpx;
  min-height: 760rpx;
}

.category-sidebar {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 12rpx;
  width: 160rpx;
}

.category-item {
  border-radius: 20rpx;
  color: #6f6154;
  font-size: 24rpx;
  padding: 18rpx 12rpx;
  text-align: center;
}

.category-item.active {
  background: rgba(31, 111, 95, 0.12);
  color: #1f6f5f;
  font-weight: 700;
}

.category-divider {
  border-top: 1rpx solid rgba(93, 76, 58, 0.16);
  margin: 8rpx 10rpx;
}

.food-content {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 16rpx;
}

.section-panel {
  padding: 24rpx;
}

.section-title-small {
  color: #3d3025;
  font-size: 26rpx;
  font-weight: 700;
}

.compact-list {
  gap: 14rpx;
  margin-top: 18rpx;
}

.food-list {
  display: flex;
  flex-direction: column;
}

.food-item {
  border-bottom: 1rpx solid rgba(93, 76, 58, 0.08);
  padding: 18rpx 0;
}

.food-item:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.food-top {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.food-name {
  color: #34281e;
  font-size: 30rpx;
  font-weight: 600;
}

.food-calories {
  color: #1f6f5f;
  font-size: 24rpx;
  font-weight: 600;
}

.food-bottom {
  color: #8f8373;
  font-size: 22rpx;
  line-height: 1.6;
  margin-top: 10rpx;
}

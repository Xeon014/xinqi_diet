<view class="page-shell food-history-page">
  <view class="panel history-head">
    <view class="history-title">历史记录</view>
    <view class="history-subtitle">选择后会带回编辑页，默认添加到 {{targetDate}} · {{targetMealTypeLabel}}</view>
  </view>

  <view wx:if="{{groups.length}}" class="history-group-list">
    <view wx:for="{{groups}}" wx:key="date" wx:for-item="group" wx:for-index="groupIndex" class="panel history-group">
      <view class="group-date">{{group.date}}</view>
      <view
        wx:for="{{group.items}}"
        wx:key="id"
        wx:for-item="item"
        wx:for-index="itemIndex"
        class="history-item"
        data-group-index="{{groupIndex}}"
        data-item-index="{{itemIndex}}"
        bindtap="handleSelectRecord"
      >
        <view class="history-item-main">
          <view class="history-item-title">{{item.foodName}}</view>
          <view class="history-item-meta">{{item.metaText}}</view>
        </view>
        <view class="history-item-arrow">›</view>
      </view>
    </view>

    <view class="history-more-row">
      <view wx:if="{{hasMore}}" class="history-more-btn {{loadingMore ? 'disabled' : ''}}" bindtap="handleLoadMore">
        {{loadingMore ? '加载中...' : '加载更多'}}
      </view>
      <view wx:else class="history-more-end">已展示全部</view>
    </view>
  </view>

  <empty-state
    wx:else
    title="还没有历史记录"
    description="记录过一次后，这里会按时间列出历史食物。"
  />
</view>

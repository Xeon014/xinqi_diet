.exercise-search-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.search-bar {
  align-items: center;
  border: 1rpx solid rgba(70, 57, 47, 0.14);
  display: flex;
  margin-left: 16rpx;
  padding: 18rpx;
}

.search-input {
  background: #fffef9;
  border-radius: 999rpx;
  flex: 1;
  font-size: 28rpx;
  height: 82rpx;
  padding: 0 24rpx;
}

.exercise-layout {
  display: flex;
  gap: 16rpx;
  min-height: 760rpx;
}

.category-sidebar {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 12rpx;
  width: 168rpx;
}

.category-item {
  border-radius: 20rpx;
  color: #675b4f;
  font-size: 24rpx;
  font-weight: 600;
  padding: 18rpx 12rpx;
  text-align: center;
}

.category-item.active {
  background: rgba(30, 90, 79, 0.14);
  color: #1e5a4f;
  font-weight: 700;
}

.category-divider {
  border-top: 1rpx solid rgba(70, 57, 47, 0.18);
  margin: 8rpx 10rpx;
}

.exercise-content {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 16rpx;
}

.exercise-content.full {
  width: 100%;
}

.section-panel {
  padding: 24rpx;
}

.section-head-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.section-title-small {
  color: #2f2a24;
  font-size: 27rpx;
  font-weight: 700;
}

.section-title-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.section-title-tag {
  background: rgba(30, 90, 79, 0.1);
  border: 1rpx solid rgba(30, 90, 79, 0.18);
  border-radius: 999rpx;
  color: #1e5a4f;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  padding: 12rpx 22rpx;
}

.section-add-btn {
  align-items: center;
  background: rgba(30, 90, 79, 0.08);
  border: 1rpx solid rgba(30, 90, 79, 0.2);
  border-radius: 999rpx;
  color: #1e5a4f;
  display: flex;
  font-size: 22rpx;
  font-weight: 700;
  height: 54rpx;
  justify-content: center;
  min-width: 98rpx;
  padding: 0 18rpx;
}

.clear-btn {
  color: #7d7062;
  font-size: 23rpx;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.history-chip {
  background: rgba(93, 76, 58, 0.08);
  border-radius: 999rpx;
  color: #5d4c3a;
  font-size: 22rpx;
  font-weight: 600;
  max-width: 100%;
  overflow: hidden;
  padding: 10rpx 20rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.compact-list {
  gap: 14rpx;
  margin-top: 18rpx;
}

.exercise-list {
  display: flex;
  flex-direction: column;
}

.exercise-item {
  border-bottom: 1rpx solid rgba(70, 57, 47, 0.1);
  padding: 18rpx 0;
}

.exercise-item:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.exercise-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.exercise-name {
  color: #2f2a24;
  font-size: 30rpx;
  font-weight: 700;
}

.exercise-met {
  color: #1e5a4f;
  font-size: 24rpx;
  font-weight: 700;
}

.exercise-meta {
  color: #75695d;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.editor-overlay {
  background: rgba(38, 29, 22, 0.36);
  inset: 0;
  position: fixed;
  z-index: 20;
}

.editor-sheet {
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  bottom: 0;
  left: 0;
  padding: 26rpx 26rpx calc(26rpx + env(safe-area-inset-bottom));
  position: fixed;
  right: 0;
  z-index: 30;
}

.editor-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.editor-title {
  color: #2f2a24;
  font-size: 30rpx;
  font-weight: 700;
}

.editor-head-actions {
  align-items: center;
  display: flex;
  gap: 10rpx;
}

.icon-action,
.editor-delete {
  align-items: center;
  border-radius: 999rpx;
  display: flex;
  justify-content: center;
}

.icon-action {
  color: #7d7062;
  font-size: 28rpx;
  font-weight: 700;
  height: 60rpx;
  width: 60rpx;
}

.editor-delete {
  background: rgba(185, 94, 58, 0.12);
  color: #b95e3a;
  font-size: 22rpx;
  font-weight: 700;
  height: 54rpx;
  padding: 0 18rpx;
}

.icon-action.disabled,
.editor-delete.disabled,
.editor-submit-btn.disabled {
  opacity: 0.6;
}

.editor-exercise-name {
  color: #2f2a24;
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 18rpx;
}

.editor-exercise-meta {
  color: #75695d;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.editor-row {
  margin-top: 20rpx;
}

.duration-wrap {
  align-items: center;
  display: flex;
}

.duration-input {
  background: #fffef9;
  border: 2rpx solid rgba(70, 57, 47, 0.14);
  border-radius: 18rpx;
  font-size: 30rpx;
  height: 84rpx;
  padding: 0 20rpx;
  text-align: right;
  width: 220rpx;
}

.duration-unit {
  color: #6f6255;
  font-size: 25rpx;
  margin-left: 12rpx;
}

.intensity-chip {
  align-items: center;
  background: rgba(30, 90, 79, 0.08);
  border: 1rpx solid rgba(30, 90, 79, 0.2);
  border-radius: 999rpx;
  color: #1e5a4f;
  display: inline-flex;
  font-size: 24rpx;
  font-weight: 700;
  height: 60rpx;
  padding: 0 22rpx;
}

.editor-summary-card {
  background: rgba(255, 255, 255, 0.76);
  border-radius: 18rpx;
  margin-top: 20rpx;
  padding: 16rpx;
}

.summary-label {
  color: #74685c;
  font-size: 22rpx;
}

.summary-value {
  color: #1e5a4f;
  font-size: 30rpx;
  font-weight: 700;
  margin-top: 10rpx;
}

.editor-action-row {
  margin-top: 16rpx;
}

.editor-submit-btn {
  align-items: center;
  background: linear-gradient(128deg, #1e5a4f 0%, #2a7364 100%);
  border: 1rpx solid rgba(19, 62, 54, 0.22);
  border-radius: 999rpx;
  color: #fffef8;
  display: flex;
  font-size: 26rpx;
  font-weight: 700;
  height: 88rpx;
  justify-content: center;
}

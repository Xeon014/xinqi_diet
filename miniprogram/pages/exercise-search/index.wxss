.exercise-search-page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.search-bar {
  border: 1rpx solid rgba(70, 57, 47, 0.14);
  margin-left: 16rpx;
  padding: 16rpx;
}

.search-input {
  background: #fffef9;
  border-radius: 999rpx;
  font-size: 28rpx;
  height: 80rpx;
  padding: 0 24rpx;
}

.category-panel {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  padding: 18rpx;
}

.category-chip {
  background: rgba(93, 76, 58, 0.08);
  border-radius: 999rpx;
  color: #5d4c3a;
  font-size: 22rpx;
  font-weight: 600;
  padding: 10rpx 20rpx;
}

.category-chip.active {
  background: rgba(30, 90, 79, 0.14);
  color: #1e5a4f;
}

.list-panel {
  padding: 6rpx 20rpx;
}

.exercise-item {
  border-bottom: 1rpx solid rgba(70, 57, 47, 0.1);
  padding: 16rpx 0;
}

.exercise-item:last-child {
  border-bottom: 0;
}

.exercise-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.exercise-name {
  color: #2f2a24;
  font-size: 29rpx;
  font-weight: 700;
}

.exercise-met {
  color: #1e5a4f;
  font-size: 24rpx;
  font-weight: 700;
}

.exercise-meta {
  color: #74685c;
  font-size: 22rpx;
  margin-top: 8rpx;
}
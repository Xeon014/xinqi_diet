.exercise-search-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.search-bar {
  align-items: center;
  border: 1rpx solid rgba(107, 144, 132, 0.1);
  display: flex;
  padding: 18rpx;
}

.search-input {
  background: rgba(253, 251, 247, 0.96);
  border-radius: 999rpx;
  color: #323b38;
  flex: 1;
  font-size: 28rpx;
  height: 82rpx;
  padding: 0 24rpx;
}

.exercise-layout {
  display: flex;
  gap: 16rpx;
  min-height: 760rpx;
}

.category-sidebar {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 12rpx;
  width: 168rpx;
}

.category-item {
  border-radius: 20rpx;
  color: #6f6b64;
  font-size: 24rpx;
  font-weight: 600;
  padding: 18rpx 12rpx;
  text-align: center;
}

.category-item.active {
  background: rgba(107, 144, 132, 0.1);
  color: #5d8378;
  font-weight: 700;
}

.category-divider {
  border-top: 1rpx solid rgba(107, 144, 132, 0.12);
  margin: 8rpx 10rpx;
}

.exercise-content {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: 16rpx;
}

.exercise-content.full {
  width: 100%;
}

.section-panel {
  padding: 24rpx;
}

.section-head-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.section-title-small {
  color: #394541;
  font-size: 27rpx;
  font-weight: 700;
}

.section-title-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.section-title-tag {
  background: rgba(107, 144, 132, 0.08);
  border: 1rpx solid rgba(107, 144, 132, 0.12);
  border-radius: 999rpx;
  color: #5d8378;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
  padding: 12rpx 22rpx;
}

.section-add-btn {
  align-items: center;
  background: rgba(107, 144, 132, 0.08);
  border: 1rpx solid rgba(107, 144, 132, 0.14);
  border-radius: 999rpx;
  color: #5d8378;
  display: flex;
  font-size: 22rpx;
  font-weight: 700;
  height: 54rpx;
  justify-content: center;
  min-width: 98rpx;
  padding: 0 18rpx;
}

.clear-btn {
  color: #7b746c;
  font-size: 23rpx;
}

.history-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 14rpx;
}

.history-chip {
  background: rgba(107, 144, 132, 0.08);
  border-radius: 999rpx;
  color: #5b665f;
  font-size: 22rpx;
  font-weight: 600;
  max-width: 100%;
  overflow: hidden;
  padding: 10rpx 20rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.compact-list {
  gap: 14rpx;
  margin-top: 18rpx;
}

.exercise-list {
  display: flex;
  flex-direction: column;
}

.exercise-swipe-cell {
  overflow: hidden;
  position: relative;
}

.exercise-swipe-action-track {
  align-items: center;
  display: flex;
  inset: 0;
  justify-content: flex-end;
  position: absolute;
}

.exercise-swipe-action-shell {
  align-items: center;
  display: flex;
  gap: 14rpx;
  height: 100%;
  justify-content: center;
  width: 84px;
}

.exercise-swipe-action-shell.double {
  width: 168px;
}

.exercise-swipe-content {
  background:
    linear-gradient(180deg, rgba(253, 252, 248, 0.98) 0%, rgba(248, 245, 238, 0.95) 100%),
    #fcfaf5;
  position: relative;
  width: 100%;
  z-index: 1;
}

.exercise-swipe-delete-btn {
  height: 64rpx;
  width: 64rpx;
}

.exercise-swipe-repeat-btn {
  align-items: center;
  background: rgba(107, 144, 132, 0.14);
  border-radius: 999rpx;
  color: #5d8378;
  display: inline-flex;
  font-size: 22rpx;
  font-weight: 700;
  height: 64rpx;
  justify-content: center;
  min-width: 128rpx;
  padding: 0 24rpx;
}

.exercise-item {
  border-bottom: 1rpx solid rgba(107, 144, 132, 0.08);
  padding: 18rpx 0;
}

.exercise-item:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.exercise-swipe-cell .exercise-item {
  border-bottom: 1rpx solid rgba(107, 144, 132, 0.08);
  padding: 18rpx 0;
}

.exercise-swipe-cell:last-child .exercise-item {
  border-bottom: 0;
  padding-bottom: 0;
}

.exercise-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.exercise-name {
  color: #394541;
  font-size: 30rpx;
  font-weight: 700;
}

.exercise-met {
  color: #5d8378;
  font-size: 24rpx;
  font-weight: 700;
}

.exercise-meta {
  color: #78776f;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.editor-overlay {
  background: rgba(40, 43, 42, 0.3);
  inset: 0;
  position: fixed;
  z-index: 20;
}

.editor-sheet {
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  bottom: 0;
  left: 0;
  padding: 26rpx 26rpx calc(26rpx + env(safe-area-inset-bottom));
  position: fixed;
  right: 0;
  z-index: 30;
}

.editor-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.editor-title {
  color: #394541;
  font-size: 30rpx;
  font-weight: 700;
}

.editor-head-actions {
  align-items: center;
  display: flex;
  gap: 10rpx;
}

.icon-action,
.editor-delete {
  align-items: center;
  border-radius: 999rpx;
  display: flex;
  justify-content: center;
}

.icon-action {
  color: #7b746c;
  font-size: 28rpx;
  font-weight: 700;
  height: 60rpx;
  width: 60rpx;
}

.editor-delete {
  background: #d59889;
  box-shadow: 0 8rpx 14rpx rgba(213, 152, 137, 0.18);
  height: 60rpx;
  width: 60rpx;
}

.icon-action.disabled,
.editor-delete.disabled,
.editor-submit-btn.disabled {
  opacity: 0.6;
}

.editor-exercise-name {
  color: #394541;
  font-size: 36rpx;
  font-weight: 700;
  margin-top: 18rpx;
}

.editor-top-row {
  display: flex;
  gap: 12rpx;
  margin-top: 14rpx;
}

.editor-top-chip {
  align-items: center;
  background: rgba(107, 144, 132, 0.08);
  border: 1rpx solid rgba(107, 144, 132, 0.1);
  border-radius: 999rpx;
  color: #5b665f;
  display: inline-flex;
  font-size: 22rpx;
  font-weight: 600;
  height: 54rpx;
  justify-content: center;
  min-width: 164rpx;
  padding: 0 20rpx;
}

.editor-exercise-meta {
  color: #78776f;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.editor-row {
  margin-top: 20rpx;
}

.duration-wrap {
  align-items: center;
  display: flex;
}

.duration-input {
  background: rgba(253, 251, 247, 0.96);
  border: 2rpx solid rgba(107, 144, 132, 0.12);
  border-radius: 18rpx;
  font-size: 30rpx;
  height: 84rpx;
  padding: 0 20rpx;
  text-align: right;
  width: 220rpx;
}

.duration-unit {
  color: #78776f;
  font-size: 25rpx;
  margin-left: 12rpx;
}

.intensity-chip {
  align-items: center;
  background: rgba(107, 144, 132, 0.08);
  border: 1rpx solid rgba(107, 144, 132, 0.14);
  border-radius: 999rpx;
  color: #5d8378;
  display: inline-flex;
  font-size: 24rpx;
  font-weight: 700;
  height: 60rpx;
  padding: 0 22rpx;
}

.editor-summary-card {
  background: rgba(252, 249, 244, 0.82);
  border-radius: 18rpx;
  margin-top: 20rpx;
  padding: 16rpx;
}

.summary-label {
  color: #78776f;
  font-size: 22rpx;
}

.summary-value {
  color: #5d8378;
  font-size: 30rpx;
  font-weight: 700;
  margin-top: 10rpx;
}

.editor-action-row {
  margin-top: 16rpx;
}

.editor-submit-btn {
  align-items: center;
  background: linear-gradient(135deg, #6f968b 0%, #5d8378 100%);
  border: 1rpx solid rgba(107, 144, 132, 0.2);
  border-radius: 999rpx;
  color: #fffef8;
  display: flex;
  font-size: 26rpx;
  font-weight: 700;
  height: 88rpx;
  justify-content: center;
}

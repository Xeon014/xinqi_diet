<view class="page-shell record-entry-page">
  <view class="panel date-panel">
    <view>
      <view class="section-title">&#x8bb0;&#x5f55;&#x4e00;&#x9910;</view>
      <view class="section-subtitle">&#x5148;&#x9009;&#x65e5;&#x671f;&#xff0c;&#x518d;&#x8fdb;&#x5165;&#x5bf9;&#x5e94;&#x9910;&#x6b21;&#x5b8c;&#x6210;&#x8bb0;&#x5f55;</view>
    </view>

    <view class="field-group compact-group">
      <view class="field-label">&#x8bb0;&#x5f55;&#x65e5;&#x671f;</view>
      <picker mode="date" value="{{recordDate}}" bindchange="handleDateChange">
        <view class="date-picker">{{recordDate}}</view>
      </picker>
    </view>
  </view>

  <view class="meal-grid">
    <view wx:for="{{mealTypes}}" wx:key="value" class="meal-card panel" data-meal-type="{{item.value}}" bindtap="handleOpenEditor">
      <view class="meal-title">{{item.label}}</view>
      <view class="meal-note">{{item.note}}</view>
      <view class="meal-arrow">></view>
    </view>
  </view>
</view>
<view class="page-shell record-entry-page">
  <view class="panel date-panel">
    <view class="date-switch-row">
      <view class="date-step" bindtap="handlePrevDay">前一天</view>
      <picker mode="date" value="{{recordDate}}" bindchange="handleDateChange">
        <view class="date-center">
          <view class="date-label">{{displayDateLabel}}</view>
        </view>
      </picker>
      <view class="date-step" bindtap="handleNextDay">后一天</view>
    </view>
  </view>

  <view class="panel summary-panel">
    <view class="summary-grid">
      <view class="summary-item">
        <view class="summary-label">已摄入</view>
        <view class="summary-value">{{summary.consumedCalories}} kcal</view>
      </view>
      <view class="summary-item">
        <view class="summary-label">已消耗</view>
        <view class="summary-value">{{summary.exerciseCalories}} kcal</view>
      </view>
      <view class="summary-item">
        <view class="summary-label">目标</view>
        <view class="summary-value">{{summary.targetCalories}} kcal</view>
      </view>
      <view class="summary-item highlight {{summary.exceededTarget ? 'danger' : ''}}">
        <view class="summary-label">{{summary.exceededTarget ? '已超出' : '剩余'}}</view>
        <view class="summary-value">{{summary.remainingCalories}} kcal</view>
      </view>
    </view>
  </view>

  <view class="panel action-panel">
    <view class="entry-btn" bindtap="handleOpenDietEditor">记录{{recommendedMealLabel}}</view>
    <view class="entry-btn secondary" bindtap="handleOpenExerciseEditor">记录运动</view>
  </view>
</view>
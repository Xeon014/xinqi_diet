.record-entry-page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.date-panel {
  border: 1rpx solid rgba(30, 90, 79, 0.12);
  padding: 18rpx;
}

.date-switch-row {
  align-items: center;
  display: grid;
  gap: 10rpx;
  grid-template-columns: 120rpx 1fr 120rpx;
}

.date-step {
  align-items: center;
  background: rgba(30, 90, 79, 0.1);
  border-radius: 14rpx;
  color: #1e5a4f;
  display: flex;
  font-size: 22rpx;
  font-weight: 700;
  height: 74rpx;
  justify-content: center;
}

.date-center {
  align-items: center;
  background: #fffef9;
  border: 2rpx solid rgba(70, 57, 47, 0.14);
  border-radius: 16rpx;
  color: #2f2a24;
  display: flex;
  flex-direction: column;
  font-weight: 700;
  height: 74rpx;
  justify-content: center;
}

.date-label {
  font-size: 28rpx;
  line-height: 1.05;
}

.summary-panel {
  border: 1rpx solid rgba(30, 90, 79, 0.12);
  padding: 18rpx;
}

.summary-grid {
  display: grid;
  gap: 10rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.summary-item {
  background: rgba(255, 255, 255, 0.75);
  border-radius: 15rpx;
  padding: 12rpx;
}

.summary-item.highlight {
  background: rgba(30, 90, 79, 0.1);
}

.summary-item.highlight.danger {
  background: rgba(185, 94, 58, 0.12);
}

.summary-label {
  color: #74685c;
  font-size: 21rpx;
}

.summary-value {
  color: #2f2a24;
  font-size: 25rpx;
  font-weight: 700;
  margin-top: 6rpx;
}

.action-panel {
  display: grid;
  gap: 12rpx;
  padding: 18rpx;
}

.entry-btn {
  align-items: center;
  background: linear-gradient(128deg, #1e5a4f 0%, #2a7364 100%);
  border-radius: 999rpx;
  color: #fffef8;
  display: flex;
  font-size: 28rpx;
  font-weight: 700;
  height: 88rpx;
  justify-content: center;
}

.entry-btn.secondary {
  background: rgba(30, 90, 79, 0.1);
  color: #1e5a4f;
}

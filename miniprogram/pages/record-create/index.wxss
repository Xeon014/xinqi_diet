.record-entry-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.summary-panel {
  border: 1rpx solid rgba(30, 90, 79, 0.12);
  padding: 24rpx;
}

.summary-grid {
  display: grid;
  gap: 10rpx;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  margin-top: 14rpx;
}

.summary-item {
  background: rgba(255, 255, 255, 0.7);
  border-radius: 16rpx;
  padding: 12rpx;
}

.summary-item.highlight {
  background: rgba(30, 90, 79, 0.1);
}

.summary-item.highlight.danger {
  background: rgba(185, 94, 58, 0.12);
}

.summary-label {
  color: #74685c;
  font-size: 21rpx;
}

.summary-value {
  color: #2f2a24;
  font-size: 25rpx;
  font-weight: 700;
  margin-top: 6rpx;
}

.date-panel {
  border: 1rpx solid rgba(30, 90, 79, 0.12);
  padding: 24rpx;
}

.compact-group {
  margin-top: 18rpx;
}

.date-picker {
  align-items: center;
  background: #fffef9;
  border: 2rpx solid rgba(70, 57, 47, 0.14);
  border-radius: 18rpx;
  color: #2f2a24;
  display: flex;
  font-size: 26rpx;
  font-weight: 600;
  height: 80rpx;
  padding: 0 20rpx;
}

.quick-panel {
  padding: 24rpx;
}

.quick-action {
  align-items: center;
  background: rgba(30, 90, 79, 0.1);
  border: 1rpx solid rgba(30, 90, 79, 0.16);
  border-radius: 18rpx;
  color: #1e5a4f;
  display: flex;
  font-size: 26rpx;
  font-weight: 700;
  height: 78rpx;
  justify-content: center;
  margin-top: 10rpx;
}

.meal-grid {
  display: grid;
  gap: 10rpx;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  margin-top: 12rpx;
}

.meal-chip {
  align-items: center;
  background: #fffef9;
  border: 1rpx solid rgba(70, 57, 47, 0.14);
  border-radius: 14rpx;
  color: #5f5347;
  display: flex;
  font-size: 22rpx;
  font-weight: 600;
  justify-content: center;
  min-height: 64rpx;
  text-align: center;
}

.entry-list {
  padding: 6rpx 22rpx;
}

.entry-item {
  align-items: center;
  border-bottom: 1rpx solid rgba(70, 57, 47, 0.12);
  display: flex;
  gap: 16rpx;
  justify-content: space-between;
  min-height: 112rpx;
  padding: 16rpx 0;
}

.entry-item:last-child {
  border-bottom: 0;
}

.entry-main {
  flex: 1;
  min-width: 0;
}

.entry-title {
  color: #2f2a24;
  font-size: 30rpx;
  font-weight: 700;
}

.entry-note {
  color: #74685c;
  font-size: 22rpx;
  margin-top: 6rpx;
}

.entry-arrow {
  align-items: center;
  background: rgba(30, 90, 79, 0.1);
  border-radius: 12rpx;
  color: #1e5a4f;
  display: flex;
  font-size: 28rpx;
  font-weight: 700;
  height: 44rpx;
  justify-content: center;
  width: 44rpx;
}

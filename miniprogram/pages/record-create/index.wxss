.record-entry-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.date-panel {
  border: 1rpx solid rgba(30, 90, 79, 0.12);
  padding: 24rpx;
}

.compact-group {
  margin-top: 18rpx;
}

.date-picker {
  align-items: center;
  background: #fffef9;
  border: 2rpx solid rgba(70, 57, 47, 0.14);
  border-radius: 18rpx;
  color: #2f2a24;
  display: flex;
  font-size: 26rpx;
  font-weight: 600;
  height: 80rpx;
  padding: 0 20rpx;
}

.entry-list {
  padding: 6rpx 22rpx;
}

.entry-item {
  align-items: center;
  border-bottom: 1rpx solid rgba(70, 57, 47, 0.12);
  display: flex;
  gap: 16rpx;
  justify-content: space-between;
  min-height: 112rpx;
  padding: 16rpx 0;
}

.entry-item:last-child {
  border-bottom: 0;
}

.entry-main {
  flex: 1;
  min-width: 0;
}

.entry-title {
  color: #2f2a24;
  font-size: 30rpx;
  font-weight: 700;
}

.entry-note {
  color: #74685c;
  font-size: 22rpx;
  margin-top: 6rpx;
}

.entry-arrow {
  align-items: center;
  background: rgba(30, 90, 79, 0.1);
  border-radius: 12rpx;
  color: #1e5a4f;
  display: flex;
  font-size: 28rpx;
  font-weight: 700;
  height: 44rpx;
  justify-content: center;
  width: 44rpx;
}
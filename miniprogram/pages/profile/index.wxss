.profile-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.profile-hero {
  background:
    radial-gradient(circle at 100% 0%, rgba(196, 167, 140, 0.16), transparent 24%),
    linear-gradient(180deg, rgba(253, 250, 245, 0.98) 0%, rgba(247, 242, 235, 0.96) 100%);
  padding: 28rpx 24rpx 24rpx;
}

.hero-copy {
  position: relative;
}

.hero-title {
  color: #3b4842;
  font-size: 40rpx;
  font-weight: 800;
}

.hero-subtitle {
  color: #7d7c74;
  font-size: 23rpx;
  margin-top: 10rpx;
}

.hero-metrics {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 22rpx;
}

.hero-metric {
  border: 1rpx solid rgba(107, 144, 132, 0.08);
  border-radius: 24rpx;
  min-height: 132rpx;
  padding: 18rpx;
}

.hero-metric-bmi {
  background: linear-gradient(180deg, rgba(250, 248, 242, 0.98) 0%, rgba(244, 239, 232, 0.96) 100%);
}

.hero-metric-bmr {
  background: linear-gradient(180deg, rgba(251, 246, 241, 0.98) 0%, rgba(245, 239, 232, 0.96) 100%);
}

.metric-label {
  color: #7d7c74;
  font-size: 22rpx;
}

.metric-value {
  color: #37423d;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 36rpx;
  font-weight: 800;
  margin-top: 12rpx;
}

.info-group,
.tools-panel {
  padding: 16rpx 20rpx 6rpx;
}

.card-item,
.tool-item {
  align-items: center;
  border-top: 1rpx solid rgba(107, 144, 132, 0.08);
  display: flex;
  justify-content: space-between;
  min-height: 104rpx;
  padding: 18rpx 4rpx;
}

.card-item.first,
.tool-item:first-child {
  border-top: 0;
}

.card-main,
.tool-main {
  flex: 1;
  min-width: 0;
}

.card-title {
  color: #3b4842;
  font-size: 30rpx;
  font-weight: 700;
}

.card-arrow,
.tool-arrow {
  color: #5d8378;
  font-size: 30rpx;
  font-weight: 700;
  margin-left: 10rpx;
}

.tool-name {
  color: #3b4842;
  font-size: 27rpx;
  font-weight: 700;
}

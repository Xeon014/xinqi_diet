.profile-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.profile-hero {
  background: linear-gradient(145deg, rgba(30, 90, 79, 0.14) 0%, rgba(255, 253, 248, 0.96) 54%, rgba(255, 243, 232, 0.92) 100%);
  border: 1rpx solid rgba(30, 90, 79, 0.16);
  padding: 28rpx 26rpx;
}

.hero-top {
  display: flex;
}

.hero-main {
  flex: 1;
  min-width: 0;
}

.hero-title {
  color: #2f2a24;
  font-size: 38rpx;
  font-weight: 700;
}

.hero-subtitle {
  color: #74685c;
  font-size: 22rpx;
  margin-top: 6rpx;
}

.hero-metrics {
  display: grid;
  gap: 14rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 20rpx;
}

.hero-metric {
  border-radius: 22rpx;
  min-height: 122rpx;
  padding: 18rpx 18rpx 16rpx;
}

.hero-metric-bmi {
  background: linear-gradient(180deg, rgba(244, 248, 245, 0.96) 0%, rgba(235, 243, 238, 0.96) 100%);
}

.hero-metric-bmr {
  background: linear-gradient(180deg, rgba(255, 247, 239, 0.96) 0%, rgba(252, 234, 219, 0.96) 100%);
}

.metric-label {
  color: #74685c;
  font-size: 22rpx;
}

.metric-value {
  color: #2f2a24;
  font-size: 34rpx;
  font-weight: 700;
  margin-top: 10rpx;
}

.card-item {
  align-items: center;
  border: 1rpx solid rgba(70, 57, 47, 0.12);
  display: flex;
  justify-content: space-between;
  min-height: 112rpx;
  padding: 18rpx 22rpx;
}

.card-main {
  flex: 1;
  min-width: 0;
}

.card-title {
  color: #2f2a24;
  font-size: 30rpx;
  font-weight: 700;
}

.card-arrow {
  color: #1e5a4f;
  font-size: 30rpx;
  font-weight: 700;
  margin-left: 10rpx;
}

.tools-panel {
  border: 1rpx solid rgba(70, 57, 47, 0.12);
  padding: 6rpx 20rpx;
}

.tool-item {
  align-items: center;
  border-top: 1rpx solid rgba(70, 57, 47, 0.12);
  display: flex;
  justify-content: space-between;
  min-height: 96rpx;
  padding: 16rpx 4rpx;
}

.tool-item:first-child {
  border-top: 0;
}

.tool-main {
  flex: 1;
  min-width: 0;
}

.tool-name {
  color: #2f2a24;
  font-size: 27rpx;
  font-weight: 700;
}

.tool-arrow {
  color: #1e5a4f;
  font-size: 30rpx;
  font-weight: 700;
  margin-left: 10rpx;
}
.profile-page {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.profile-hero {
  background: linear-gradient(140deg, rgba(30, 90, 79, 0.14) 0%, rgba(255, 253, 248, 0.96) 56%);
  border: 1rpx solid rgba(30, 90, 79, 0.16);
  padding: 24rpx;
}

.hero-top {
  align-items: center;
  display: flex;
  gap: 12rpx;
}

.hero-avatar {
  align-items: center;
  background: rgba(30, 90, 79, 0.15);
  border-radius: 50%;
  color: #1e5a4f;
  display: flex;
  flex-shrink: 0;
  font-size: 30rpx;
  font-weight: 700;
  height: 76rpx;
  justify-content: center;
  width: 76rpx;
}

.hero-main {
  flex: 1;
  min-width: 0;
}

.hero-title {
  color: #2f2a24;
  font-size: 38rpx;
  font-weight: 700;
}

.hero-subtitle {
  color: #74685c;
  font-size: 22rpx;
  margin-top: 6rpx;
}

.hero-pill {
  background: rgba(255, 255, 255, 0.86);
  border-radius: 999rpx;
  color: #1e5a4f;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.2;
  max-width: 220rpx;
  padding: 8rpx 14rpx;
  text-align: center;
}

.hero-metrics {
  display: grid;
  gap: 10rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 14rpx;
}

.hero-metric {
  background: rgba(255, 255, 255, 0.78);
  border-radius: 14rpx;
  padding: 12rpx 14rpx;
}

.metric-label {
  color: #74685c;
  font-size: 20rpx;
}

.metric-value {
  color: #2f2a24;
  font-size: 27rpx;
  font-weight: 700;
  margin-top: 6rpx;
}

.card-item {
  align-items: center;
  border: 1rpx solid rgba(70, 57, 47, 0.12);
  display: flex;
  justify-content: space-between;
  min-height: 108rpx;
  padding: 22rpx 24rpx;
}

.card-main {
  flex: 1;
}

.card-title {
  color: #2f2a24;
  font-size: 30rpx;
  font-weight: 700;
}

.card-desc {
  color: #74685c;
  font-size: 22rpx;
  margin-top: 6rpx;
}

.card-arrow {
  color: #1e5a4f;
  font-size: 28rpx;
  font-weight: 700;
  margin-left: 12rpx;
}

.tools-panel {
  border: 1rpx solid rgba(70, 57, 47, 0.12);
  padding: 20rpx 24rpx;
}

.tools-title {
  color: #2f2a24;
  font-size: 29rpx;
  font-weight: 700;
}

.tool-item {
  align-items: center;
  border-top: 1rpx solid rgba(70, 57, 47, 0.12);
  display: flex;
  justify-content: space-between;
  min-height: 92rpx;
  padding: 12rpx 0;
}

.tool-item:first-child {
  margin-top: 8rpx;
}

.tool-main {
  flex: 1;
}

.tool-name {
  color: #2f2a24;
  font-size: 26rpx;
  font-weight: 700;
}

.tool-desc {
  color: #74685c;
  font-size: 21rpx;
  margin-top: 4rpx;
}

.tool-arrow {
  color: #1e5a4f;
  font-size: 27rpx;
  font-weight: 700;
  margin-left: 12rpx;
}
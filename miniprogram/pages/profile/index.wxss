.profile-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.profile-hero {
  background: radial-gradient(circle at top right, rgba(47, 139, 120, 0.22), transparent 42%), rgba(255, 253, 248, 0.92);
  padding: 32rpx 28rpx;
  position: relative;
}

.hero-kicker {
  color: #1f6f5f;
  font-size: 24rpx;
  font-weight: 600;
}

.hero-title {
  margin-top: 12rpx;
  color: #30241a;
  font-size: 50rpx;
  font-weight: 700;
}

.hero-date {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.84);
  color: #8f8373;
  font-size: 22rpx;
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.overview-card {
  padding: 24rpx;
}

.overview-card.tone-green {
  background: linear-gradient(180deg, #f4f8f2 0%, #edf6ea 100%);
}

.overview-card.tone-sand {
  background: linear-gradient(180deg, #fbf5ea 0%, #f8ecdb 100%);
}

.overview-card.tone-teal {
  background: linear-gradient(180deg, #edf8f5 0%, #e0f3ed 100%);
}

.overview-card.tone-orange {
  background: linear-gradient(180deg, #fff6ee 0%, #fee8d6 100%);
}

.overview-label {
  color: #6b5f51;
  font-size: 24rpx;
}

.overview-value {
  margin-top: 14rpx;
  color: #2f251c;
  font-size: 34rpx;
  font-weight: 700;
}

.entry-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.entry-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding: 28rpx;
}

.entry-main {
  flex: 1;
  min-width: 0;
}

.entry-title {
  color: #34281e;
  font-size: 32rpx;
  font-weight: 700;
}

.entry-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.entry-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(52, 40, 30, 0.06);
  color: #6c6154;
  font-size: 22rpx;
}

.entry-tag-accent {
  background: rgba(31, 111, 95, 0.1);
  color: #1f6f5f;
}

.entry-note {
  margin-top: 16rpx;
  color: #7b6f61;
  font-size: 24rpx;
  line-height: 1.6;
}

.entry-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #f7f3eb;
  color: #7f7365;
  font-size: 36rpx;
  flex-shrink: 0;
}
.profile-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.profile-panel {
  padding: 28rpx;
}

.metrics-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 24rpx;
}

.metric-card {
  border-radius: 24rpx;
  padding: 24rpx;
  background: linear-gradient(180deg, #f4f8f2 0%, #edf6ea 100%);
}

.metric-card.accent {
  background: linear-gradient(180deg, #fff7ec 0%, #ffeccc 100%);
}

.metric-label {
  color: #5f6f52;
  font-size: 24rpx;
}

.metric-value {
  margin-top: 14rpx;
  color: #1f2a1b;
  font-size: 40rpx;
  font-weight: 600;
}

.metric-unit {
  margin-top: 8rpx;
  color: #7c8a71;
  font-size: 22rpx;
}

.hint-text {
  margin-top: 20rpx;
  color: #6f7a67;
  font-size: 24rpx;
  line-height: 1.6;
}

.field-group {
  margin-top: 28rpx;
}

.two-column {
  display: flex;
  gap: 16rpx;
}

.field-half {
  flex: 1;
}

.field-picker {
  min-height: 88rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f7f8f3;
  color: #22301f;
  box-sizing: border-box;
}
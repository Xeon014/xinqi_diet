<view class="page-shell profile-page" wx:if="{{profile}}">
  <view class="panel profile-hero">
    <view class="hero-copy">
      <view class="hero-title">{{heroTitle}}</view>
      <view class="hero-subtitle">{{heroSubtitle}}</view>
    </view>

    <view class="hero-metrics">
      <view class="hero-metric hero-metric-bmi">
        <view class="metric-label">BMI</view>
        <view class="metric-value">{{bmiLabel}}</view>
      </view>
      <view class="hero-metric hero-metric-bmr">
        <view class="metric-label">基础代谢</view>
        <view class="metric-value">{{bmrLabel}}</view>
      </view>
    </view>
  </view>

  <view class="panel info-group">
    <view class="card-item first" bindtap="handleOpenPersonalInfo">
      <view class="card-main">
        <view class="card-title">个人资料</view>
      </view>
      <view class="card-arrow">></view>
    </view>

    <view class="card-item" bindtap="handleOpenHealthProfile">
      <view class="card-main">
        <view class="card-title">健康档案</view>
      </view>
      <view class="card-arrow">></view>
    </view>
  </view>

  <view class="panel tools-panel">
    <view
      wx:for="{{toolEntries}}"
      wx:key="key"
      class="tool-item"
      data-key="{{item.key}}"
      bindtap="handleOpenTool"
    >
      <view class="tool-main">
        <view class="tool-name">{{item.title}}</view>
      </view>
      <view class="tool-arrow">></view>
    </view>
  </view>
</view>

<view wx:else class="page-shell profile-page">
  <empty-state title="暂无用户资料" description="请先完成资料初始化。" />
</view>

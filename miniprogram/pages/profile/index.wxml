<view class="page-shell profile-page" wx:if="{{profile && summary}}">
  <view class="profile-hero panel">
    <view class="hero-kicker">我的</view>
    <view class="hero-title">{{profile.name}}</view>
    <view class="hero-date">{{today}}</view>
  </view>

  <view class="overview-grid">
    <view wx:for="{{overviewCards}}" wx:key="label" class="overview-card panel {{'tone-' + item.tone}}">
      <view class="overview-label">{{item.label}}</view>
      <view class="overview-value">{{item.value}}</view>
    </view>
  </view>

  <view class="entry-list">
    <view class="entry-card panel" bindtap="handleOpenPersonalInfo">
      <view class="entry-main">
        <view class="entry-title">个人信息</view>
        <view class="entry-tags">
          <view wx:for="{{personalTags}}" wx:key="*this" class="entry-tag">{{item}}</view>
        </view>
        <view class="entry-note">{{personalNote}}</view>
      </view>
      <view class="entry-icon">></view>
    </view>

    <view class="entry-card panel" bindtap="handleOpenHealthProfile">
      <view class="entry-main">
        <view class="entry-title">健康档案</view>
        <view class="entry-tags">
          <view wx:for="{{healthTags}}" wx:key="*this" class="entry-tag entry-tag-accent">{{item}}</view>
        </view>
        <view class="entry-note">{{healthNote}}</view>
      </view>
      <view class="entry-icon">></view>
    </view>
  </view>

  <view class="panel tools-panel">
    <view class="section-title">长期参数与工具</view>
    <view wx:for="{{toolEntries}}" wx:key="key" class="tool-item" data-key="{{item.key}}" bindtap="handleOpenTool">
      <view class="tool-main">
        <view class="tool-title">{{item.title}}</view>
        <view class="tool-desc">{{item.desc}}</view>
      </view>
      <view class="tool-arrow">></view>
    </view>
  </view>
</view>

<empty-state wx:else title="暂无用户资料" description="请先完成资料初始化。" />

<view class="page-shell weight-import-page">

  <!-- Step 1: Select File -->
  <view wx:if="{{step === 'select'}}" class="panel select-panel">
    <view class="select-title">导入体重数据</view>
    <view class="select-desc">
      支持主流健康应用导出的 CSV / XLSX 文件数据。
    </view>
    <view class="select-tips">
      <view class="tip-item">支持自动识别列名、分隔符和日期格式</view>
      <view class="tip-item">自动检测体重单位并转换</view>
      <view class="tip-item">预览确认后才写入</view>
    </view>
    <view class="select-btn" bindtap="handleChooseFile">
      <view class="select-btn-text">选择文件</view>
    </view>
  </view>

  <!-- Parsing Loading -->
  <view wx:if="{{step === 'select' && parsing}}" class="panel select-panel">
    <view class="select-title">正在解析文件...</view>
  </view>

  <!-- Step 2: Preview -->
  <view wx:if="{{step === 'preview'}}" class="preview-section">
    <view class="panel preview-stats">
      <view class="stats-file">{{preview.fileName}}</view>
      <view class="stats-row">
        <view class="stat-item">
          <view class="stat-value">{{preview.totalRows}}</view>
          <view class="stat-label">总行数</view>
        </view>
        <view class="stat-item stat-ok">
          <view class="stat-value">{{preview.parsedRows}}</view>
          <view class="stat-label">可导入</view>
        </view>
        <view class="stat-item stat-warn">
          <view class="stat-value">{{preview.skippedRows}}</view>
          <view class="stat-label">跳过</view>
        </view>
      </view>
      <view wx:if="{{preview.detectedUnit && preview.detectedUnit !== 'kg'}}" class="stats-info">
        检测到单位：{{preview.detectedUnit}}（已自动转换为 kg）
      </view>
      <view wx:if="{{preview.detectedFileType}}" class="stats-info">
        文件类型：{{preview.detectedFileType}}
        <text wx:if="{{preview.detectedSheetName}}"> · 工作表：{{preview.detectedSheetName}}</text>
      </view>
      <view wx:if="{{preview.detectedDelimiter}}" class="stats-info">
        分隔符：{{preview.detectedDelimiter}} · 日期格式：{{preview.detectedDateFormat || '自动检测'}}
      </view>
      <view class="stats-info stats-summary">
        已选 {{selectedCount}} 条 · 可导入 {{selectableCount}} 条 · 异常 {{errorCount}} 条
      </view>
    </view>

    <view class="panel policy-panel">
      <view class="policy-title">重复记录处理</view>
      <view class="policy-options">
        <view
          class="policy-option {{duplicatePolicy === 'SKIP' ? 'active' : ''}}"
          data-policy="SKIP"
          bindtap="handlePolicyChange"
        >
          跳过已有记录
        </view>
        <view
          class="policy-option {{duplicatePolicy === 'OVERWRITE' ? 'active' : ''}}"
          data-policy="OVERWRITE"
          bindtap="handlePolicyChange"
        >
          覆盖已有记录
        </view>
      </view>
    </view>

    <view class="top-action-bar">
      <view class="floating-action-row">
        <view class="floating-action ghost" bindtap="handleSelectAllValid">全选可导入</view>
        <view class="floating-action ghost" bindtap="handleClearAll">全不选</view>
        <view
          class="floating-action ghost {{showOnlyErrors ? 'active' : ''}}"
          bindtap="handleToggleErrorFilter"
        >
          {{showOnlyErrors ? '查看全部' : '仅看异常'}}
        </view>
      </view>
      <view
        class="floating-confirm {{selectedCount === 0 ? 'disabled' : ''}}"
        bindtap="handleConfirmImport"
      >
        确认导入
      </view>
    </view>

    <view class="panel preview-list">
      <view class="list-header">
        <view class="list-title">数据预览</view>
      </view>
      <view class="preview-row-header">
        <view class="col-check"></view>
        <view class="col-date">日期时间</view>
        <view class="col-weight">体重(kg)</view>
        <view class="col-status">状态</view>
      </view>
      <view
        wx:for="{{displayRows}}"
        wx:key="originalIndex"
        class="preview-row {{item.error ? 'row-error' : (checkedRows[item.originalIndex] ? 'row-checked' : 'row-unchecked')}}"
      >
        <view class="col-check" data-original-index="{{item.originalIndex}}" bindtap="handleRowCheck">
          <view class="check-box {{checkedRows[item.originalIndex] && !item.error ? 'checked' : ''}} {{item.error ? 'disabled' : ''}}">
            ✓
          </view>
        </view>
        <view class="col-date">{{item.displayMeasuredAt}}</view>
        <view class="col-weight">{{item.parsedWeightKg != null ? item.parsedWeightKg : '-'}}</view>
        <view class="col-status">
          <text wx:if="{{item.error}}" class="status-error">{{item.error}}</text>
          <text wx:elif="{{checkedRows[item.originalIndex]}}" class="status-ok">可导入</text>
          <text wx:else class="status-skip">已排除</text>
        </view>
      </view>
      <view wx:if="{{displayRows.length === 0}}" class="preview-empty">
        当前没有异常数据
      </view>
    </view>

    <view class="action-bar action-bar-single">
      <view class="action-btn secondary" bindtap="handleImportAnother">返回</view>
    </view>
  </view>

  <!-- Step 3: Result -->
  <view wx:if="{{step === 'result'}}" class="panel result-panel">
    <view class="result-title">导入完成</view>
    <view class="result-stats">
      <view class="result-item result-imported">
        <view class="result-value">{{result.imported}}</view>
        <view class="result-label">成功导入</view>
      </view>
      <view class="result-item result-skipped">
        <view class="result-value">{{result.skipped}}</view>
        <view class="result-label">跳过</view>
      </view>
      <view class="result-item result-overwritten">
        <view class="result-value">{{result.overwritten}}</view>
        <view class="result-label">覆盖</view>
      </view>
    </view>
    <view class="result-actions">
      <view class="action-btn primary" bindtap="handleViewHistory">查看历史记录</view>
      <view class="action-btn secondary" bindtap="handleImportAnother">继续导入</view>
    </view>
  </view>

</view>

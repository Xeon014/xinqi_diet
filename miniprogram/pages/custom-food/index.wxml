<view class="page-shell custom-food-page">
  <view class="panel custom-panel">
    <view class="section-title">自定义食物</view>
    <view class="section-subtitle">补充食物后会直接回到本次记录</view>

    <view class="field-group">
      <view class="field-label">食物名称</view>
      <input class="field-input" value="{{form.name}}" data-field="name" bindinput="handleInput" />
    </view>

    <view class="field-group">
      <view class="field-label">分类</view>
      <view class="category-grid">
        <view wx:for="{{categories}}" wx:key="key" class="category-chip {{selectedCategoryKey === item.key ? 'active' : ''}}" data-key="{{item.key}}" bindtap="handleCategoryTap">
          {{item.label}}
        </view>
      </view>
    </view>

    <view class="field-group two-column">
      <view class="field-half">
        <view class="field-label">热量(kcal/100g)</view>
        <input class="field-input" type="digit" value="{{form.caloriesPer100g}}" data-field="caloriesPer100g" bindinput="handleInput" />
      </view>
      <view class="field-half">
        <view class="field-label">蛋白质(g)</view>
        <input class="field-input" type="digit" value="{{form.proteinPer100g}}" data-field="proteinPer100g" bindinput="handleInput" />
      </view>
    </view>

    <view class="field-group two-column">
      <view class="field-half">
        <view class="field-label">碳水(g)</view>
        <input class="field-input" type="digit" value="{{form.carbsPer100g}}" data-field="carbsPer100g" bindinput="handleInput" />
      </view>
      <view class="field-half">
        <view class="field-label">脂肪(g)</view>
        <input class="field-input" type="digit" value="{{form.fatPer100g}}" data-field="fatPer100g" bindinput="handleInput" />
      </view>
    </view>
  </view>

  <view class="primary-button" bindtap="handleSubmit">保存并使用</view>
</view>
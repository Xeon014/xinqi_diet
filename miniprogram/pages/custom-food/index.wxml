<view class="page-shell custom-food-page">
  <view class="panel manage-head">
    <input class="search-input" placeholder="搜索自定义食物" value="{{keyword}}" bindinput="handleKeywordInput" />
    <view class="action-btn" bindtap="handleStartCreate">新建</view>
  </view>

  <view wx:if="{{displayedFoods.length}}" class="panel list-panel" bindtap="handleListBackgroundTap">
    <view class="list-head">
      <view class="list-count">共 {{displayedFoods.length}} 项</view>
    </view>
    <view
      wx:for="{{displayedFoods}}"
      wx:key="id"
      class="swipe-cell"
      data-id="{{item.id}}"
      bindtouchstart="handleFoodTouchStart"
      bindtouchmove="handleFoodTouchMove"
      bindtouchend="handleFoodTouchEnd"
      bindtouchcancel="handleFoodTouchEnd"
    >
      <view class="swipe-action-track">
        <view class="swipe-action-shell">
          <view class="danger-icon-btn swipe-delete-btn" data-id="{{item.id}}" catchtap="handleDelete">
            <view class="trash-icon">
              <view class="trash-icon-handle"></view>
              <view class="trash-icon-lid"></view>
              <view class="trash-icon-body">
                <view class="trash-icon-line left"></view>
                <view class="trash-icon-line center"></view>
                <view class="trash-icon-line right"></view>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view class="swipe-content" style="{{item.swipeContentStyle}}" catchtap="handleSwipeContentTap">
        <view class="item-row">
          <view class="item-main">
            <view class="item-name">{{item.name}}</view>
            <view class="item-meta">{{item.categoryLabel}} · {{item.displayCaloriesPer100}} {{item.calorieUnitLabel}} / 100{{item.quantityUnitLabel}}</view>
          </view>
          <view class="item-actions">
            <view class="mini-action" data-id="{{item.id}}" bindtap="handleEdit">编辑</view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <empty-state wx:else title="暂无自定义食物" description="先添加一个自定义食物" />

  <view wx:if="{{sheetVisible}}" class="sheet-overlay" bindtap="handleCancelEdit"></view>
  <view wx:if="{{sheetVisible}}" class="bottom-sheet panel" style="{{sheetStyle}}" catchtap="noop" catchtouchmove="noop">
    <view class="sheet-head">
      <view class="sheet-title">{{editMode === 'edit' ? '编辑自定义食物' : '新建自定义食物'}}</view>
      <view class="sheet-actions">
        <view wx:if="{{editMode === 'edit'}}" class="danger-icon-btn" data-id="{{editForm.id}}" bindtap="handleDelete">
          <view class="trash-icon">
            <view class="trash-icon-handle"></view>
            <view class="trash-icon-lid"></view>
            <view class="trash-icon-body">
              <view class="trash-icon-line left"></view>
              <view class="trash-icon-line center"></view>
              <view class="trash-icon-line right"></view>
            </view>
          </view>
        </view>
        <view class="sheet-close" bindtap="handleCancelEdit">✕</view>
      </view>
    </view>

    <view class="field-group">
      <view class="field-label">食物名称</view>
      <view wx:if="{{recognitionImagePath}}" class="recognition-card">
        <image class="recognition-image" src="{{recognitionImagePath}}" mode="aspectFill" />
        <view class="recognition-body">
          <view class="recognition-head">
            <view class="recognition-title">识别结果</view>
            <view wx:if="{{recognitionConfidenceLabel}}" class="recognition-badge {{recognitionConfidenceClass}}">
              {{recognitionConfidenceLabel}}
            </view>
          </view>
          <view wx:if="{{recognitionSummary}}" class="recognition-summary">{{recognitionSummary}}</view>
          <view wx:for="{{recognitionWarnings}}" wx:key="*this" class="recognition-warning">{{item}}</view>
          <view wx:if="{{recognitionRawTextLines.length}}" class="recognition-raw">
            <view class="recognition-raw-title">识别原文</view>
            <view wx:for="{{recognitionRawTextLines}}" wx:key="index" class="recognition-raw-line">{{item}}</view>
            <view wx:if="{{recognitionRawTextOverflow}}" class="recognition-raw-more">仅显示前 6 行</view>
          </view>
        </view>
      </view>
      <input
        class="field-input"
        value="{{editForm.name}}"
        placeholder="请输入食物名称"
        data-field="name"
        bindinput="handleInput"
        adjust-position="{{true}}"
        cursor-spacing="20"
        confirm-type="next"
      />
    </view>

    <view class="field-group">
      <view class="field-label">分类</view>
      <view class="category-grid">
        <view
          wx:for="{{categories}}"
          wx:key="key"
          class="category-chip {{selectedCategoryKey === item.key ? 'active' : ''}}"
          data-key="{{item.key}}"
          bindtap="handleCategoryTap"
        >
          {{item.label}}
        </view>
      </view>
    </view>

    <view class="input-mode-tabs">
      <view
        wx:for="{{nutritionInputModes}}"
        wx:key="key"
        class="input-mode-tab {{nutritionInputMode === item.key ? 'active' : ''}}"
        data-mode="{{item.key}}"
        bindtap="handleNutritionInputModeTap"
      >
        {{item.label}}
      </view>
    </view>

    <view wx:if="{{nutritionInputMode === 'PER_100'}}" class="field-group nutrition-layout">
      <view class="nutrition-column">
        <view class="compact-field">
          <view class="field-label">热量</view>
          <view class="value-input-row">
            <input
              class="field-input"
              type="digit"
              value="{{editForm.caloriesPer100g}}"
              placeholder="0"
              data-field="caloriesPer100g"
              bindinput="handleInput"
              adjust-position="{{true}}"
              cursor-spacing="20"
              confirm-type="next"
            />
            <view class="input-unit calorie-unit">{{editForm.calorieUnit === 'KJ' ? 'kJ' : 'kcal'}}/100{{editForm.quantityUnit === 'ML' ? 'ml' : 'g'}}</view>
          </view>
        </view>

        <view class="compact-field">
          <view class="field-label">热量单位</view>
          <view class="category-grid compact-grid">
            <view
              wx:for="{{calorieUnits}}"
              wx:key="key"
              class="category-chip {{editForm.calorieUnit === item.key ? 'active' : ''}}"
              data-key="{{item.key}}"
              bindtap="handleCalorieUnitTap"
            >
              {{item.label}}
            </view>
          </view>
        </view>

        <view class="compact-field">
          <view class="field-label">计量单位</view>
          <view class="category-grid compact-grid">
            <view
              wx:for="{{quantityUnits}}"
              wx:key="key"
              class="category-chip {{editForm.quantityUnit === item.key ? 'active' : ''}}"
              data-key="{{item.key}}"
              bindtap="handleQuantityUnitTap"
            >
              {{item.label}}
            </view>
          </view>
        </view>
      </view>

      <view class="nutrition-column">
        <view class="nutrition-input-item">
          <view class="nutrition-input-label">碳水</view>
          <view class="value-input-row">
            <input
              class="nutrition-input"
              type="digit"
              value="{{editForm.carbsPer100g}}"
              placeholder="0"
              data-field="carbsPer100g"
              bindinput="handleInput"
              adjust-position="{{true}}"
              cursor-spacing="24"
              confirm-type="next"
            />
            <view class="input-unit">g</view>
          </view>
        </view>
        <view class="nutrition-input-item">
          <view class="nutrition-input-label">蛋白质</view>
          <view class="value-input-row">
            <input
              class="nutrition-input"
              type="digit"
              value="{{editForm.proteinPer100g}}"
              placeholder="0"
              data-field="proteinPer100g"
              bindinput="handleInput"
              adjust-position="{{true}}"
              cursor-spacing="24"
              confirm-type="next"
            />
            <view class="input-unit">g</view>
          </view>
        </view>
        <view class="nutrition-input-item">
          <view class="nutrition-input-label">脂肪</view>
          <view class="value-input-row">
            <input
              class="nutrition-input"
              type="digit"
              value="{{editForm.fatPer100g}}"
              placeholder="0"
              data-field="fatPer100g"
              bindinput="handleInput"
              adjust-position="{{true}}"
              cursor-spacing="24"
              confirm-type="done"
            />
            <view class="input-unit">g</view>
          </view>
        </view>
      </view>
    </view>

    <view wx:else class="field-group package-nutrition-block">
      <view class="package-size-row compact-field">
        <view class="field-label">包装量</view>
        <view class="value-input-row">
          <input class="field-input" type="digit" value="{{packageForm.servingSize}}" placeholder="0" data-field="servingSize" bindinput="handlePackageInput" adjust-position="{{true}}" cursor-spacing="20" confirm-type="next" />
          <view class="input-unit">{{editForm.quantityUnit === 'ML' ? 'ml' : 'g'}}</view>
        </view>
      </view>

      <view class="nutrition-layout package-nutrition-layout">
        <view class="nutrition-column">
          <view class="compact-field">
            <view class="field-label">热量</view>
            <view class="value-input-row">
              <input class="field-input" type="digit" value="{{packageForm.calories}}" placeholder="0" data-field="calories" bindinput="handlePackageInput" adjust-position="{{true}}" cursor-spacing="20" confirm-type="next" />
              <view class="input-unit">{{editForm.calorieUnit === 'KJ' ? 'kJ' : 'kcal'}}</view>
            </view>
          </view>
          <view class="compact-field">
            <view class="field-label">计量单位</view>
            <view class="category-grid compact-grid">
              <view
                wx:for="{{quantityUnits}}"
                wx:key="key"
                class="category-chip {{editForm.quantityUnit === item.key ? 'active' : ''}}"
                data-key="{{item.key}}"
                bindtap="handleQuantityUnitTap"
              >
                {{item.label}}
              </view>
            </view>
          </view>
          <view class="compact-field">
            <view class="field-label">热量单位</view>
            <view class="category-grid compact-grid">
              <view
                wx:for="{{calorieUnits}}"
                wx:key="key"
                class="category-chip {{editForm.calorieUnit === item.key ? 'active' : ''}}"
                data-key="{{item.key}}"
                bindtap="handleCalorieUnitTap"
              >
                {{item.label}}
              </view>
            </view>
          </view>
        </view>

        <view class="nutrition-column">
          <view class="nutrition-input-item">
            <view class="nutrition-input-label">碳水</view>
            <view class="value-input-row">
              <input class="nutrition-input" type="digit" value="{{packageForm.carbs}}" placeholder="0" data-field="carbs" bindinput="handlePackageInput" adjust-position="{{true}}" cursor-spacing="24" confirm-type="next" />
              <view class="input-unit">g</view>
            </view>
          </view>
          <view class="nutrition-input-item">
            <view class="nutrition-input-label">蛋白质</view>
            <view class="value-input-row">
              <input class="nutrition-input" type="digit" value="{{packageForm.protein}}" placeholder="0" data-field="protein" bindinput="handlePackageInput" adjust-position="{{true}}" cursor-spacing="24" confirm-type="next" />
              <view class="input-unit">g</view>
            </view>
          </view>
          <view class="nutrition-input-item">
            <view class="nutrition-input-label">脂肪</view>
            <view class="value-input-row">
              <input class="nutrition-input" type="digit" value="{{packageForm.fat}}" placeholder="0" data-field="fat" bindinput="handlePackageInput" adjust-position="{{true}}" cursor-spacing="24" confirm-type="done" />
              <view class="input-unit">g</view>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view class="editor-actions">
      <view class="ghost-button" bindtap="handleCancelEdit">取消</view>
      <view class="primary-button {{saving ? 'disabled' : ''}}" bindtap="handleSubmit">{{editMode === 'edit' ? '保存' : '创建'}}</view>
    </view>
  </view>
</view>

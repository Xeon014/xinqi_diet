.custom-food-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.manage-head,
.list-panel {
  padding: 24rpx;
}

.manage-head,
.list-head,
.item-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.manage-head {
  gap: 16rpx;
}

.search-input {
  background: rgba(252, 250, 245, 0.96);
  border: 2rpx solid rgba(107, 144, 132, 0.12);
  border-radius: 999rpx;
  box-sizing: border-box;
  flex: 1;
  font-size: 28rpx;
  height: 82rpx;
  min-width: 0;
  padding: 0 24rpx;
}

.action-btn,
.mini-action {
  align-items: center;
  background: rgba(107, 144, 132, 0.12);
  border-radius: 999rpx;
  color: #5d8378;
  display: flex;
  font-size: 22rpx;
  font-weight: 700;
  justify-content: center;
}

.action-btn {
  min-width: 104rpx;
  padding: 16rpx 22rpx;
}

.mini-action {
  min-width: 88rpx;
  padding: 12rpx 18rpx;
}

.action-btn.danger,
.mini-action.danger {
  background: rgba(187, 134, 108, 0.14);
  color: #bb866c;
}

.action-btn.disabled,
.mini-action.disabled {
  opacity: 0.6;
}

.field-group {
  margin-top: 18rpx;
}

.recognition-card {
  align-items: flex-start;
  background: linear-gradient(180deg, rgba(249, 247, 240, 0.98) 0%, rgba(244, 239, 229, 0.98) 100%);
  border: 1rpx solid rgba(107, 144, 132, 0.12);
  border-radius: 24rpx;
  display: flex;
  gap: 18rpx;
  margin-top: 16rpx;
  padding: 18rpx;
}

.recognition-image {
  border-radius: 18rpx;
  flex: 0 0 132rpx;
  height: 132rpx;
  width: 132rpx;
}

.recognition-body {
  flex: 1;
  min-width: 0;
}

.recognition-head {
  align-items: center;
  display: flex;
  gap: 12rpx;
  justify-content: space-between;
}

.recognition-title {
  color: #37423d;
  font-size: 24rpx;
  font-weight: 700;
}

.recognition-badge {
  background: rgba(107, 144, 132, 0.14);
  border-radius: 999rpx;
  color: #5d8378;
  font-size: 20rpx;
  font-weight: 700;
  padding: 8rpx 16rpx;
  white-space: nowrap;
}

.recognition-badge.medium {
  background: rgba(190, 153, 91, 0.14);
  color: #a5751d;
}

.recognition-badge.low {
  background: rgba(187, 134, 108, 0.16);
  color: #bb866c;
}

.recognition-summary,
.recognition-warning,
.recognition-raw-line,
.recognition-raw-more {
  color: #6a6f69;
  font-size: 22rpx;
  line-height: 1.5;
}

.recognition-summary,
.recognition-warning,
.recognition-raw {
  margin-top: 10rpx;
}

.recognition-warning {
  color: #9b704f;
}

.recognition-raw {
  border-top: 1rpx solid rgba(107, 144, 132, 0.08);
  padding-top: 10rpx;
}

.recognition-raw-title {
  color: #6d7f78;
  font-size: 22rpx;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.recognition-raw-more {
  color: #7d7c74;
}

.sheet-overlay {
  background: rgba(54, 66, 61, 0.22);
  bottom: 0;
  left: 0;
  position: fixed;
  right: 0;
  top: 0;
  z-index: 40;
}

.bottom-sheet {
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  bottom: 0;
  left: 0;
  max-height: 78vh;
  overflow-y: auto;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  position: fixed;
  right: 0;
  transition: bottom 160ms ease;
  z-index: 50;
}

.bottom-sheet .field-label {
  font-size: 24rpx;
  margin-bottom: 8rpx;
  white-space: nowrap;
}

.bottom-sheet .field-input {
  border-radius: 18rpx;
  font-size: 28rpx;
  height: 60rpx;
  padding: 0 14rpx;
}

.sheet-head,
.sheet-actions {
  align-items: center;
  display: flex;
}

.sheet-head {
  justify-content: space-between;
}

.sheet-title {
  color: #37423d;
  font-size: 30rpx;
  font-weight: 800;
}

.sheet-actions {
  gap: 12rpx;
}

.sheet-actions .danger-icon-btn {
  background: #d59889;
  box-shadow: 0 8rpx 14rpx rgba(213, 152, 137, 0.18);
}

.sheet-close {
  align-items: center;
  background: rgba(107, 144, 132, 0.1);
  border-radius: 999rpx;
  color: #6d7f78;
  display: flex;
  font-size: 26rpx;
  font-weight: 700;
  height: 56rpx;
  justify-content: center;
  line-height: 1;
  width: 56rpx;
}

.nutrition-layout {
  background: rgba(252, 249, 244, 0.72);
  border: 1rpx solid rgba(107, 144, 132, 0.1);
  border-radius: 20rpx;
  display: grid;
  column-gap: 20rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  row-gap: 14rpx;
  padding: 14rpx;
}

.nutrition-column {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 0;
}

.compact-field,
.nutrition-input-item {
  align-items: center;
  display: flex;
  gap: 10rpx;
  min-height: 60rpx;
  min-width: 0;
}

.compact-field {
  gap: 14rpx;
}

.compact-field .field-label {
  flex: 0 0 104rpx;
  margin-bottom: 0;
}

.compact-field:first-child .field-label {
  flex-basis: 68rpx;
}

.nutrition-input-label {
  color: #73756d;
  flex: 0 0 76rpx;
  font-size: 23rpx;
  font-weight: 600;
  white-space: nowrap;
}

.nutrition-input {
  background: rgba(254, 252, 248, 0.98);
  border: 2rpx solid rgba(107, 144, 132, 0.12);
  border-radius: 16rpx;
  color: #37423d;
  font-size: 28rpx;
  height: 60rpx;
  min-width: 0;
  padding: 0 12rpx;
  flex: 0 0 116rpx;
  width: 116rpx;
}

.value-input-row .field-input {
  flex: 0 0 116rpx;
  width: 116rpx;
}

.value-input-row {
  align-items: center;
  display: flex;
  flex: 1;
  gap: 10rpx;
  min-width: 0;
}

.input-unit {
  color: #7d7c74;
  flex: 0 0 36rpx;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
  white-space: nowrap;
}

.input-unit.calorie-unit {
  flex-basis: 96rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.compact-grid {
  align-items: center;
  flex: 1;
  gap: 8rpx;
  min-height: 60rpx;
  min-width: 0;
}

.category-chip {
  background: rgba(107, 144, 132, 0.08);
  border-radius: 20rpx;
  color: #6e796f;
  font-size: 22rpx;
  font-weight: 600;
  padding: 12rpx 18rpx;
  white-space: nowrap;
}

.compact-grid .category-chip {
  border-radius: 16rpx;
  font-size: 22rpx;
  min-width: 0;
  padding: 10rpx 14rpx;
}

.category-chip.active {
  background: rgba(107, 144, 132, 0.16);
  color: #5d8378;
  font-weight: 700;
}

.editor-actions {
  background: linear-gradient(180deg, rgba(248, 245, 238, 0) 0%, rgba(248, 245, 238, 0.96) 28%, rgba(248, 245, 238, 1) 100%);
  display: grid;
  gap: 12rpx;
  grid-template-columns: 1fr 1fr;
  margin-top: 22rpx;
  padding-top: 10rpx;
  position: sticky;
  bottom: 0;
}

.primary-button.disabled {
  opacity: 0.6;
}

.list-count {
  color: #7d7c74;
  font-size: 22rpx;
}

.item-row {
  min-height: 106rpx;
  padding: 18rpx 20rpx;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-name {
  color: #37423d;
  font-size: 30rpx;
  font-weight: 700;
}

.item-meta {
  color: #7d7c74;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.item-actions {
  display: flex;
  gap: 10rpx;
  margin-left: 16rpx;
}

.list-panel {
  overflow: hidden;
}

.swipe-cell {
  border-radius: 24rpx;
  box-shadow: 0 10rpx 20rpx rgba(68, 78, 73, 0.05);
  margin-top: 12rpx;
  overflow: hidden;
  position: relative;
}

.swipe-cell:first-of-type {
  margin-top: 16rpx;
}

.swipe-action-track {
  align-items: center;
  display: flex;
  inset: 0;
  justify-content: flex-end;
  position: absolute;
}

.swipe-action-shell {
  align-items: center;
  border-radius: 24rpx;
  display: flex;
  height: 100%;
  justify-content: center;
  width: 84px;
}

.swipe-content {
  background: linear-gradient(180deg, #fdfcf8 0%, #f8f5ee 100%);
  border: 1rpx solid rgba(91, 126, 115, 0.11);
  border-radius: 24rpx;
  position: relative;
  z-index: 1;
}

.swipe-delete-btn {
  height: 64rpx;
  width: 64rpx;
}

.custom-food-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.custom-panel {
  border-left: 8rpx solid rgba(30, 90, 79, 0.68);
  padding: 28rpx;
}

.field-group {
  margin-top: 28rpx;
}

.two-column {
  display: flex;
  gap: 16rpx;
}

.field-half {
  flex: 1;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.category-chip {
  background: rgba(70, 57, 47, 0.08);
  border-radius: 20rpx;
  color: #64584c;
  font-size: 24rpx;
  font-weight: 600;
  padding: 16rpx 20rpx;
}

.category-chip.active {
  background: rgba(30, 90, 79, 0.14);
  color: #1e5a4f;
  font-weight: 700;
}

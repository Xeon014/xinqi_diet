.custom-food-page {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.manage-head,
.list-panel {
  padding: 24rpx;
}

.manage-head,
.list-head,
.item-row {
  align-items: center;
  display: flex;
  justify-content: space-between;
}

.manage-head {
  gap: 16rpx;
}

.search-input {
  background: rgba(252, 250, 245, 0.96);
  border: 2rpx solid rgba(107, 144, 132, 0.12);
  border-radius: 999rpx;
  box-sizing: border-box;
  flex: 1;
  font-size: 28rpx;
  height: 82rpx;
  min-width: 0;
  padding: 0 24rpx;
}

.action-btn,
.mini-action {
  align-items: center;
  background: rgba(107, 144, 132, 0.12);
  border-radius: 999rpx;
  color: #5d8378;
  display: flex;
  font-size: 22rpx;
  font-weight: 700;
  justify-content: center;
}

.action-btn {
  min-width: 104rpx;
  padding: 16rpx 22rpx;
}

.mini-action {
  min-width: 88rpx;
  padding: 12rpx 18rpx;
}

.action-btn.danger,
.mini-action.danger {
  background: rgba(187, 134, 108, 0.14);
  color: #bb866c;
}

.field-group {
  margin-top: 24rpx;
}

.sheet-overlay {
  background: rgba(54, 66, 61, 0.22);
  bottom: 0;
  left: 0;
  position: fixed;
  right: 0;
  top: 0;
  z-index: 40;
}

.bottom-sheet {
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  bottom: 0;
  left: 0;
  max-height: 78vh;
  overflow-y: auto;
  padding: 28rpx 26rpx calc(26rpx + env(safe-area-inset-bottom));
  position: fixed;
  right: 0;
  z-index: 50;
}

.sheet-head,
.sheet-actions {
  align-items: center;
  display: flex;
}

.sheet-head {
  justify-content: space-between;
}

.sheet-title {
  color: #37423d;
  font-size: 30rpx;
  font-weight: 800;
}

.sheet-actions {
  gap: 12rpx;
}

.sheet-actions .danger-icon-btn {
  background: #d59889;
  box-shadow: 0 8rpx 14rpx rgba(213, 152, 137, 0.18);
}

.sheet-close {
  align-items: center;
  background: rgba(107, 144, 132, 0.1);
  border-radius: 999rpx;
  color: #6d7f78;
  display: flex;
  font-size: 26rpx;
  font-weight: 700;
  height: 56rpx;
  justify-content: center;
  line-height: 1;
  width: 56rpx;
}

.two-column {
  display: flex;
  gap: 16rpx;
}

.field-half {
  flex: 1;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.category-chip {
  background: rgba(107, 144, 132, 0.08);
  border-radius: 20rpx;
  color: #6e796f;
  font-size: 24rpx;
  font-weight: 600;
  padding: 16rpx 20rpx;
}

.category-chip.active {
  background: rgba(107, 144, 132, 0.16);
  color: #5d8378;
  font-weight: 700;
}

.editor-actions {
  display: grid;
  gap: 12rpx;
  grid-template-columns: 1fr 1fr;
  margin-top: 28rpx;
}

.primary-button.disabled {
  opacity: 0.6;
}

.list-count {
  color: #7d7c74;
  font-size: 22rpx;
}

.item-row {
  min-height: 106rpx;
  padding: 18rpx 20rpx;
}

.item-main {
  flex: 1;
  min-width: 0;
}

.item-name {
  color: #37423d;
  font-size: 30rpx;
  font-weight: 700;
}

.item-meta {
  color: #7d7c74;
  font-size: 22rpx;
  margin-top: 8rpx;
}

.item-actions {
  display: flex;
  gap: 10rpx;
  margin-left: 16rpx;
}

.list-panel {
  overflow: hidden;
}

.swipe-cell {
  border-radius: 24rpx;
  box-shadow: 0 10rpx 20rpx rgba(68, 78, 73, 0.05);
  margin-top: 12rpx;
  overflow: hidden;
  position: relative;
}

.swipe-cell:first-of-type {
  margin-top: 16rpx;
}

.swipe-action-track {
  align-items: center;
  display: flex;
  inset: 0;
  justify-content: flex-end;
  position: absolute;
}

.swipe-action-shell {
  align-items: center;
  border-radius: 24rpx;
  display: flex;
  height: 100%;
  justify-content: center;
  width: 84px;
}

.swipe-content {
  background: linear-gradient(180deg, #fdfcf8 0%, #f8f5ee 100%);
  border: 1rpx solid rgba(91, 126, 115, 0.11);
  border-radius: 24rpx;
  position: relative;
  z-index: 1;
}

.swipe-delete-btn {
  height: 64rpx;
  width: 64rpx;
}

.personal-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.personal-panel {
  border-right: 8rpx solid rgba(30, 90, 79, 0.64);
  padding: 28rpx;
}

.age-chip {
  background: rgba(30, 90, 79, 0.12);
  border-radius: 999rpx;
  color: #1e5a4f;
  display: inline-flex;
  font-size: 22rpx;
  font-weight: 700;
  margin-top: 22rpx;
  padding: 10rpx 20rpx;
}

.field-group {
  margin-top: 28rpx;
}

.field-picker {
  align-items: center;
  background: #fffef9;
  border: 2rpx solid rgba(70, 57, 47, 0.12);
  border-radius: 22rpx;
  color: #2f2a24;
  display: flex;
  font-size: 28rpx;
  min-height: 88rpx;
  padding: 0 24rpx;
}

.personal-page {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.personal-panel {
  border-right: 8rpx solid rgba(107, 144, 132, 0.42);
  padding: 28rpx;
}

.age-chip {
  background: rgba(107, 144, 132, 0.12);
  border-radius: 999rpx;
  color: #5d8378;
  display: inline-flex;
  font-size: 22rpx;
  font-weight: 700;
  margin-top: 0;
  padding: 10rpx 20rpx;
}

.field-group {
  margin-top: 28rpx;
}

.field-picker {
  align-items: center;
  background: rgba(252, 250, 245, 0.96);
  border: 2rpx solid rgba(107, 144, 132, 0.12);
  border-radius: 22rpx;
  color: #37423d;
  display: flex;
  font-size: 28rpx;
  min-height: 88rpx;
  padding: 0 24rpx;
}

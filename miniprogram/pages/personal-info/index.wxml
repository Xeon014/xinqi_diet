<view class="page-shell personal-page" wx:if="{{profile}}">
  <view class="panel personal-panel">
    <view class="section-title">个人信息</view>
    <view class="age-chip">{{profile.age == null ? '年龄未设置' : profile.age + ' 岁'}}</view>

    <view class="field-group">
      <view class="field-label">昵称</view>
      <input
        class="field-input"
        value="{{form.name}}"
        data-field="name"
        bindinput="handleInput"
        maxlength="20"
        placeholder="请输入昵称"
      />
    </view>

    <view class="field-group">
      <view class="field-label">性别</view>
      <picker mode="selector" range="{{genderOptions}}" range-key="label" value="{{genderIndex}}" bindchange="handleGenderChange">
        <view class="field-picker">{{genderOptions[genderIndex].label}}</view>
      </picker>
    </view>

    <view class="field-group">
      <view class="field-label">生日</view>
      <picker mode="date" value="{{form.birthDate}}" end="{{maxBirthDate}}" bindchange="handleBirthDateChange">
        <view class="field-picker">{{form.birthDate || '请选择生日'}}</view>
      </picker>
    </view>

    <view class="field-group">
      <view class="field-label">身高(cm)</view>
      <input
        class="field-input"
        type="digit"
        value="{{form.height}}"
        data-field="height"
        bindinput="handleInput"
        placeholder="请输入身高"
      />
    </view>
  </view>

  <view class="primary-button" bindtap="handleSave">保存</view>
</view>

<empty-state wx:else title="资料加载失败" description="下拉刷新后重试。" />

.empty {
  align-items: center;
  border: 1rpx dashed rgba(70, 57, 47, 0.22);
  display: flex;
  flex-direction: column;
  padding: 48rpx 28rpx;
}

.empty-title {
  color: #3b3128;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-description {
  color: #7d7062;
  font-size: 24rpx;
  line-height: 1.6;
  margin-top: 10rpx;
  text-align: center;
}

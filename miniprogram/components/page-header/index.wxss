.page-header {
  margin: -30rpx -26rpx 14rpx;
  padding: 0 26rpx 2rpx;
}

.page-header-card {
  border-bottom: 1rpx solid rgba(70, 57, 47, 0.08);
  border-bottom-left-radius: 34rpx;
  border-bottom-right-radius: 22rpx;
  overflow: hidden;
  padding: 0 26rpx 20rpx;
  position: relative;
}

.scene-home .page-header-card {
  background:
    radial-gradient(circle at 78% 68%, rgba(30, 90, 79, 0.12), transparent 28%),
    radial-gradient(circle at 18% 8%, rgba(197, 106, 61, 0.14), transparent 26%),
    linear-gradient(180deg, rgba(248, 241, 231, 0.98) 0%, rgba(240, 230, 212, 0.96) 100%);
}

.scene-progress .page-header-card {
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.36) 0, rgba(255, 255, 255, 0.36) 18rpx, transparent 18rpx, transparent 36rpx),
    linear-gradient(180deg, rgba(246, 239, 228, 0.98) 0%, rgba(237, 228, 212, 0.95) 100%);
  background-size: 36rpx 36rpx, auto;
}

.scene-profile .page-header-card {
  background:
    radial-gradient(circle at 86% 22%, rgba(197, 106, 61, 0.16), transparent 22%),
    radial-gradient(circle at 24% 78%, rgba(30, 90, 79, 0.12), transparent 24%),
    linear-gradient(180deg, rgba(247, 240, 232, 0.98) 0%, rgba(239, 229, 215, 0.96) 100%);
}

.scene-onboarding .page-header-card {
  background:
    radial-gradient(circle at 82% 18%, rgba(30, 90, 79, 0.14), transparent 22%),
    linear-gradient(180deg, rgba(248, 242, 234, 0.98) 0%, rgba(240, 231, 220, 0.96) 100%);
}

.page-header-nav {
  align-items: center;
  display: flex;
  position: relative;
  z-index: 1;
}

.nav-back,
.nav-slot {
  align-items: center;
  background: rgba(255, 253, 248, 0.56);
  border: 1rpx solid rgba(70, 57, 47, 0.08);
  border-radius: 999rpx;
  display: flex;
  flex-shrink: 0;
  height: 60rpx;
  justify-content: center;
  width: 60rpx;
}

.nav-back {
  justify-content: center;
}

.nav-back-icon {
  border-bottom: 4rpx solid #2f2a24;
  border-left: 4rpx solid #2f2a24;
  height: 18rpx;
  transform: rotate(45deg);
  width: 18rpx;
}

.header-stage {
  align-items: center;
  display: flex;
  justify-content: center;
  margin-top: 8rpx;
  min-height: 166rpx;
  position: relative;
  z-index: 1;
}

.header-stage-full {
  margin-top: 0;
}

.header-art {
  align-items: center;
  display: flex;
  height: 166rpx;
  justify-content: center;
  position: relative;
  width: 100%;
}

.art-home,
.art-progress,
.art-profile,
.art-onboarding {
  height: 100%;
  position: relative;
  width: 100%;
}

.art-home {
  width: 260rpx;
}

.home-plate {
  border-radius: 999rpx;
  position: absolute;
}

.home-plate-outer {
  background: rgba(255, 253, 248, 0.82);
  border: 3rpx solid rgba(30, 90, 79, 0.16);
  height: 144rpx;
  right: 36rpx;
  top: 14rpx;
  width: 144rpx;
}

.home-plate-inner {
  border: 3rpx solid rgba(30, 90, 79, 0.32);
  height: 96rpx;
  right: 60rpx;
  top: 38rpx;
  width: 96rpx;
}

.home-cutlery {
  background: rgba(47, 42, 36, 0.7);
  border-radius: 999rpx;
  height: 96rpx;
  position: absolute;
  top: 40rpx;
  width: 6rpx;
}

.home-cutlery-left {
  left: 46rpx;
}

.home-cutlery-right {
  right: 12rpx;
}

.home-leaf {
  background: linear-gradient(180deg, rgba(30, 90, 79, 0.92), rgba(53, 126, 109, 0.78));
  border-radius: 100% 0 100% 0;
  height: 34rpx;
  position: absolute;
  width: 26rpx;
}

.home-leaf-a {
  right: 108rpx;
  top: 62rpx;
  transform: rotate(-28deg);
}

.home-leaf-b {
  right: 82rpx;
  top: 52rpx;
  transform: rotate(34deg);
}

.home-stem {
  background: rgba(30, 90, 79, 0.7);
  border-radius: 999rpx;
  height: 28rpx;
  position: absolute;
  right: 97rpx;
  top: 80rpx;
  transform: rotate(18deg);
  width: 4rpx;
}

.art-progress {
  width: 250rpx;
}

.progress-bar,
.progress-segment,
.progress-dot {
  position: absolute;
}

.progress-bar {
  background: linear-gradient(180deg, rgba(30, 90, 79, 0.28), rgba(30, 90, 79, 0.12));
  border-radius: 999rpx 999rpx 18rpx 18rpx;
  bottom: 18rpx;
  width: 28rpx;
}

.progress-bar-a {
  height: 54rpx;
  left: 58rpx;
}

.progress-bar-b {
  height: 82rpx;
  left: 108rpx;
}

.progress-bar-c {
  background: linear-gradient(180deg, rgba(197, 106, 61, 0.32), rgba(197, 106, 61, 0.14));
  height: 122rpx;
  left: 158rpx;
}

.progress-segment {
  background: #1e5a4f;
  border-radius: 999rpx;
  height: 5rpx;
  transform-origin: left center;
}

.progress-segment-a {
  left: 70rpx;
  top: 94rpx;
  transform: rotate(-18deg);
  width: 72rpx;
}

.progress-segment-b {
  left: 136rpx;
  top: 72rpx;
  transform: rotate(-28deg);
  width: 68rpx;
}

.progress-dot {
  background: #fffdf8;
  border: 4rpx solid #1e5a4f;
  border-radius: 999rpx;
  height: 18rpx;
  width: 18rpx;
}

.progress-dot-a {
  left: 62rpx;
  top: 88rpx;
}

.progress-dot-b {
  left: 130rpx;
  top: 66rpx;
}

.progress-dot-c {
  border-color: #c56a3d;
  left: 196rpx;
  top: 34rpx;
}

.art-profile {
  width: 238rpx;
}

.profile-orbit,
.profile-head,
.profile-shoulder,
.profile-badge {
  position: absolute;
}

.profile-orbit {
  border: 3rpx solid rgba(30, 90, 79, 0.16);
  border-radius: 999rpx;
}

.profile-orbit-outer {
  height: 148rpx;
  right: 18rpx;
  top: 8rpx;
  width: 148rpx;
}

.profile-orbit-inner {
  border-color: rgba(197, 106, 61, 0.26);
  height: 108rpx;
  right: 38rpx;
  top: 28rpx;
  width: 108rpx;
}

.profile-head {
  background: #1e5a4f;
  border-radius: 999rpx;
  height: 40rpx;
  right: 72rpx;
  top: 46rpx;
  width: 40rpx;
}

.profile-shoulder {
  background: #1e5a4f;
  border-radius: 999rpx 999rpx 28rpx 28rpx;
  height: 46rpx;
  right: 54rpx;
  top: 90rpx;
  width: 76rpx;
}

.profile-badge {
  background: linear-gradient(180deg, rgba(197, 106, 61, 0.92), rgba(214, 137, 93, 0.84));
  border-radius: 999rpx;
  box-shadow: 0 10rpx 20rpx rgba(197, 106, 61, 0.18);
  height: 26rpx;
  right: 28rpx;
  top: 38rpx;
  width: 26rpx;
}

.art-onboarding {
  width: 244rpx;
}

.onboarding-track,
.onboarding-node,
.onboarding-card {
  position: absolute;
}

.onboarding-track {
  background: linear-gradient(90deg, rgba(30, 90, 79, 0.18), rgba(30, 90, 79, 0.62), rgba(197, 106, 61, 0.24));
  border-radius: 999rpx;
  height: 6rpx;
  left: 34rpx;
  top: 84rpx;
  width: 176rpx;
}

.onboarding-node {
  background: #fffdf8;
  border: 4rpx solid rgba(30, 90, 79, 0.26);
  border-radius: 999rpx;
  height: 22rpx;
  top: 76rpx;
  width: 22rpx;
}

.onboarding-node.active {
  border-color: #1e5a4f;
}

.onboarding-node-a {
  left: 32rpx;
}

.onboarding-node-b {
  left: 86rpx;
}

.onboarding-node-c {
  left: 140rpx;
}

.onboarding-node-d {
  border-color: rgba(197, 106, 61, 0.32);
  left: 194rpx;
}

.onboarding-card {
  background: rgba(255, 253, 248, 0.86);
  border: 2rpx solid rgba(70, 57, 47, 0.08);
  border-radius: 18rpx;
  box-shadow: 0 12rpx 20rpx rgba(47, 42, 36, 0.08);
  height: 72rpx;
  left: 118rpx;
  top: 22rpx;
  transform: rotate(-8deg);
  width: 88rpx;
}

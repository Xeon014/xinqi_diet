.card {
  border-top: 8rpx solid rgba(30, 90, 79, 0.76);
  padding: 28rpx;
}

.header {
  align-items: flex-start;
  display: flex;
  justify-content: space-between;
}

.title {
  color: #2f2a24;
  font-size: 34rpx;
  font-weight: 700;
}

.subtitle {
  color: #7a6d60;
  font-size: 24rpx;
  line-height: 1.55;
  margin-top: 10rpx;
}

.metrics {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
}

.metric {
  background: rgba(70, 57, 47, 0.06);
  border-radius: 22rpx;
  flex: 1;
  min-height: 140rpx;
  padding: 24rpx;
}

.metric.primary {
  background: linear-gradient(136deg, rgba(30, 90, 79, 0.16) 0%, rgba(30, 90, 79, 0.06) 100%);
  border: 1rpx solid rgba(30, 90, 79, 0.14);
  flex: 1.25;
}

.metric-label {
  color: #74685c;
  font-size: 22rpx;
}

.metric-value {
  color: #1f4f45;
  font-size: 52rpx;
  font-weight: 700;
  margin-top: 14rpx;
}

.metric-unit,
.metric-small {
  color: #53483d;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.danger {
  color: #b95e3a;
}

.success {
  color: #1e5a4f;
}

<view class="card panel">
  <view class="header">
    <view>
      <view class="title">{{title}}</view>
      <view class="subtitle">{{subtitle}}</view>
    </view>
    <view wx:if="{{exceededTarget}}" class="pill pill-danger">已超目标</view>
    <view wx:else class="pill pill-success">状态良好</view>
  </view>

  <view class="metrics">
    <view class="metric primary">
      <view class="metric-label">已摄入</view>
      <view class="metric-value">{{displayConsumedCalories}}</view>
      <view class="metric-unit">kcal</view>
    </view>
    <view class="metric">
      <view class="metric-label">目标</view>
      <view class="metric-small">{{displayTargetCalories}} kcal</view>
    </view>
    <view class="metric">
      <view class="metric-label">剩余</view>
      <view class="metric-small {{exceededTarget ? 'danger' : 'success'}}">{{displayRemainingCalories}} kcal</view>
    </view>
  </view>
</view>
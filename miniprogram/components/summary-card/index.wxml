<view class="card panel">
  <view class="header">
    <view>
      <view class="title">{{title}}</view>
      <view class="subtitle">{{subtitle}}</view>
    </view>
    <view wx:if="{{exceededTarget}}" class="pill pill-danger">&#x5df2;&#x8d85;&#x76ee;&#x6807;</view>
    <view wx:else class="pill pill-success">&#x72b6;&#x6001;&#x826f;&#x597d;</view>
  </view>

  <view class="metrics">
    <view class="metric primary">
      <view class="metric-label">&#x5df2;&#x6444;&#x5165;</view>
      <view class="metric-value">{{consumedCalories}}</view>
      <view class="metric-unit">kcal</view>
    </view>
    <view class="metric">
      <view class="metric-label">&#x76ee;&#x6807;</view>
      <view class="metric-small">{{targetCalories}} kcal</view>
    </view>
    <view class="metric">
      <view class="metric-label">&#x5269;&#x4f59;</view>
      <view class="metric-small {{exceededTarget ? 'danger' : 'success'}}">{{remainingCalories}} kcal</view>
    </view>
  </view>
</view>
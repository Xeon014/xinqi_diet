.sheet-overlay {
  background: rgba(24, 20, 16, 0.44);
  bottom: 0;
  left: 0;
  position: fixed;
  right: 0;
  top: 0;
  z-index: 120;
}

.bottom-sheet {
  background:
    linear-gradient(180deg, rgba(255, 250, 242, 0.98) 0%, rgba(248, 239, 226, 0.98) 100%),
    #fff9f1;
  border: 1rpx solid rgba(70, 57, 47, 0.12);
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  bottom: 0;
  box-shadow:
    0 -8rpx 22rpx rgba(34, 27, 21, 0.06),
    0 -28rpx 56rpx rgba(34, 27, 21, 0.18),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
  left: 0;
  padding: 24rpx 26rpx calc(34rpx + env(safe-area-inset-bottom));
  position: fixed;
  right: 0;
  z-index: 121;
}

.sheet-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 2rpx;
}

.sheet-title {
  color: #2f2a24;
  font-size: 34rpx;
  font-weight: 700;
}

.sheet-close {
  align-items: center;
  background: rgba(70, 57, 47, 0.08);
  border-radius: 999rpx;
  color: #7f7264;
  display: flex;
  font-size: 32rpx;
  height: 56rpx;
  justify-content: center;
  line-height: 1;
  width: 56rpx;
}

.sheet-close:active {
  opacity: 0.8;
}

.sheet-date,
.sheet-date-picker {
  color: #7a6e61;
  font-size: 23rpx;
  margin-top: 12rpx;
}

.sheet-date-picker {
  background: rgba(30, 90, 79, 0.08);
  border: 1rpx solid rgba(30, 90, 79, 0.12);
  border-radius: 14rpx;
  display: inline-flex;
  padding: 8rpx 16rpx;
}

.sheet-input-row {
  align-items: center;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid rgba(70, 57, 47, 0.16);
  border-radius: 20rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
  display: flex;
  margin-top: 20rpx;
  overflow: hidden;
}

.sheet-input {
  flex: 1;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 38rpx;
  height: 92rpx;
  padding: 0 22rpx;
}

.sheet-unit {
  color: #6f6458;
  font-size: 26rpx;
  font-weight: 700;
  min-width: 94rpx;
  text-align: center;
}

.sheet-submit-btn {
  align-items: center;
  background: linear-gradient(128deg, #1e5a4f 0%, #2a7364 100%);
  border-radius: 999rpx;
  color: #fffef8;
  display: flex;
  font-size: 28rpx;
  font-weight: 700;
  height: 88rpx;
  justify-content: center;
  margin-top: 24rpx;
}

.sheet-submit-btn.disabled {
  opacity: 0.6;
}

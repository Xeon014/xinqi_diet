.sheet-overlay {
  background: rgba(40, 43, 42, 0.3);
  bottom: 0;
  left: 0;
  position: fixed;
  right: 0;
  top: 0;
  z-index: 120;
}

.bottom-sheet {
  background:
    linear-gradient(180deg, rgba(253, 250, 245, 0.98) 0%, rgba(247, 242, 235, 0.98) 100%),
    #fcfaf5;
  border: 1rpx solid rgba(107, 144, 132, 0.1);
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  border-top-left-radius: 36rpx;
  border-top-right-radius: 36rpx;
  bottom: 0;
  box-shadow:
    0 -8rpx 22rpx rgba(57, 65, 62, 0.06),
    0 -24rpx 48rpx rgba(57, 65, 62, 0.12),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.74);
  display: flex;
  flex-direction: column;
  left: 0;
  max-height: calc(100vh - 88rpx);
  padding: 24rpx 26rpx calc(26rpx + env(safe-area-inset-bottom));
  position: fixed;
  right: 0;
  transition: bottom 160ms ease;
  z-index: 121;
}

.sheet-body {
  flex: 1;
  min-height: 0;
}

.sheet-head {
  align-items: center;
  display: flex;
  justify-content: space-between;
  margin-bottom: 2rpx;
}

.sheet-title {
  color: #3b4842;
  font-size: 34rpx;
  font-weight: 700;
}

.sheet-close {
  align-items: center;
  background: rgba(107, 144, 132, 0.08);
  border-radius: 999rpx;
  color: #75756e;
  display: flex;
  font-size: 32rpx;
  height: 56rpx;
  justify-content: center;
  line-height: 1;
  width: 56rpx;
}

.sheet-close:active {
  opacity: 0.8;
}

.sheet-actions {
  background: linear-gradient(180deg, rgba(250, 247, 241, 0) 0%, rgba(247, 242, 235, 0.96) 18%, rgba(247, 242, 235, 1) 100%);
  margin-top: 22rpx;
  padding-top: 12rpx;
}

.sheet-date,
.sheet-date-picker {
  color: #7d7c74;
  font-size: 23rpx;
  margin-top: 12rpx;
}

.sheet-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.sheet-date-trigger {
  display: inline-flex;
}

.sheet-date-picker {
  background: rgba(107, 144, 132, 0.08);
  border: 1rpx solid rgba(107, 144, 132, 0.12);
  border-radius: 14rpx;
  display: inline-flex;
  padding: 8rpx 16rpx;
}

.sheet-input-row {
  align-items: center;
  background: rgba(253, 251, 247, 0.96);
  border: 1rpx solid rgba(107, 144, 132, 0.12);
  border-radius: 20rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.6);
  display: flex;
  margin-top: 20rpx;
  overflow: hidden;
}

.sheet-input {
  flex: 1;
  font-family: "DIN Alternate", "PingFang SC", sans-serif;
  font-size: 38rpx;
  height: 92rpx;
  padding: 0 22rpx;
}

.sheet-unit {
  color: #75756e;
  font-size: 26rpx;
  font-weight: 700;
  min-width: 94rpx;
  text-align: center;
}

.sheet-submit-btn {
  align-items: center;
  background: linear-gradient(135deg, #6f968b 0%, #5d8378 100%);
  border-radius: 999rpx;
  color: #fffef8;
  display: flex;
  font-size: 28rpx;
  font-weight: 700;
  height: 88rpx;
  justify-content: center;
}

.sheet-submit-btn.disabled {
  opacity: 0.6;
}

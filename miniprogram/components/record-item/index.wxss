.item {
  align-items: center;
  border-bottom: 1rpx solid rgba(93, 76, 58, 0.08);
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
}

.item:last-child {
  border-bottom: 0;
  padding-bottom: 0;
}

.name {
  color: #35291f;
  font-size: 30rpx;
  font-weight: 600;
}

.meta {
  color: #8f8373;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.side {
  text-align: right;
}

.calories {
  color: #1f6f5f;
  font-size: 34rpx;
  font-weight: 700;
}

.unit {
  color: #8f8373;
  font-size: 22rpx;
  margin-top: 8rpx;
}
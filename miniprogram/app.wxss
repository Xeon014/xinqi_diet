page {
  background:
    radial-gradient(circle at 12% 0%, rgba(107, 144, 132, 0.1), transparent 34%),
    radial-gradient(circle at 88% 8%, rgba(196, 167, 140, 0.1), transparent 30%),
    linear-gradient(180deg, #f7f5ef 0%, #f2efe8 56%, #eeebe4 100%);
  color: #37423d;
  font-family: "PingFang SC", "Noto Sans SC", sans-serif;
  min-height: 100%;
}

page,
view,
text,
input,
picker {
  box-sizing: border-box;
}

.page-shell {
  padding: 16rpx 26rpx 52rpx;
}

.panel {
  background:
    linear-gradient(180deg, rgba(253, 252, 248, 0.98) 0%, rgba(248, 245, 238, 0.95) 100%),
    #fcfaf5;
  border: 1rpx solid rgba(91, 126, 115, 0.11);
  border-radius: 32rpx;
  box-shadow:
    0 14rpx 30rpx rgba(68, 78, 73, 0.07),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}

.section-title {
  color: #3b4842;
  font-size: 34rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.section-subtitle {
  color: #7d7c74;
  font-size: 24rpx;
  line-height: 1.55;
}

.primary-button {
  align-items: center;
  background: linear-gradient(135deg, #6f968b 0%, #5d8378 100%);
  border: 1rpx solid rgba(93, 131, 120, 0.2);
  border-radius: 999rpx;
  box-shadow: 0 10rpx 20rpx rgba(70, 104, 95, 0.16);
  color: #fcfffd;
  display: flex;
  font-size: 28rpx;
  font-weight: 700;
  height: 90rpx;
  justify-content: center;
  letter-spacing: 1rpx;
}

.primary-button:active {
  opacity: 0.92;
  transform: translateY(2rpx);
}

.ghost-button {
  align-items: center;
  background: rgba(107, 144, 132, 0.08);
  border: 1rpx solid rgba(107, 144, 132, 0.16);
  border-radius: 999rpx;
  color: #5d8378;
  display: flex;
  font-size: 26rpx;
  font-weight: 600;
  height: 84rpx;
  justify-content: center;
}

.ghost-button:active {
  opacity: 0.86;
}

.pill {
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
  padding: 10rpx 20rpx;
}

.pill-success {
  background: rgba(107, 144, 132, 0.12);
  color: #5d8378;
}

.pill-danger {
  background: rgba(187, 134, 108, 0.14);
  color: #bb866c;
}

.field-label {
  color: #73756d;
  font-size: 24rpx;
  margin-bottom: 12rpx;
}

.field-input {
  background: rgba(254, 252, 248, 0.96);
  border: 2rpx solid rgba(107, 144, 132, 0.12);
  border-radius: 24rpx;
  color: #37423d;
  font-size: 28rpx;
  height: 88rpx;
  padding: 0 24rpx;
  width: 100%;
}
